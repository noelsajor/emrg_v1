---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque en Salud | EMRG" description="SEO y crecimiento digital especializado en salud. Ayudamos a clínicas y médicos a atraer más pacientes.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-health">
          <div class="hero-copy">
            <p class="scene-label">SEO y crecimiento digital especializado en salud</p>
            <h1 class="hero-title">Más visibilidad en Google. <span class="accent">Más pacientes.</span></h1>
            <p class="hero-sub">
              Ayudamos a médicos, dentistas, clínicas y consultorios a atraer pacientes
              cualificados con SEO para clínicas, diseño web para médicos, CRO y estrategia
              digital enfocada en resultados reales.
            </p>

            <div class="hero-actions-health">
              <button class="nav-cta" onclick="window.goToScene(5)">Solicitar auditoría gratuita</button>
              <button class="btn-outline-health" onclick="window.goToScene(4)">Ver casos de éxito</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">Especialización Salud</span>
               <span class="chip-pill">SEO Local</span>
               <span class="chip-pill">Web Médica</span>
            </div>
          </div>

          <aside class="hero-card-health">
            <div class="stat-cell-health">
              <div class="stat-figure-health">Captación</div>
              <div class="stat-desc-health">Enfoque principal</div>
            </div>
            <div class="stat-cell-health">
              <div class="stat-figure-health">SEO+Web+CRO</div>
              <div class="stat-desc-health">Servicios clave</div>
            </div>
            <div class="hero-note-health">
              <p>
                Una estrategia digital médica no debe atraer tráfico genérico. Debe atraer
                búsquedas con intención y generar confianza.
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Problema</p>
          <h2 class="scene-title">Muchos centros de salud tienen presencia digital, pero no un sistema que <em>genere pacientes.</em></h2>
        </div>

        <div class="pillars-grid-health">
          <article class="pillar-row-health">
            <span class="pillar-num">01</span>
            <div class="pillar-content">
              <h3 class="pillar-name">No apareces en búsquedas clave</h3>
              <p class="pillar-tagline">Si tu clínica no posiciona para términos locales, estás perdiendo demanda activa cada semana.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">02</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Tu web no convierte</h3>
              <p class="pillar-tagline">Muchas webs médicas informan, pero no guían al usuario hacia una acción clara: reservar o llamar.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">03</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Dependes de recomendaciones</h3>
              <p class="pillar-tagline">Los referidos ayudan, pero no son predecibles para llenar agendas de forma consistente.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">04</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Competencia local activa</h3>
              <p class="pillar-tagline">Clínicas con mejor SEO y mejores reseñas terminan captando al paciente antes que tú.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Autoridad</p>
          <h2 class="scene-title">Propuesta creada para el <em>contexto real</em> del sector salud.</h2>
          <p class="hero-sub" style="margin: 0; max-width: 600px;">Diseñamos estrategias para especialidades y clínicas que necesitan visibilidad local y autoridad digital.</p>
        </div>

        <div class="work-scroll-track-health">
          <article class="case-card-imm">
            <span class="case-tag-imm">SEO Especializado</span>
            <h3 class="case-brand-imm">Especialidades Médicas</h3>
            <p class="case-desc-imm">Arquitectura de contenidos y optimización local enfocada en búsquedas con intención de cita.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Diseño UX</span>
            <h3 class="case-brand-imm">Web de Confianza</h3>
            <p class="case-desc-imm">Estructuras claras y una experiencia que reduce la fricción para agendar pacientes.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Conversión</span>
            <h3 class="case-brand-imm">CRO Salud</h3>
            <p class="case-desc-imm">Mejoramos formularios y pruebas sociales para aumentar contactos cualificados.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Servicios</p>
          <h2 class="scene-title">Estrategias diseñadas para el <em>crecimiento local.</em></h2>
        </div>

        <div class="services-grid-health">
          <div class="service-item-health">
             <span class="pillar-num">01</span>
             <h3 class="case-brand-imm">SEO para Médicos</h3>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">02</span>
             <h3 class="case-brand-imm">SEO para Dentistas</h3>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">03</span>
             <h3 class="case-brand-imm">SEO para Clínicas</h3>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">04</span>
             <h3 class="case-brand-imm">SEO Local</h3>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">05</span>
             <h3 class="case-brand-imm">Web Médica</h3>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">06</span>
             <h3 class="case-brand-imm">Marketing Clínico</h3>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Casos de Éxito</p>
          <h2 class="scene-title">Resultados en <em>Visibilidad y Confianza.</em></h2>
        </div>

        <div class="cases-row-health">
          <article class="case-card-imm featured-case">
             <h3 class="case-brand-imm">Clínica Dental X</h3>
             <p class="case-desc-imm">De una web informativa a una página que genera solicitudes de valoración.</p>
             <div class="case-metrics-imm">
                <div class="case-metric-row"><span class="case-metric-lbl">Visibilidad Local</span><span class="case-metric-val">+80%</span></div>
                <div class="case-metric-row"><span class="case-metric-lbl">Tasa de Contacto</span><span class="case-metric-val">+15%</span></div>
             </div>
          </article>
          <article class="case-card-imm">
             <h3 class="case-brand-imm">Consultorio Especialistas</h3>
             <p class="case-desc-imm">SEO local para captar pacientes de zonas cercanas con enfoque en reserva.</p>
          </article>
           <article class="case-card-imm">
             <h3 class="case-brand-imm">Centro Multiservicio</h3>
             <p class="case-desc-imm">Arquitectura pensada para crecer sin canibalizar especialidades.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-health">
         <div class="form-copy-health">
            <p class="scene-label">Auditoría</p>
            <h2 class="scene-title">Solicita un <em>Diagnóstico Digital.</em></h2>
            <p class="hero-sub">Analizamos tu posicionamiento actual y detectamos barreras de conversión.</p>
         </div>
         <form class="qualification-form-health" action="#" method="post">
            <div class="form-row">
               <input type="text" placeholder="NOMBRE" required />
            </div>
            <div class="form-row">
               <input type="text" placeholder="CLÍNICA O ESPECIALIDAD" required />
            </div>
            <div class="form-row">
               <input type="email" placeholder="EMAIL" required />
            </div>
            <div class="form-row">
               <select required>
                  <option value="">OBJETIVO PRINCIPAL</option>
                  <option>Atraer más pacientes</option>
                  <option>Mejorar posicionamiento</option>
                  <option>Rediseñar la web</option>
               </select>
            </div>
            <button class="nav-cta" type="submit">Enviar Solicitud</button>
            <p class="form-success-health" style="margin-top: 1rem; color: var(--teal); font-size: 0.8rem;"></p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-health {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-actions-health {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-health {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-health:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .hero-card-health {
    background: rgba(11, 21, 32, 0.4);
    border: 1px solid var(--rim2);
    backdrop-filter: blur(12px);
    padding: 40px;
  }

  .stat-cell-health {
    margin-bottom: 24px;
    border-bottom: 1px solid var(--rim);
    padding-bottom: 12px;
  }

  .stat-figure-health {
    font-family: var(--title);
    font-size: 2.5rem;
    color: var(--white);
    line-height: 1;
  }

  .stat-desc-health {
    font-size: 0.7rem;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-note-health {
    font-size: 0.85rem;
    color: var(--smoke);
    line-height: 1.6;
    margin-top: 20px;
  }

  .pillars-grid-health {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 60px;
    margin-top: 40px;
  }

  .pillar-row-health {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rim);
  }

  .pillar-num {
    font-family: var(--body);
    font-size: 0.7rem;
    color: var(--teal);
    font-weight: 600;
  }

  .pillar-name {
    font-family: var(--title);
    font-size: 1.8rem;
    margin-bottom: 8px;
    color: var(--white);
  }

  .pillar-tagline {
    font-size: 0.85rem;
    color: var(--smoke);
  }

  .work-scroll-track-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 60px;
  }

  .services-grid-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rim);
    border: 1px solid var(--rim);
    width: 100%;
  }

  .service-item-health {
    background: var(--surface);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cases-row-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .featured-case {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .form-split-health {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .qualification-form-health {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    font-family: var(--body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 15px var(--teal-glow);
  }

  @media (max-width: 1024px) {
    .hero-grid-health, .pillars-grid-health, .work-scroll-track-health, .services-grid-health, .cases-row-health, .form-split-health {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector(".qualification-form-health");
    if (form) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const success = form.querySelector(".form-success-health");
        form.reset();
        if (success) success.textContent = "SOLICITUD RECIBIDA CON ÉXITO.";
      });
    }
  });
</script>
