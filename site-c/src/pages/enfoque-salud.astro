---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque en Salud | EMRG" description="SEO y crecimiento digital especializado en salud. Ayudamos a clínicas y médicos a atraer más pacientes.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-health">
          <div class="hero-copy">
            <p class="scene-label">Sector Salud</p>
            <h1 class="hero-title">¿Tus pacientes te buscan en Google o <span class="accent">solo te encuentran por recomendación?</span></h1>
            <p class="hero-sub">
              Creamos sitios web que generan confianza y citas médicas en automático. 
              Diseño web para médicos y clínicas que buscan autoridad digital.
            </p>

            <div class="hero-actions-health">
              <button class="nav-cta" onclick="window.goToScene(5)">Quiero digitalizar mi consulta</button>
              <button class="btn-outline-health" onclick="window.goToScene(3)">Ver servicios</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">Especialización Salud</span>
               <span class="chip-pill">SEO Local</span>
               <span class="chip-pill">Web Médica</span>
            </div>
          </div>

          <aside class="hero-image-scene">
            <img src="/images/hero-medical.png" alt="Consultorio" class="hero-img-scene" />
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">El Problema</p>
          <h2 class="scene-title">¿Tu web actual parece un <em class="accent">folleto viejo?</em></h2>
          <p class="hero-sub">
            La autoridad digital en salud no se improvisa. Si no transmites confianza 
            desde el primer clic, estás perdiendo pacientes.
          </p>
        </div>

        <div class="pillars-grid-health">
          <article class="pillar-row-health">
            <span class="pillar-num">01</span>
            <div class="pillar-content">
              <h3 class="pillar-name">No apareces en búsquedas clave</h3>
              <p class="pillar-tagline">Si tu clínica no posiciona para términos locales, estás perdiendo demanda activa cada semana.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">02</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Tu web no convierte</h3>
              <p class="pillar-tagline">Muchas webs médicas informan, pero no guían al usuario hacia una acción clara: reservar o llamar.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">03</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Dependes de recomendaciones</h3>
              <p class="pillar-tagline">Los referidos ayudan, pero no son predecibles para llenar agendas de forma consistente.</p>
            </div>
          </article>
          <article class="pillar-row-health">
            <span class="pillar-num">04</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Competencia local activa</h3>
              <p class="pillar-tagline">Clínicas con mejor SEO y mejores reseñas terminan captando al paciente antes que tú.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Autoridad</p>
          <h2 class="scene-title">Propuesta creada para el <em>contexto real</em> del sector salud.</h2>
          <p class="hero-sub" style="margin: 0; max-width: 600px;">Diseñamos estrategias para especialidades y clínicas que necesitan visibilidad local y autoridad digital.</p>
        </div>

        <div class="work-scroll-track-health">
          <article class="case-card-imm">
            <span class="case-tag-imm">SEO Especializado</span>
            <h3 class="case-brand-imm">Especialidades Médicas</h3>
            <p class="case-desc-imm">Arquitectura de contenidos y optimización local enfocada en búsquedas con intención de cita.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Diseño UX</span>
            <h3 class="case-brand-imm">Web de Confianza</h3>
            <p class="case-desc-imm">Estructuras claras y una experiencia que reduce la fricción para agendar pacientes.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Conversión</span>
            <h3 class="case-brand-imm">CRO Salud</h3>
            <p class="case-desc-imm">Mejoramos formularios y pruebas sociales para aumentar contactos cualificados.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">La Solución</p>
          <h2 class="scene-title">Servicios con <em class="accent">estándar médico.</em></h2>
        </div>

        <div class="services-grid-health">
          <div class="service-item-health">
             <span class="pillar-num">01</span>
             <h3 class="case-brand-imm">Diseño UX/UI Médico</h3>
             <p class="pillar-tagline">Webs rápidas y confiables optimizadas para citas.</p>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">02</span>
             <h3 class="case-brand-imm">SEO Local (Map Pack)</h3>
             <p class="pillar-tagline">Aparece cuando busquen tu especialidad en tu ciudad.</p>
          </div>
          <div class="service-item-health">
             <span class="pillar-num">03</span>
             <h3 class="case-brand-imm">Contenido Experto</h3>
             <p class="pillar-tagline">Artículos que responden las dudas de tus pacientes.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Casos de Éxito</p>
          <h2 class="scene-title">Resultados en <em class="accent">Visibilidad y Confianza.</em></h2>
        </div>

        <div class="cases-row-health">
          <article class="case-card-imm featured-case">
             <h3 class="case-brand-imm">Clínica Dental X</h3>
             <p class="case-desc-imm">De una web informativa a una página que genera solicitudes de valoración.</p>
             <div class="case-metrics-imm">
                <div class="case-metric-row"><span class="case-metric-lbl">Visibilidad Local</span><span class="case-metric-val">+80%</span></div>
                <div class="case-metric-row"><span class="case-metric-lbl">Tasa de Contacto</span><span class="case-metric-val">+15%</span></div>
             </div>
          </article>
          <article class="case-card-imm">
             <h3 class="case-brand-imm">Consultorio Especialistas</h3>
             <p class="case-desc-imm">SEO local para captar pacientes de zonas cercanas con enfoque en reserva.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4-proof">
      <div class="content-wrap">
        <div class="section-header-health">
          <p class="scene-label">Prueba Social</p>
          <h2 class="scene-title">Confianza avalada por el <em class="accent">sector.</em></h2>
        </div>

        <div class="testimonial-carousel-container-imm">
          <div class="testimonial-track-imm" id="testimonial-track">
            <article class="testimonial-slide-imm active">
              <p>“Profesionales que entienden las necesidades específicas de nosotros los especialistas.”</p>
              <strong>Dr. Alejandro Ruiz — Dermatólogo</strong>
            </article>
            <article class="testimonial-slide-imm">
              <p>“Mi clínica duplicó las citas desde que renovamos la web con el enfoque SEO local.”</p>
              <strong>Dra. Elena Martínez — Clínica Dental</strong>
            </article>
            <article class="testimonial-slide-imm">
              <p>“La autoridad digital que hemos construido nos ha permitido dejar de depender de referidos.”</p>
              <strong>Dr. Roberto Silva — Cirujano Plástico</strong>
            </article>
          </div>
          <div class="carousel-dots-imm">
            <button class="dot-imm active" aria-label="Slide 1"></button>
            <button class="dot-imm" aria-label="Slide 2"></button>
            <button class="dot-imm" aria-label="Slide 3"></button>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-health">
         <div class="form-copy-health">
            <p class="scene-label">Diagnóstico</p>
            <h2 class="scene-title">Quiero digitalizar mi consulta y <em class="accent">atraer más pacientes.</em></h2>
            <p class="hero-sub">Agenda tu auditoría gratuita y descubre cómo podemos ayudarte.</p>
         </div>
         <form class="qualification-form-health" action="#" method="post">
            <div class="form-row">
               <input type="text" placeholder="NOMBRE" required />
            </div>
            <div class="form-row">
               <input type="text" placeholder="CLÍNICA O ESPECIALIDAD" required />
            </div>
            <div class="form-row">
               <input type="email" placeholder="EMAIL" required />
            </div>
            <div class="form-row">
               <select required>
                  <option value="">OBJETIVO PRINCIPAL</option>
                  <option>Atraer más pacientes</option>
                  <option>Mejorar posicionamiento</option>
                  <option>Rediseñar la web</option>
                  <option>Reducir dependencia de referidos</option>
               </select>
            </div>
            <button class="nav-cta" type="submit">Quiero mi auditoría ahora</button>
            <p class="form-success-health" style="margin-top: 1rem; color: var(--teal); font-size: 0.8rem;"></p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .section-header-health {
    margin-bottom: 48px;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-health {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-grid-health .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-grid-health .hero-sub {
    max-width: 480px;
    text-align: left;
    margin: 0 0 32px;
  }

  .scene-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
  }

  .hero-actions-health {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-health {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-health:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .hero-card-health {
    background: rgba(11, 21, 32, 0.4);
    border: 1px solid var(--rim2);
    backdrop-filter: blur(12px);
    padding: 40px;
  }

  .stat-cell-health {
    margin-bottom: 24px;
    border-bottom: 1px solid var(--rim);
    padding-bottom: 12px;
  }

  .stat-figure-health {
    font-family: var(--title);
    font-size: 2.5rem;
    color: var(--white);
    line-height: 1;
  }

  .stat-desc-health {
    font-size: 0.7rem;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-note-health {
    font-size: 0.85rem;
    color: var(--smoke);
    line-height: 1.6;
    margin-top: 20px;
  }

  /* Image Scene Styles */
  .hero-image-scene {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--rim2);
    box-shadow: 0 0 50px rgba(186, 211, 65, 0.2);
    transform: perspective(1000px) rotateY(-5deg);
    transition: all 0.5s;
    width: 100%;
  }

  .hero-image-scene:hover {
    transform: perspective(1000px) rotateY(0deg) scale(1.02);
    box-shadow: 0 0 70px rgba(186, 211, 65, 0.4);
  }

  .hero-img-scene {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  /* Carousel Styles for Scene */
  .testimonial-carousel-container-imm {
    margin-top: 40px;
    position: relative;
    overflow: hidden;
    padding-bottom: 60px;
  }

  .testimonial-track-imm {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-slide-imm {
    min-width: 100%;
    padding: 60px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--rim);
    text-align: center;
    opacity: 0.3;
    transform: scale(0.9);
    transition: all 0.5s;
  }

  .testimonial-slide-imm.active {
    opacity: 1;
    transform: scale(1);
    border-color: var(--teal);
    background: rgba(186, 211, 65, 0.05);
  }

  .testimonial-slide-imm p {
    font-size: 1.8rem;
    font-style: italic;
    color: var(--white);
    margin-bottom: 24px;
    font-family: var(--title);
  }

  .carousel-dots-imm {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  .dot-imm {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rim2);
    border: none;
    cursor: pointer;
    transition: 0.3s;
  }

  .dot-imm.active {
    background: var(--teal);
    width: 20px;
    border-radius: 10px;
  }

  .pillars-grid-health {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 60px;
    margin-top: 0;
  }

  .pillar-row-health {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rim);
  }

  .pillar-num {
    font-family: var(--body);
    font-size: 0.7rem;
    color: var(--teal);
    font-weight: 600;
  }

  .pillar-name {
    font-family: var(--title);
    font-size: 1.8rem;
    margin-bottom: 8px;
    color: var(--white);
  }

  .pillar-tagline {
    font-size: 0.85rem;
    color: var(--smoke);
  }

  .work-scroll-track-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 0;
  }

  .services-grid-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rim);
    border: 1px solid var(--rim);
    width: 100%;
  }

  .service-item-health {
    background: var(--surface);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cases-row-health {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 0;
  }

  .featured-case {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .form-split-health {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .qualification-form-health {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    font-family: var(--body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 15px var(--teal-glow);
  }

  @media (max-width: 1024px) {
    .hero-grid-health, .pillars-grid-health, .work-scroll-track-health, .services-grid-health, .cases-row-health, .form-split-health {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector(".qualification-form-health");
    if (form) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const success = form.querySelector(".form-success-health");
        form.reset();
        if (success) success.textContent = "SOLICITUD RECIBIDA CON ÉXITO.";
      });
    }

    // Carousel Logic
    const track = document.getElementById('testimonial-track');
    const slides = Array.from(track ? track.children : []);
    const dots = Array.from(document.querySelectorAll('.dot-imm'));
    let currentIndex = 0;

    function updateCarousel(idx) {
      if (!track) return;
      track.style.transform = `translateX(-${idx * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      currentIndex = idx;
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => updateCarousel(i));
    });

    if (slides.length > 0) {
      setInterval(() => {
        let next = (currentIndex + 1) % slides.length;
        updateCarousel(next);
      }, 5000);
    }
  });
</script>
