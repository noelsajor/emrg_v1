---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque Retail y Mayoristas | EMRG" description="Gestión integral de marketing digital para negocios que venden en grande. Infraestructura e-commerce y SEO para catálogos masivos.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-retail">
          <div class="hero-copy">
            <p class="scene-label">Infraestructura para Retail & Mayoristas</p>
            <h1 class="hero-title">Vende en <span class="accent">Grande.</span></h1>
            <p class="hero-sub">
              Lleva tu inventario a las pantallas de tus clientes ideales. Gestión integral de marketing digital para negocios que operan en gran volumen.
            </p>

            <div class="hero-actions-retail">
              <button class="nav-cta" onclick="window.goToScene(5)">Escalar mis Ventas</button>
              <button class="btn-outline-retail" onclick="window.goToScene(2)">Ver Servicios</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">High Performance</span>
               <span class="chip-pill">Inventory Growth</span>
               <span class="chip-pill">Enterprise Scale</span>
            </div>
          </div>

          <aside class="hero-card-retail">
             <img src="/images/hero-retail.png" alt="Retail Management" style="width: 100%; border-radius: 4px; opacity: 0.8;" />
             <p class="card-note">Ingeniería preparada para picos de tráfico extremo y operaciones logísticas de alto impacto.</p>
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-retail">
          <p class="scene-label">Resultados</p>
          <h2 class="scene-title">Crecimiento <em>Sistematizado.</em></h2>
        </div>

        <div class="results-dashboard-retail">
           <div class="chart-box">
              <div class="chart-header">
                 <span>Traffic Index</span>
                 <strong>+120%</strong>
              </div>
              <div class="mini-chart">
                 <div class="line" style="height: 30%"></div>
                 <div class="line" style="height: 45%"></div>
                 <div class="line" style="height: 60%"></div>
                 <div class="line" style="height: 85%"></div>
                 <div class="line" style="height: 100%"></div>
              </div>
           </div>
           <div class="chart-box accent-box">
              <div class="chart-header">
                 <span>Sales Velocity</span>
                 <strong>+45%</strong>
              </div>
              <div class="mini-chart">
                 <div class="line" style="height: 20%"></div>
                 <div class="line" style="height: 40%"></div>
                 <div class="line" style="height: 55%"></div>
                 <div class="line" style="height: 70%"></div>
                 <div class="line" style="height: 90%"></div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap">
        <div class="section-header-retail">
          <p class="scene-label">Servicios</p>
          <h2 class="scene-title">Infraestructura de <em>Alto Rendimiento.</em></h2>
        </div>

        <div class="solutions-grid-retail">
          <div class="sol-item">
            <span class="pillar-num">01</span>
            <h3>Tiendas High-End</h3>
            <p>E-commerce robusto para catálogos dinámicos y gran volumen de transacciones.</p>
          </div>
          <div class="sol-item">
            <span class="pillar-num">02</span>
            <h3>Email Automático</h3>
            <p>Sistemas que recuperan carritos y cierran ventas de forma autónoma.</p>
          </div>
          <div class="sol-item">
            <span class="pillar-num">03</span>
            <h3>SEO de Categoría</h3>
            <p>Visibilidad total para tus secciones de mayor demanda y productos estrella.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-retail">
          <p class="scene-label">Diferenciador</p>
          <h2 class="scene-title">Contenido que <em>Convierte.</em></h2>
        </div>
        
        <div class="value-prop-retail">
           <p class="big-quote">"Estrategias de contenido integral que convierten seguidores en compradores. Gestión de redes sociales enfocada 100% en catálogo y conversión comercial."</p>
           <div class="value-icons">
              <div class="v-pill">Social Selling</div>
              <div class="v-pill">ROI Focused</div>
              <div class="v-pill">Catalog Sync</div>
           </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4">
      <div class="content-wrap">
         <div class="section-header-retail">
            <p class="scene-label">Capacidades</p>
            <h2 class="scene-title">Evolución <em>Retail.</em></h2>
         </div>
         <div class="retail-stats-grid">
            <div class="stat-card">
               <span class="stat-val">99%</span>
               <p>Eficiencia en sincronización de stock real.</p>
            </div>
            <div class="stat-card">
               <span class="stat-val">3x</span>
               <p>Aumento promedio en tickets recurrentes.</p>
            </div>
            <div class="stat-card">
               <span class="stat-val">+60%</span>
               <p>Aperturas en campañas automatizadas.</p>
            </div>
         </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-retail">
         <div class="form-copy-retail">
            <p class="scene-label">Consultoría</p>
            <h2 class="scene-title">Escalar <em>Hoy.</em></h2>
            <p class="hero-sub">Analizamos tu operación logística y digital para diseñar el siguiente nivel de tu ecommerce.</p>
         </div>
         <form class="qualification-form-retail personal-form">
            <input type="text" placeholder="NOMBRE COMPLETO" required />
            <input type="text" placeholder="EMPRESA / RETAILER" required />
            <input type="email" placeholder="EMAIL CORPORATIVO" required />
            <select required>
               <option value="">OBJETIVO DE ESCALADO</option>
               <option>Aumentar Conversión</option>
               <option>Automatizar Marketing</option>
               <option>Lanzar Nuevo Catálogo</option>
            </select>
            <button class="nav-cta" type="submit">Hablemos de tus Ventas</button>
            <p class="form-success-retail" style="display:none; margin-top: 1rem; color: var(--teal); font-size: 0.8rem; font-weight: 600;">SOLICITUD ENVIADA CORRECTAMENTE.</p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .section-header-retail {
    margin-bottom: 48px;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-retail {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.01em;
    margin-bottom: 32px;
    font-family: var(--title);
  }

  .hero-grid-retail .hero-sub {
    max-width: 480px;
    text-align: left;
    margin: 0 0 32px;
  }

  .scene-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
  }

  .hero-actions-retail {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-retail {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-retail:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .hero-card-retail {
    background: rgba(11, 21, 32, 0.4);
    border: 1px solid var(--rim2);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .card-note {
    font-size: 0.8rem;
    color: var(--smoke);
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .results-dashboard-retail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 0;
  }
  .chart-box {
    background: var(--surface);
    border: 1px solid var(--rim);
    padding: 40px;
  }
  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 30px;
  }
  .chart-header span { font-size: 0.9rem; color: var(--smoke); text-transform: uppercase; letter-spacing: 0.1em; }
  .chart-header strong { font-size: 2.5rem; color: var(--white); font-family: var(--title); }
  .accent-box strong { color: var(--teal); }

  .mini-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 100px;
  }
  .mini-chart .line {
    flex: 1;
    background: var(--rim2);
    transition: 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scene.active .mini-chart .line {
    background: var(--teal);
  }

  .solutions-grid-retail {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .sol-item {
    padding: 40px;
    background: var(--surface);
    border: 1px solid var(--rim);
    transition: 0.3s;
  }
  .sol-item:hover { border-color: var(--teal); }

  .sol-item h3 {
    font-family: var(--title);
    font-size: 1.8rem;
    letter-spacing: 0.06em;
    color: var(--white);
    margin: 12px 0 8px;
    line-height: 1;
  }

  .sol-item p {
    font-size: 0.8rem;
    color: var(--smoke);
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .value-prop-retail {
     max-width: 900px;
  }
  .big-quote {
    font-size: 2.2rem;
    line-height: 1.3;
    font-family: var(--title);
    color: var(--white);
    margin-bottom: 40px;
    font-style: italic;
  }
  .value-icons {
    display: flex;
    gap: 16px;
  }
  .v-pill {
    padding: 8px 20px;
    background: var(--rim);
    border: 1px solid var(--rim2);
    font-size: 0.75rem;
    color: var(--teal);
    font-weight: 800;
  }

  .retail-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .stat-card {
    text-align: center;
  }

  .stat-val {
    display: block;
    font-family: var(--title);
    font-size: 3.5rem;
    color: var(--teal);
    margin-bottom: 10px;
  }

  .form-split-retail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    margin-bottom: 16px;
  }

  @media (max-width: 1024px) {
    .hero-grid-retail, .results-dashboard-retail, .solutions-grid-retail, .retail-stats-grid, .form-split-retail {
      grid-template-columns: 1fr;
    }
    .big-quote { font-size: 1.5rem; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.querySelector('.personal-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        document.querySelector('.form-success-retail').style.display = 'block';
      });
    }
  });
</script>
