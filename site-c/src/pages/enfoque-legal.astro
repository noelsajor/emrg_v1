---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque Legal | EMRG" description="SEO y estrategias digitales para despachos de abogados y firmas legales. Construimos prestigio y captamos clientes cualificados.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-legal">
          <div class="hero-copy">
            <p class="scene-label">Sector Legal</p>
            <h1 class="hero-title">Tu despacho merece una presencia digital <span class="accent">tan sólida como tus argumentos.</span></h1>
            <p class="hero-sub">
              Estrategias de SEO y contenidos para firmas que buscan liderar su sector. 
              Construimos la infraestructura digital que tu prestigio demanda.
            </p>

            <div class="hero-actions-legal">
              <button class="nav-cta" onclick="window.goToScene(5)">Solicitar auditoría gratuita</button>
              <button class="btn-outline-legal" onclick="window.goToScene(3)">Ver servicios</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">Especialización Legal</span>
               <span class="chip-pill">Gestión de Reputación</span>
               <span class="chip-pill">Marketing Ético</span>
            </div>
          </div>

          <aside class="hero-image-scene">
            <img src="/images/hero-legal.png" alt="Despacho legal" class="hero-img-scene" />
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Propuesta de Valor</p>
          <h2 class="scene-title">No solo hacemos webs, <em class="accent">construimos prestigio.</em></h2>
          <p class="hero-sub">
            En el sector legal, la reputación es el activo más valioso. Nuestra metodología se centra en 
            servicios personalizados y gestión de reputación.
          </p>
        </div>

        <div class="pillars-grid-legal">
          <article class="pillar-row-legal">
            <span class="pillar-num">01</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Arquitectura de Especialidad</h3>
              <p class="pillar-tagline">Estructuramos tu sitio para reflejar la profundidad de tus servicios: Penal, Mercantil, Familia.</p>
            </div>
          </article>
          <article class="pillar-row-legal">
            <span class="pillar-num">02</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Reputación Digital</h3>
              <p class="pillar-tagline">Aseguramos que tu autoridad offline se traduzca perfectamente al entorno digital.</p>
            </div>
          </article>
          <article class="pillar-row-legal">
            <span class="pillar-num">03</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Captación Cualificada</h3>
              <p class="pillar-tagline">Diseñamos estrategias para atraer potenciales clientes que valoran la excelencia.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Autoridad</p>
          <h2 class="scene-title">Expertos en marketing para <em>expertos en leyes</em>.</h2>
          <p class="hero-sub" style="margin: 0; max-width: 600px;">Entendemos el lenguaje, la ética y las dinámicas del sector legal.</p>
        </div>

        <div class="work-scroll-track-legal">
          <article class="authority-box-imm">
            <span class="stat-num-imm">+15</span>
            <h3 class="case-brand-imm">Firmas</h3>
            <p class="case-desc-imm">Asesoradas con éxito en su transformación digital.</p>
          </article>
          <article class="authority-box-imm">
            <span class="stat-num-imm">Premium</span>
            <h3 class="case-brand-imm">Posicionamiento</h3>
            <p class="case-desc-imm">Estrategias que reflejan el estatus de tu despacho.</p>
          </article>
          <article class="authority-box-imm">
            <span class="stat-num-imm">LinkedIn</span>
            <h3 class="case-brand-imm">Estrategia</h3>
            <p class="case-desc-imm">Potenciamos la marca personal de los socios.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">La Solución</p>
          <h2 class="scene-title">Servicios con <em class="accent">estándar profesional.</em></h2>
        </div>

        <div class="services-grid-legal">
          <div class="service-item-legal">
             <span class="pillar-num">01</span>
             <h3 class="case-brand-imm">Arquitectura Web Legal</h3>
             <p class="pillar-tagline">Diseño enfocado en servicios específicos: Penal, Mercantil, Familia.</p>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">02</span>
             <h3 class="case-brand-imm">Gestión de RRSS</h3>
             <p class="pillar-tagline">LinkedIn e Instagram con tono institucional y profesional.</p>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">03</span>
             <h3 class="case-brand-imm">Email Marketing</h3>
             <p class="pillar-tagline">Estrategias de fidelización para mantener clientes actuales.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4-proof">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Confianza</p>
          <h2 class="scene-title">Nuestra reputación se mide en <em class="accent">resultados.</em></h2>
        </div>

        <div class="testimonial-carousel-container-imm">
          <div class="testimonial-track-imm" id="testimonial-track">
            <article class="testimonial-slide-imm active">
              <p>“Profesionales que entienden el rigor que nuestra profesión exige.”</p>
              <strong>Firma Boutique — Madrid</strong>
            </article>
            <article class="testimonial-slide-imm">
              <p>“Nuestra presencia en LinkedIn se transformó en un canal real de captación.”</p>
              <strong>Socio Director — Despacho Mercantil</strong>
            </article>
            <article class="testimonial-slide-imm">
              <p>“La arquitectura web por áreas de práctica mejoró drásticamente nuestra conversión.”</p>
              <strong>Despacho Familia — Barcelona</strong>
            </article>
          </div>
          <div class="carousel-dots-imm">
            <button class="dot-imm active" aria-label="Slide 1"></button>
            <button class="dot-imm" aria-label="Slide 2"></button>
            <button class="dot-imm" aria-label="Slide 3"></button>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-legal">
         <div class="form-copy-legal">
            <p class="scene-label">Diagnóstico</p>
            <h2 class="scene-title">Solicita una auditoría gratuita para <em class="accent">tu firma legal.</em></h2>
            <p class="hero-sub">Agenda tu diagnóstico y descubre tu potencial de crecimiento.</p>
         </div>
         <form class="qualification-form-legal" id="legal-form">
            <div class="form-row">
               <input type="text" placeholder="NOMBRE COMPLETO" required />
            </div>
            <div class="form-row">
               <input type="text" placeholder="NOMBRE DE LA FIRMA" required />
            </div>
            <div class="form-row">
               <input type="email" placeholder="EMAIL CORPORATIVO" required />
            </div>
            <div class="form-row">
               <select required>
                  <option value="">ÁREA DE PRÁCTICA</option>
                  <option>Derecho Penal</option>
                  <option>Derecho Mercantil</option>
                  <option>Derecho de Familia</option>
                  <option>Otro</option>
               </select>
            </div>
            <button class="nav-cta" type="submit">Solicitar auditoría ahora</button>
            <p class="form-success-legal" style="margin-top: 1rem; color: var(--teal); font-size: 0.8rem;"></p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .section-header-legal {
    margin-bottom: 48px;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-legal {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-grid-legal .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-grid-legal .hero-sub {
    max-width: 480px;
    text-align: left;
    margin: 0 0 32px;
  }

  .scene-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
  }

  .hero-actions-legal {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-legal {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-legal:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  /* Image Scene Styles */
  .hero-image-scene {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--rim2);
    box-shadow: 0 0 50px rgba(186, 211, 65, 0.2);
    transform: perspective(1000px) rotateY(-5deg);
    transition: all 0.5s;
    width: 100%;
  }

  .hero-img-scene {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  /* Carousel Styles for Scene */
  .testimonial-carousel-container-imm {
    margin-top: 40px;
    position: relative;
    overflow: hidden;
    padding-bottom: 60px;
  }

  .testimonial-track-imm {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-slide-imm {
    min-width: 100%;
    padding: 60px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--rim);
    text-align: center;
    opacity: 0.3;
    transform: scale(0.9);
    transition: all 0.5s;
  }

  .testimonial-slide-imm.active {
    opacity: 1;
    transform: scale(1);
    border-color: var(--teal);
    background: rgba(186, 211, 65, 0.05);
  }

  .testimonial-slide-imm p {
    font-size: 1.8rem;
    font-style: italic;
    color: var(--white);
    margin-bottom: 24px;
    font-family: var(--title);
  }

  .carousel-dots-imm {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  .dot-imm {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rim2);
    border: none;
    cursor: pointer;
    transition: 0.3s;
  }

  .dot-imm.active {
    background: var(--teal);
    width: 20px;
    border-radius: 10px;
  }

  .pillars-grid-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 60px;
    margin-top: 0;
  }

  .pillar-row-legal {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rim);
  }

  .pillar-num {
    font-family: var(--body);
    font-size: 0.7rem;
    color: var(--teal);
    font-weight: 600;
  }

  .pillar-name {
    font-family: var(--title);
    font-size: 1.8rem;
    margin-bottom: 8px;
    color: var(--white);
  }

  .pillar-tagline {
    font-size: 0.85rem;
    color: var(--smoke);
  }

  .work-scroll-track-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 0;
  }

  .authority-box-imm {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--rim);
    padding: 40px;
    text-align: center;
    transition: all 0.3s;
  }
  .authority-box-imm:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }
  .stat-num-imm {
    display: block;
    font-family: var(--title);
    font-size: 3rem;
    color: var(--teal);
    margin-bottom: 12px;
  }

  .services-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rim);
    border: 1px solid var(--rim);
    width: 100%;
  }

  .service-item-legal {
    background: var(--surface);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-split-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .qualification-form-legal {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    font-family: var(--body);
    font-size: 0.8rem;
  }

  @media (max-width: 1024px) {
    .hero-grid-legal, .pillars-grid-legal, .work-scroll-track-legal, .services-grid-legal, .form-split-legal {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const f = document.getElementById('legal-form');
    if (f) {
      f.addEventListener('submit', (e) => {
        e.preventDefault();
        const s = f.querySelector('.form-success-legal');
        f.reset();
        if (s) s.textContent = "SOLICITUD RECIBIDA.";
      });
    }

    // Carousel Logic
    const track = document.getElementById('testimonial-track');
    const slides = Array.from(track ? track.children : []);
    const dots = Array.from(document.querySelectorAll('.dot-imm'));
    let currentIndex = 0;

    function upd(idx) {
      if (!track) return;
      track.style.transform = `translateX(-${idx * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      currentIndex = idx;
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => upd(i)));

    if (slides.length > 0) {
      setInterval(() => {
        let next = (currentIndex + 1) % slides.length;
        upd(next);
      }, 5000);
    }
  });
</script>
