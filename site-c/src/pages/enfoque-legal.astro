---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque Legal | EMRG" description="Sistemas de adquisición de clientes y autoridad digital para firmas legales de alto impacto.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-legal">
          <div class="hero-copy">
            <p class="scene-label">Estrategia Digital para Sector Legal</p>
            <h1 class="hero-title">Autoridad que <span class="accent">Convierte.</span></h1>
            <p class="hero-sub">
              Diseñamos y construimos la infraestructura digital que las firmas legales necesitan para captar leads cualificados y proyectar una autoridad innegable en su práctica.
            </p>

            <div class="hero-actions-legal">
              <button class="nav-cta" onclick="window.goToScene(5)">Auditoría de Captación</button>
              <button class="btn-outline-legal" onclick="window.goToScene(2)">Ver Framework</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">Legal Growth</span>
               <span class="chip-pill">Authority Systems</span>
               <span class="chip-pill">HNI Lead Gen</span>
            </div>
          </div>

          <aside class="hero-card-legal">
             <div class="hero-quote-imm">
                <p>“En el sector legal, la confianza no se pide, se construye mediante una arquitectura digital impecable.”</p>
             </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">El Problema</p>
          <h2 class="scene-title">El prestigio offline no siempre se traduce en <em>resultados online.</em></h2>
        </div>

        <div class="pillars-grid-legal">
          <article class="pillar-row-legal">
            <span class="pillar-num">01</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Fuga de Prospectos</h3>
              <p class="pillar-tagline">Webs obsoletas que no transmiten la seriedad ni el nivel de especialización de la firma.</p>
            </div>
          </article>
          <article class="pillar-row-legal">
            <span class="pillar-num">02</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Tráfico Irrelevante</h3>
              <p class="pillar-tagline">Mucho volumen de visitas pero pocos clientes potenciales que cumplan el perfil ideal.</p>
            </div>
          </article>
          <article class="pillar-row-legal">
            <span class="pillar-num">03</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Ausencia de Sistema</h3>
              <p class="pillar-tagline">Dependencia exclusiva de directorios o recomendaciones sin un canal de captación propio controlado.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Framework</p>
          <h2 class="scene-title">Legal <em>Authority Engine.</em></h2>
          <p class="hero-sub" style="margin: 0; max-width: 600px;">Un proceso modular enfocado en tres áreas críticas para el crecimiento de una firma legal.</p>
        </div>

        <div class="work-scroll-track-legal">
          <article class="case-card-imm">
            <span class="case-tag-imm">Etapa 01</span>
            <h3 class="case-brand-imm">Posicionamiento</h3>
            <p class="case-desc-imm">Definición de autoridad, diferenciación por práctica y arquitectura de contenidos SEO.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Etapa 02</span>
            <h3 class="case-brand-imm">Conversión</h3>
            <p class="case-desc-imm">Diseño de interfaces que proyectan confianza y eliminan la fricción en el contacto.</p>
          </article>
          <article class="case-card-imm">
            <span class="case-tag-imm">Etapa 03</span>
            <h3 class="case-brand-imm">Tráfico</h3>
            <p class="case-desc-imm">Campañas de captación directa para áreas de práctica específicas y rentables.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Servicios</p>
          <h2 class="scene-title">Ingeniería para <em>Firmas de Elite.</em></h2>
        </div>

        <div class="services-grid-legal">
          <div class="service-item-legal">
             <span class="pillar-num">01</span>
             <h3 class="case-brand-imm">Legal SEO</h3>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">02</span>
             <h3 class="case-brand-imm">Partner Websites</h3>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">03</span>
             <h3 class="case-brand-imm">Practice Area Funnels</h3>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">04</span>
             <h3 class="case-brand-imm">Authority Content</h3>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">05</span>
             <h3 class="case-brand-imm">Legal Analytics</h3>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">06</span>
             <h3 class="case-brand-imm">Direct Lead Gen</h3>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Casos</p>
          <h2 class="scene-title">Resultados de <em>Alto Impacto.</em></h2>
        </div>

        <div class="cases-row-legal">
          <article class="case-card-imm">
             <h3 class="case-brand-imm">Firma Boutique</h3>
             <p class="case-desc-imm">Incremento del 150% en leads cualificados para áreas de derecho mercantil senior.</p>
          </article>
          <article class="case-card-imm featured-case">
             <h3 class="case-brand-imm">Despacho Nacional</h3>
             <p class="case-desc-imm">Domino absoluto de keywords locales logrando visibilidad en 3 ciudades clave.</p>
          </article>
           <article class="case-card-imm">
             <h3 class="case-brand-imm">Especialista Litigios</h3>
             <p class="case-desc-imm">Rediseño de identidad digital logrando un incremento en el ticket promedio de consulta.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-legal">
         <div class="form-copy-legal">
            <p class="scene-label">Consulta</p>
            <h2 class="scene-title">Solicita una <em>Auditoría Legal.</em></h2>
            <p class="hero-sub">Analizamos tu infraestructura de captación y posicionamiento actual.</p>
         </div>
         <form class="qualification-form-legal personal-form">
            <div class="form-grid">
               <input type="text" placeholder="NOMBRE COMPLETO" required />
               <input type="text" placeholder="CARGO / FIRMA" required />
            </div>
            <div class="form-row">
               <input type="text" placeholder="ÁREA DE PRÁCTICA PRINCIPAL" required />
            </div>
            <div class="form-grid">
               <select required>
                  <option value="">OBJETIVO</option>
                  <option>Captación de Clientes</option>
                  <option>Autoridad de Marca</option>
                  <option>Rediseño Estratégico</option>
               </select>
               <input type="email" placeholder="EMAIL" required />
            </div>
            <button class="nav-cta" type="submit">Solicitar Auditoría</button>
            <p class="form-success-legal" style="display:none; margin-top: 1rem; color: var(--teal); font-size: 0.8rem; font-weight: 600;">SOLICITUD ENVIADA CON ÉXITO.</p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-legal {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-actions-legal {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-legal {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-legal:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .hero-card-legal {
    background: rgba(11, 21, 32, 0.4);
    border: 1px solid var(--rim2);
    backdrop-filter: blur(12px);
    padding: 60px;
  }

  .hero-quote-imm {
     font-size: 1.8rem;
     line-height: 1.3;
     color: var(--white);
     font-family: var(--title);
     font-style: italic;
  }

  .pillars-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
    margin-top: 40px;
  }

  .pillar-row-legal {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 24px 0;
    border-top: 1px solid var(--rim);
  }

  .pillar-num {
    font-family: var(--body);
    font-size: 0.7rem;
    color: var(--teal);
    font-weight: 600;
  }

  .pillar-name {
    font-family: var(--title);
    font-size: 1.8rem;
    margin-bottom: 8px;
    color: var(--white);
  }

  .pillar-tagline {
    font-size: 0.85rem;
    color: var(--smoke);
  }

  .work-scroll-track-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 60px;
  }

  .services-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rim);
    border: 1px solid var(--rim);
    width: 100%;
  }

  .service-item-legal {
    background: var(--surface);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cases-row-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .featured-case {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .form-split-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .qualification-form-legal {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  .form-grid {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 15px;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    font-family: var(--body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 15px var(--teal-glow);
  }

  @media (max-width: 1024px) {
    .hero-grid-legal, .pillars-grid-legal, .work-scroll-track-legal, .services-grid-legal, .cases-row-legal, .form-split-legal, .form-grid {
      grid-template-columns: 1fr;
    }
    .hero-card-legal { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.querySelector('.personal-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        document.querySelector('.form-success-legal').style.display = 'block';
      });
    }
  });
</script>
