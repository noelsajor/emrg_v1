---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque Emprendedores/PYMES | EMRG" description="Deja de ser invisible. Es hora de que el mundo encuentre tu negocio. Diseño global y estrategias de escalado digital para PYMES.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap-imm">
        <div class="hero-grid-imm">
          <div class="hero-copy-imm">
            <p class="scene-label-imm">Crecimiento Digital</p>
            <h1 class="hero-title-imm">Deja de ser invisible. <span class="accent-teal">El mundo te espera.</span></h1>
            <p class="hero-sub-imm">
              Diseño de sitios web desde cero y optimización estratégica para que tu marca despegue. No solo creamos páginas, construimos autoridad.
            </p>

            <div class="hero-actions-imm">
              <button class="nav-cta-imm" onclick="window.goToScene(5)">¡Sí, quiero lanzar mi negocio!</button>
              <button class="btn-outline-imm" onclick="window.goToScene(1)">El Dato Maestro</button>
            </div>
          </div>

          <div class="hero-visual-imm">
             <img src="/images/hero-pymes.png" alt="PYMES Growth" class="hero-img-imm" />
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap-imm">
        <div class="hook-box-imm">
          <p class="scene-label-imm">El Gancho</p>
          <h2 class="section-title-imm">¿Sabías que el <span class="accent-teal">80% de las personas</span> investigan en internet antes de comprar?</h2>
          <p class="hero-sub-imm">Si tu negocio no es parte de esa investigación, simplemente no existe para la mayoría de tus clientes potenciales.</p>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-2">
      <div class="content-wrap-imm">
        <div class="scene-header-imm">
          <p class="scene-label-imm">Servicios</p>
          <h2 class="section-title-imm">Paquetes de <em>Despegue.</em></h2>
        </div>

        <div class="services-grid-imm">
          <div class="sol-item-imm">
            <span class="pillar-num-imm">01</span>
            <h3>Tienda Online</h3>
            <p>E-commerce fácil de usar, autogestionable y diseñado para vender 24/7.</p>
          </div>
          <div class="sol-item-imm">
            <span class="pillar-num-imm">02</span>
            <h3>SEO Nativo</h3>
            <p>Optimización desde el día 1 para que tu marca lidere las búsquedas en Google.</p>
          </div>
          <div class="sol-item-imm">
            <span class="pillar-num-imm">03</span>
            <h3>Contenidos</h3>
            <p>Nosotros escribimos por ti. Gestión narrativa que conecta con tu audiencia.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap-imm">
        <div class="scene-header-imm">
          <p class="scene-label-imm">Beneficios</p>
          <h2 class="section-title-imm">Ventajas <em>Nacionales.</em></h2>
        </div>
        
        <div class="benefits-row-imm">
          <div class="benefit-card-imm">
            <span class="step-num-imm">01</span>
            <h3>Ventas Total</h3>
            <p>Sistemas que operan ininterrumpidamente sin importar el horario comercial.</p>
          </div>
          <div class="benefit-card-imm">
            <span class="step-num-imm">02</span>
            <h3>Escalamiento</h3>
            <p>Llega a todo el mercado nacional con una infraestructura digital sólida.</p>
          </div>
          <div class="benefit-card-imm">
            <span class="step-num-imm">03</span>
            <h3>Prestigio</h3>
            <p>Valida tu marca con un estándar de diseño que transmita confianza absoluta.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4" style="background: var(--deep);">
      <div class="content-wrap-imm">
         <div class="scene-header-imm">
            <p class="scene-label-imm">Garantía</p>
            <h2 class="section-title-imm">Resultados <em>Reales.</em></h2>
         </div>
         <div class="results-grid-imm">
            <div class="res-card-imm">
               <h4>+50%</h4>
               <p>Aumento medio en alcance tras el lanzamiento del nuevo sitio.</p>
            </div>
            <div class="res-card-imm">
               <h4>24/7</h4>
               <p>Disponibilidad de catálogo y captación de clientes cualificados.</p>
            </div>
            <div class="res-card-imm">
               <h4>100%</h4>
               <p>Soporte técnico y estratégico en cada fase del despegue.</p>
            </div>
         </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap-imm form-split-imm">
         <div class="form-info-imm">
            <p class="scene-label-imm">Lanzamiento</p>
            <h2 class="section-title-imm">¿Listo para el <em>Siguiente Nivel?</em></h2>
            <p class="hero-sub-imm">Agenda tu auditoría y descubre cómo llevar tu negocio al mundo digital hoy mismo.</p>
         </div>
         <div class="form-box-imm">
          <form class="pymes-launch-form-imm" id="pymes-form">
              <input type="text" placeholder="NOMBRE COMPLETO" required />
              <input type="text" placeholder="NEGOCIO / PROYECTO" required />
              <input type="email" placeholder="EMAIL DE CONTACTO" required />
              <select required style="background:var(--deep); border:1px solid var(--rim2); color:white; padding:16px; width:100%; font-family:var(--body); font-size:0.8rem; letter-spacing:0.05em;">
                 <option value="">OBJETIVO PRINCIPAL</option>
                 <option>Tienda Online</option>
                 <option>Web Corporativa</option>
                 <option>Rediseño</option>
              </select>
              <button class="nav-cta-imm" type="submit">¡Sí, quiero lanzar mi negocio!</button>
              <p class="success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.8rem; font-weight: 800;">SOLICITUD RECIBIDA. NOS CONTACTAREMOS PRONTO.</p>
          </form>
         </div>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .scene-label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  .hero-grid-imm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-title-imm {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    font-family: var(--title);
    letter-spacing: -0.01em;
    margin-bottom: 32px;
  }

  .section-title-imm {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    font-family: var(--title);
    letter-spacing: -0.01em;
    margin-bottom: 48px;
  }

  .hero-sub-imm {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--smoke);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .hero-actions-imm {
    display: flex;
    gap: 20px;
  }

  .nav-cta-imm {
    background: transparent;
    border: 1px solid var(--teal);
    color: var(--teal);
    padding: 10px 24px;
    font-family: var(--body);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
  }

  .nav-cta-imm:hover {
    background: var(--teal);
    color: var(--void);
  }

  .btn-outline-imm {
    background: transparent;
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 10px 24px;
    font-family: var(--body);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: all 0.3s;
  }

  .btn-outline-imm:hover {
    border-color: var(--teal);
    color: var(--teal);
  }

  .hero-visual-imm {
    overflow: hidden;
    border: 1px solid var(--rim2);
    box-shadow: 0 0 50px rgba(186, 211, 65, 0.15);
  }

  .hero-img-imm {
    width: 100%;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .hook-box-imm {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    padding: 60px;
    border: 1px solid var(--rim2);
    background: rgba(255,255,255,0.02);
  }

  .services-grid-imm {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rim);
    border: 1px solid var(--rim);
  }

  .sol-item-imm {
    padding: 40px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pillar-num-imm {
    font-family: var(--body);
    font-size: 0.65rem;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    display: block;
  }

  .sol-item-imm h3 {
    font-family: var(--title);
    font-size: 1.8rem;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    line-height: 1;
  }

  .sol-item-imm p {
    font-size: 0.8rem;
    color: var(--smoke);
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .benefits-row-imm {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--rim);
    padding-top: 40px;
  }

  .benefit-card-imm {
    max-width: 300px;
  }

  .step-num-imm {
    font-family: var(--body);
    font-size: 0.65rem;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 16px;
  }

  .benefit-card-imm h3 {
    font-family: var(--title);
    font-size: 1.8rem;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    line-height: 1;
  }

  .benefit-card-imm p {
    font-size: 0.8rem;
    color: var(--smoke);
    line-height: 1.7;
  }

  .results-grid-imm {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .res-card-imm {
    padding: 40px;
    background: var(--surface);
    border-left: 2px solid var(--teal);
  }

  .res-card-imm h4 {
    font-family: var(--title);
    font-size: 2.8rem;
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }

  .res-card-imm p {
    font-size: 0.8rem;
    color: var(--smoke);
    line-height: 1.7;
  }

  .form-split-imm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .form-box-imm form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  input {
    background: var(--deep);
    border: 1px solid var(--rim2);
    padding: 16px;
    color: var(--white);
    width: 100%;
    font-family: var(--body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  input:focus, select:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 15px var(--teal-glow);
  }

  @media (max-width: 1024px) {
    .hero-grid-imm, .services-grid-imm, .benefits-row-imm, .results-grid-imm, .form-split-imm {
      grid-template-columns: 1fr;
      flex-direction: column;
      gap: 40px;
    }
    .hero-visual-imm { order: -1; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const f = document.getElementById('pymes-form');
    if (f) {
      f.addEventListener('submit', (e) => {
        e.preventDefault();
        f.reset();
        const s = f.querySelector('.success-imm');
        if (s) s.style.display = 'block';
      });
    }
  });
</script>
