---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Enfoque Marca Personal | EMRG" description="SEO, Contenidos y Estrategia Digital para quienes no se conforman con lo básico. Convierte tu web en un imán de leads.">
  <SceneNav />
  <Header />

  <div id="scroll-container">
    <section class="scene active" id="scene-0">
      <div class="content-wrap">
        <div class="hero-grid-legal">
          <div class="hero-copy">
            <p class="scene-label">Personal Branding</p>
            <h1 class="hero-title">¿Tu web solo <span class="accent">la ves tú?</span></h1>
            <p class="hero-sub">
              SEO, Contenidos y Estrategia Digital para quienes no se conforman con lo básico. 
              Vamos a cambiar eso y convertir tu presencia en un imán de leads.
            </p>

            <div class="hero-actions-legal">
              <button class="nav-cta" onclick="window.goToScene(5)">Diseñar mi Estrategia</button>
              <button class="btn-outline-legal" onclick="window.goToScene(1)">Web vs. Imán de Leads</button>
            </div>

            <div class="hero-chips">
               <span class="chip-pill">Lead Magnet</span>
               <span class="chip-pill">Authority SEO</span>
               <span class="chip-pill">Conversion Pathways</span>
            </div>
          </div>

          <aside class="hero-card-legal">
             <img src="/images/hero-branding.png" alt="High-Authority Personal Brand" class="hero-img-scene" />
          </aside>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-1">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">La Evolución</p>
          <h2 class="scene-title">El <em>Antes y Después.</em></h2>
        </div>

        <div class="pillars-grid-legal">
          <article class="pillar-row-legal before-card">
            <span class="pillar-num">ANTES</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Web "Tarjeta"</h3>
              <ul class="pillar-list-imm">
                 <li>Invisibilidad en buscadores</li>
                 <li>Estética genérica sin alma</li>
                 <li>Sin llamadas a la acción</li>
              </ul>
            </div>
          </article>
          <article class="pillar-row-legal after-card featured-pillar">
            <span class="pillar-num">DESPUÉS</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Imán de Leads</h3>
              <ul class="pillar-list-imm">
                 <li>Dominio de palabras clave</li>
                 <li>Diseño que inspira autoridad</li>
                 <li>Rutas de conversión claras</li>
              </ul>
            </div>
          </article>
          <article class="pillar-row-legal">
            <span class="pillar-num">IMPACTO</span>
            <div class="pillar-content">
              <h3 class="pillar-name">Crecimiento</h3>
              <p class="pillar-tagline">Transformamos un gasto digital en un generador de negocio 24/7 para tu marca.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-3">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Servicios</p>
          <h2 class="scene-title">Estrategia <em>Integral.</em></h2>
        </div>

        <div class="services-grid-legal">
          <div class="service-item-legal">
             <span class="pillar-num">01</span>
             <h3 class="case-brand-imm">Auditoría SEO Profunda</h3>
             <p class="service-desc-imm">Encontramos fugas de autoridad en tus activos.</p>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">02</span>
             <h3 class="case-brand-imm">Web Optimizada</h3>
             <p class="service-desc-imm">Velocidad extrema y enfoque móvil total.</p>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">03</span>
             <h3 class="case-brand-imm">Blog Corporativo</h3>
             <p class="service-desc-imm">Contenidos que atraen clientes cualificados.</p>
          </div>
          <div class="service-item-legal">
             <span class="pillar-num">04</span>
             <h3 class="case-brand-imm">Redes con Propósito</h3>
             <p class="service-desc-imm">Gestión enfocada en conversión comercial.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-4">
      <div class="content-wrap">
        <div class="section-header-legal">
          <p class="scene-label">Diferenciador</p>
          <h2 class="scene-title">Por qué <em>EMRG.</em></h2>
        </div>

        <div class="cases-row-legal">
          <div class="quote-scene-full">
            <p class="hero-quote-imm">"Somos tu equipo de marketing externo, pero con tu misma pasión."</p>
          </div>
        </div>
      </div>
    </section>

    <section class="scene" id="scene-5">
      <div class="content-wrap form-split-legal">
         <div class="form-copy-legal">
            <p class="scene-label">Contacto</p>
            <h2 class="scene-title">Hablemos de tu <em>Proyecto.</em></h2>
            <p class="hero-sub">Cuéntanos sobre tus metas y diseñamos tu estrategia personalizada hoy mismo.</p>
         </div>
         <form class="qualification-form-legal personal-form">
            <div class="form-grid">
               <input type="text" placeholder="TU NOMBRE" required />
               <input type="text" placeholder="TU PROFESIÓN" required />
            </div>
            <div class="form-row">
               <textarea placeholder="CUÉNTANOS TU PROYECTO..." required style="width: 100%; height: 100px; padding: 16px; background: var(--deep); border: 1px solid var(--rim2); color: white;"></textarea>
            </div>
            <div class="form-grid">
               <input type="email" placeholder="EMAIL" required />
               <input type="tel" placeholder="WHATSAPP" required />
            </div>
            <button class="nav-cta" type="submit">Diseñar mi Estrategia</button>
            <p class="form-success-legal" style="display:none; margin-top: 1rem; color: var(--teal); font-size: 0.8rem; font-weight: 600;">ESTRATEGIA SOLICITADA CON ÉXITO.</p>
         </form>
      </div>
    </section>

    <CTA />
  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .section-header-legal {
    margin-bottom: 48px;
  }

  .accent {
    color: var(--teal);
  }

  .hero-grid-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-grid-legal .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-grid-legal .hero-sub {
    max-width: 480px;
    text-align: left;
    margin: 0 0 32px;
  }

  .scene-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
  }

  .hero-actions-legal {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }

  .btn-outline-legal {
    background: transparent;
    padding: 10px 24px;
    border: 1px solid var(--rim2);
    color: var(--white);
    font-family: var(--body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.3s;
    cursor: pointer;
  }
  .btn-outline-legal:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .hero-card-legal {
    border: 1px solid var(--rim2);
    background: white;
    padding: 10px;
  }

  .hero-img-scene {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .hero-quote-imm {
     font-size: 2.5rem;
     line-height: 1.2;
     color: var(--white);
     font-family: var(--title);
     font-style: italic;
     text-align: center;
     max-width: 900px;
     margin: 0 auto;
  }

  .pillars-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-top: 0;
  }

  .pillar-row-legal {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 40px;
    border: 1px solid var(--rim2);
    background: var(--surface);
  }

  .featured-pillar {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .pillar-num {
    font-family: var(--body);
    font-size: 0.7rem;
    color: var(--teal);
    font-weight: 600;
    letter-spacing: 0.2em;
  }

  .pillar-name {
    font-family: var(--title);
    font-size: 1.8rem;
    margin-bottom: 20px;
    color: var(--white);
  }

  .pillar-list-imm {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 12px;
    color: var(--smoke);
    font-size: 0.9rem;
  }

  .pillar-list-imm li::before {
    content: "→";
    margin-right: 10px;
    color: var(--teal);
  }

  .services-grid-legal {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 0;
  }

  .service-item-legal {
    background: var(--surface);
    padding: 60px;
    border: 1px solid var(--rim2);
    transition: 0.3s;
  }
  .service-item-legal:hover {
    border-color: var(--teal);
  }

  .service-desc-imm {
    font-size: 0.9rem;
    color: var(--smoke);
    margin-top: 10px;
  }

  .quote-scene-full {
    width: 100%;
    padding: 100px 0;
  }

  .form-split-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .qualification-form-legal {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  .form-grid {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 15px;
  }

  input, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--rim2);
    color: var(--white);
    padding: 16px;
    font-family: var(--body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 15px var(--teal-glow);
  }

  @media (max-width: 1024px) {
    .hero-grid-legal, .pillars-grid-legal, .services-grid-legal, .form-split-legal, .form-grid {
      grid-template-columns: 1fr;
    }
    .hero-card-legal { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.querySelector('.personal-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        document.querySelector('.form-success-legal').style.display = 'block';
      });
    }
  });
</script>
