---
import { urlFor } from '../lib/sanity.client';

interface Props {
  post: {
    title: string;
    slug: string;
    excerpt: string;
    publishedAt: string;
    categories: string[];
    readingTime?: number;
    mainImage?: any;
  };
  showExcerpt?: boolean;
}

const { post, showExcerpt = true } = Astro.props;
---

<article class="testi-card-imm" style="display: flex; flex-direction: column;">
  <div class="case-tag-imm" style="margin-bottom: 20px;">
    {post.categories?.[0]} {post.readingTime && `· ${post.readingTime} min read`}
  </div>
  <h3 class="case-brand-imm" style="font-size: 1.8rem; margin-bottom: 12px;">{post.title}</h3>
  
  {showExcerpt && <p class="case-desc-imm" style="flex: 1;">{post.excerpt}</p>}
  
  <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--rim); display: flex; justify-content: space-between; align-items: center;">
    <span style="font-size: 0.65rem; color: var(--mist); text-transform: uppercase; letter-spacing: 0.1em;">
      {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </span>
    <a href={`/blog/${post.slug}`} class="pillar-cta-link" style="padding-top: 0;">Read Entry →</a>
  </div>
</article>
