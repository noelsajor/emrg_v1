---
import { client } from '../lib/sanity.client';
import { latestPostsQuery } from '../lib/sanity.queries';
import { urlFor } from '../lib/sanity.client';
import BlogCard from './BlogCard.astro';

// In a real build, we'd fetch data here. For now, placeholders to show markup.
// const posts = await client.fetch(latestPostsQuery);

const posts = [
  {
    title: "The Future of DTC Architecture",
    slug: "future-dtc-architecture",
    excerpt: "How headless systems are changing the conversion landscape for growing brands.",
    publishedAt: "2025-02-24",
    readingTime: 5,
    categories: ["Engineering"]
  },
  {
    title: "Brand Identity as a Growth Lever",
    slug: "brand-identity-growth",
    excerpt: "Why performance brands are investing in high-fidelity design early.",
    publishedAt: "2025-02-20",
    readingTime: 4,
    categories: ["Design"]
  },
  {
    title: "Optimizing the Post-Purchase Flow",
    slug: "post-purchase-optimization",
    excerpt: "Increasing LTV through strategic email and SMS infrastructure.",
    publishedAt: "2025-02-15",
    readingTime: 6,
    categories: ["Growth"]
  }
];
---
<section class="scene" id="scene-blog" aria-labelledby="blog-h">
	<div class="scene-label">Insights</div>
	<h2 class="scene-title" id="blog-h">Ecommerce<br><em>intelligence.</em></h2>
	
	<div class="testi-layout" style="margin-top: 48px;">
		{posts.map((post) => (
			<BlogCard post={post} />
		))}
	</div>

	<div style="margin-top: 48px; width: 100%; display: flex; justify-content: center;">
		<a href="/blog" class="btn-outline-imm">View All Insights</a>
	</div>
</section>

<style>
	/* Reusing existing classes, adding minimal spacing/layout for blog teaser */
	#scene-blog {
		flex-direction: column;
		padding: 120px 80px 80px;
		align-items: flex-start;
		overflow-y: auto;
	}
	@media (max-width: 768px) {
		#scene-blog {
			padding: 100px 24px 60px;
		}
	}
</style>
