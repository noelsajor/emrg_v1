---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getAllPosts } from '../../lib/sanity.queries';

const posts = await getAllPosts();

const title = "Blog — EMRG Ecommerce Journal";
const description = "Insights, strategies, and technical guides for scaling DTC commerce engines.";
---

<BaseLayout title={title} description={description}>
  <Nav />
  
  <main style="padding-top: var(--nav-h);">
    <section class="wrap sr" style="padding-top:80px; padding-bottom:120px;">
      <div class="section-rule">
        <div class="section-rule-label">Journal</div>
        <div class="section-rule-line"></div>
        <div class="section-rule-num">{posts.length} Posts</div>
      </div>
      
      <h1 class="serif" style="font-size: clamp(3rem, 8vw, 6rem); line-height: 1; margin-bottom: 80px;">
        The <em>Performance</em> Journal.
      </h1>

      <div class="blog-grid" style="grid-template-columns: repeat(2, 1fr);">
        {posts.map((post, idx) => (
          <article class={`blog-card sr sr-d${idx % 2 + 1}`}>
            <a href={`/blog/${post.slug}`} style="display:block">
              <div style="background: var(--paper-2); width:100%; aspect-ratio:16/9; border:1px solid var(--border-strong);"></div>
            </a>
            <div class="blog-card-meta">
              <span>{post.categories?.join(', ')}</span>
              <span>•</span>
              <span>{new Date(post.publishedAt).toLocaleDateString()}</span>
            </div>
            <h2 class="blog-card-title" style="font-size: 2rem;">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h2>
            <p class="blog-card-excerpt" style="font-size: 1rem;">{post.excerpt}</p>
            <a href={`/blog/${post.slug}`} class="btn-text">Read Full Article</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
