---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PortableText from '../../components/PortableText.astro';
import { getPosts, getPost } from '../../lib/sanity';
import { urlFor } from '../../lib/image';
import { buildBlogPostingJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await getPost(slug as string);

if (!post) {
  return Astro.redirect('/404');
}

const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const seo = {
  title: `${post.title} | EMRG Studio`,
  description: post.excerpt,
  image: post.mainImage ? urlFor(post.mainImage).width(1200).url() : undefined,
};

const jsonLd = buildBlogPostingJsonLd(post);
---

<BaseLayout {...seo}>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />
  
  <Nav />
  
  <main>
    <article class="post-article">
      <header class="post-header">
        <div class="container container-sm">
          <div class="post-meta">
            {post.categories?.[0] && <span class="post-category">{post.categories[0].title}</span>}
            <time datetime={post.publishedAt}>{formattedDate}</time>
          </div>
          <h1 class="post-title">{post.title}</h1>
          {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
          
          {post.author && (
            <div class="post-author">
              {post.author.image && (
                <img 
                  src={urlFor(post.author.image).width(48).height(48).url()} 
                  alt={post.author.name}
                  class="author-avatar"
                />
              )}
              <div class="author-info">
                <span class="author-name">{post.author.name}</span>
                <span class="author-label">Author</span>
              </div>
            </div>
          )}
        </div>
      </header>

      {post.mainImage && (
        <div class="container">
          <div class="post-main-image">
            <img 
              src={urlFor(post.mainImage).width(1200).url()} 
              alt={post.title} 
            />
          </div>
        </div>
      )}

      <div class="container container-sm">
        <div class="post-content">
          <PortableText value={post.body} />
        </div>
        
        <footer class="post-footer">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 8H3M3 8L7 4M3 8L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Back to Articles
          </a>
        </footer>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .container-sm {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-article {
    padding: 160px 0 120px;
  }

  .post-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    gap: 16px;
    align-items: center;
    margin-bottom: 24px;
    color: var(--gray-2);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .post-category {
    color: var(--accent-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .post-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .post-excerpt {
    font-size: 1.25rem;
    color: var(--gray-2);
    line-height: 1.5;
    margin-bottom: 40px;
  }

  .post-author {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-align: left;
    padding: 8px 16px;
    background: var(--bg-2);
    border: 1px solid var(--gray-4);
    border-radius: 100px;
  }

  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .author-label {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-3);
  }

  .post-main-image {
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 80px;
    border: 1px solid var(--gray-4);
  }

  .post-main-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-content {
    margin-bottom: 80px;
  }

  .post-footer {
    padding-top: 40px;
    border-top: 1px solid var(--gray-4);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg);
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--accent-light);
  }

  @media (max-width: 768px) {
    .post-article {
      padding: 120px 0 60px;
    }
    
    .post-main-image {
      margin-bottom: 40px;
      border-radius: 12px;
    }
    
    .post-header {
      margin-bottom: 40px;
    }
  }
</style>
