---
---
<section id="hero" aria-labelledby="hero-heading">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
  </div>

  <div class="container">
    <div class="hero-inner">
      <div class="hero-badge" id="hero-badge-wrap">
        <span class="dot"></span>
        <span data-i18n="hero.badge">Accepting Projects</span>
      </div>

      <h1 id="hero-heading">
        <span class="hero-line" data-i18n="hero.h1.line1">We design the brand.</span>
        <span class="hero-line" data-i18n="hero.h1.line2">We build the store.</span>
        <span class="hero-line">We <span data-i18n="hero.h1.line3.accent">engineer</span> <span data-i18n="hero.h1.line3.rest">the</span></span>
        <span class="hero-line" data-i18n="hero.h1.line4">growth system.</span>
      </h1>

      <p class="hero-sub" data-i18n="hero.sub">
        End-to-end ecommerce execution — from brand identity and packaging to store build, conversion engineering, and post-launch growth infrastructure. Built for DTC brands that mean business.
      </p>

      <div class="hero-cta">
        <a href="#cta" class="btn btn-primary" id="hero-cta-primary">
          <span data-i18n="hero.cta.primary">Book a 15-min Call</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#work" class="btn btn-outline" data-i18n="hero.cta.secondary">View Work</a>
      </div>

      <div class="hero-chips" role="list">
        <div class="chip" role="listitem" data-i18n="hero.chip1">7-Day Launch</div>
        <div class="chip" role="listitem" data-i18n="hero.chip2">CRO-First Execution</div>
        <div class="chip" role="listitem" data-i18n="hero.chip3">Built for Scale</div>
      </div>
    </div>
  </div>
</section>
