---
---
<section class="about-hero">
  <div class="container">
    <div class="hero-content">
      <div class="eyebrow" data-i18n="about.eyebrow">The Studio</div>
      <h1 class="title" data-i18n="about.title" data-i18n-html="true">Engineered to <span class="accent">Win.</span></h1>
      <p class="sub" data-i18n="about.p1">We are a tactical ecommerce performance studio. We unite brand identity and technical engineering to build high-converting growth systems for DTC brands.</p>
    </div>
    
    <div class="about-grid">
      <div class="trait-card">
        <div class="trait-icon">01</div>
        <div class="trait-name" data-i18n="about.trait1">Speed First</div>
        <p class="trait-desc" data-i18n="about.trait1_desc">We launch full-stack stores in 7 days, eliminating the "agency lag" that kills momentum.</p>
      </div>
      <div class="trait-card">
        <div class="trait-icon">02</div>
        <div class="trait-name" data-i18n="about.trait2">Tech Depth</div>
        <p class="trait-desc" data-i18n="about.trait2_desc">Under the hood of every design is rigid, scalable code built for extreme mobile performance.</p>
      </div>
      <div class="trait-card">
        <div class="trait-icon">03</div>
        <div class="trait-name" data-i18n="about.trait3">Growth Focus</div>
        <p class="trait-desc" data-i18n="about.trait3_desc">We don't just build sites; we build the infrastructure that compounds revenue.</p>
      </div>
    </div>
  </div>
</section>

<section class="focus-area-imm">
  <div class="container">
    <div class="focus-header-imm">
      <div class="eyebrow" data-i18n="about.focus_eyebrow">Expertise</div>
      <h2 class="title-sm" data-i18n="about.focus_title">Strategic Focus</h2>
    </div>
    
    <div class="focus-list-imm">
      <a href="/enfoque-salud" class="focus-row-imm">
        <div class="row-left">
          <span class="row-num">01</span>
          <span class="row-title" data-i18n="about.focus_salud">Enfoque en Salud</span>
        </div>
        <div class="row-center">
          <p data-i18n="about.focus_salud_desc">Bio-technical performance for high-stakes healthcare ecosystem.</p>
        </div>
        <div class="row-right">
          <span class="row-link">Launch //</span>
        </div>
      </a>
      <a href="/enfoque-legal" class="focus-row-imm">
        <div class="row-left">
          <span class="row-num">02</span>
          <span class="row-title" data-i18n="about.focus_legal">Enfoque Legal</span>
        </div>
        <div class="row-center">
          <p data-i18n="about.focus_legal_desc">Authority-driven design systems for the legal industry.</p>
        </div>
        <div class="row-right">
          <span class="row-link">Launch //</span>
        </div>
      </a>
      <a href="/enfoque-pymes" class="focus-row-imm">
        <div class="row-left">
          <span class="row-num">03</span>
          <span class="row-title" data-i18n="about.focus_pymes">Enfoque Emprendedores/PYMES</span>
        </div>
        <div class="row-center">
          <p data-i18n="about.focus_pymes_desc">Strategic scaling engines for small & medium businesses.</p>
        </div>
        <div class="row-right">
          <span class="row-link">Launch //</span>
        </div>
      </a>
      <a href="/enfoque-retail" class="focus-row-imm">
        <div class="row-left">
          <span class="row-num">04</span>
          <span class="row-title" data-i18n="about.focus_retail">Enfoque Retail/Mayoristas</span>
        </div>
        <div class="row-center">
          <p data-i18n="about.focus_retail_desc">Complex B2B/B2C hybrid systems for retail giants.</p>
        </div>
        <div class="row-right">
          <span class="row-link">Launch //</span>
        </div>
      </a>
      <a href="/enfoque-marca-personal" class="focus-row-imm">
        <div class="row-left">
          <span class="row-num">05</span>
          <span class="row-title" data-i18n="about.focus_personal">Enfoque Marca Personal</span>
          <p class="row-desc" data-i18n="about.focus_personal_desc">Authority building and digital systems for experts.</p>
        </div>
        <div class="row-right">
          <span class="row-link">Launch //</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    width: 100%;
  }
  .focus-area-imm {
    padding: 120px 0;
    background: var(--void);
    border-top: 1px solid var(--rim);
  }
  .focus-header-imm {
    margin-bottom: 80px;
  }
  .title-sm {
    font-family: var(--title);
    font-size: 3.5rem;
    color: var(--white);
    margin: 0;
  }
  .focus-list-imm {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rim);
  }
  .focus-row-imm {
    display: grid;
    grid-template-columns: 350px 1fr 150px;
    align-items: center;
    padding: 40px 24px;
    border-bottom: 1px solid var(--rim);
    text-decoration: none;
    transition: background 0.3s ease;
  }
  .focus-row-imm:hover {
    background: var(--teal-glow);
  }
  .row-left {
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .row-num {
    font-family: var(--title);
    font-size: 1rem;
    color: var(--teal);
    opacity: 0.5;
  }
  .row-title {
    font-family: var(--title);
    font-size: 1.8rem;
    color: var(--white);
    letter-spacing: 0.04em;
  }
  .row-center p {
    font-size: 0.95rem;
    color: var(--smoke);
    margin: 0;
    max-width: 500px;
  }
  .row-link {
    font-family: var(--title);
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--teal);
    letter-spacing: 0.1em;
    opacity: 0.4;
    transition: opacity 0.3s ease;
    text-align: right;
    display: block;
  }
  .focus-row-imm:hover .row-link {
    opacity: 1;
  }
  @media (max-width: 1024px) {
    .focus-row-imm {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .row-link { text-align: left; }
  }
  .about-hero {
    padding: 160px 0 100px;
    background: var(--void);
    min-height: 100vh;
  }
  .hero-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 100px;
  }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 24px;
  }
  .title {
    font-family: var(--title);
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.92;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 32px;
  }
  .title .accent {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }
  .sub {
    font-size: 1.1rem;
    color: var(--smoke);
    line-height: 1.7;
    margin: 0 auto;
  }
  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .trait-card {
    background: var(--surface);
    border: 1px solid var(--rim);
    padding: 48px 32px;
    transition: border-color 0.3s, background 0.3s;
  }
  .trait-card:hover {
    border-color: var(--teal);
    background: var(--teal-glow);
  }
  .trait-icon {
    font-family: var(--title);
    font-size: 1.5rem;
    color: var(--teal);
    margin-bottom: 24px;
  }
  .trait-name {
    font-family: var(--title);
    font-size: 1.8rem;
    color: var(--white);
    margin-bottom: 12px;
    letter-spacing: 0.04em;
  }
  .trait-desc {
    font-size: 0.9rem;
    color: var(--smoke);
    line-height: 1.6;
  }
  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
