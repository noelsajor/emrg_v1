---
---

<section id="scene-3" class="scene">
  <div class="scene-label" data-i18n="work.label">Featured work</div>
  <h2 class="scene-title" data-i18n="work.title" data-i18n-html="true">Outcomes,<br /><em>not outputs.</em></h2>
  
  <div class="work-scroll-track" id="work-track">
    <!-- C1 -->
    <div class="case-card-imm">
      <div class="case-tag-imm" data-i18n="work.c1.tag">Shopify · Brand Identity</div>
      <h3 class="case-brand-imm">Solera</h3>
      <p class="case-desc-imm" data-i18n="work.c1.desc">Entering a saturated skincare market with no digital presence. Needed a brand and store capable of converting cold traffic from day one.</p>
      <div class="case-metrics-imm">
        <div class="case-metric-row">
          <div class="case-metric-val">3.8%</div>
          <div class="case-metric-lbl" data-i18n="work.c1.m1" data-i18n-html="true">CVR vs<br />industry avg</div>
        </div>
        <div class="case-metric-row">
          <div class="case-metric-val">6d</div>
          <div class="case-metric-lbl" data-i18n="work.c1.m2" data-i18n-html="true">Launch<br />timeline</div>
        </div>
      </div>
    </div>
    
    <!-- C2 -->
    <div class="case-card-imm">
      <div class="case-tag-imm" data-i18n="work.c2.tag">WooCommerce · Growth Systems</div>
      <h3 class="case-brand-imm">Varka</h3>
      <p class="case-desc-imm" data-i18n="work.c2.desc">Existing store suffering from slow load times, poor mobile UX, and no post-purchase retention system. Rebuilt from the ground up.</p>
      <div class="case-metrics-imm">
        <div class="case-metric-row">
          <div class="case-metric-val">-65%</div>
          <div class="case-metric-lbl" data-i18n="work.c2.m1" data-i18n-html="true">Page load<br />time</div>
        </div>
        <div class="case-metric-row">
          <div class="case-metric-val">+22%</div>
          <div class="case-metric-lbl" data-i18n="work.c2.m2" data-i18n-html="true">Repeat purchase<br />rate</div>
        </div>
      </div>
    </div>
    
    <!-- C3 -->
    <div class="case-card-imm">
      <div class="case-tag-imm" data-i18n="work.c3.tag">Shopify · Brand · CRO</div>
      <h3 class="case-brand-imm">Dune</h3>
      <p class="case-desc-imm" data-i18n="work.c3.desc">Apparel brand pivoting from wholesale to DTC. Needed a flagship store and full brand system built for conversion from day one.</p>
      <div class="case-metrics-imm">
        <div class="case-metric-row">
          <div class="case-metric-val">2x</div>
          <div class="case-metric-lbl" data-i18n="work.c3.m1" data-i18n-html="true">CVR<br />improvement</div>
        </div>
        <div class="case-metric-row">
          <div class="case-metric-val">12d</div>
          <div class="case-metric-lbl" data-i18n="work.c3.m2" data-i18n-html="true">Full<br />launch</div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="drag-hint">
    <span data-i18n="work.drag">Drag to explore</span>
  </div>
</section>
