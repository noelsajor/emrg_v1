---
import { client } from '../lib/sanity.client';
import { latestPostsQuery } from '../lib/sanity.queries';
import BlogCard from './BlogCard.astro';

// Attempt to fetch, fallback to placeholders if project ID is not set or fetch fails
const posts = await client.fetch(latestPostsQuery);
---
<section class="scene" id="scene-blog" aria-labelledby="blog-h">
  <div class="scene-label">Insights</div>
  <h2 class="scene-title" id="blog-h">Ecommerce<br /><em>intelligence.</em></h2>
  
  <div class="testi-layout" style="margin-top: 48px;">
    {posts.map((post: any) => (
      <BlogCard post={post} />
    ))}
  </div>

  <div style="margin-top: 48px; width: 100%; display: flex; justify-content: center;">
    <a href="/blog" class="btn-outline-imm">View All Insights</a>
  </div>
</section>

<style>
  #scene-blog {
    flex-direction: column;
    padding: 120px 80px 80px;
    align-items: flex-start;
    overflow-y: auto;
  }
  @media (max-width: 768px) {
    #scene-blog {
      padding: 100px 24px 60px;
    }
  }
</style>
