---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque Marca Personal | EMRG" description="SEO, Contenidos y Estrategia Digital para quienes no se conforman con lo básico. Convierte tu web en un imán de leads.">
  
  <section class="scene active" id="scene-0">
    <div class="content-wrap-imm">
      <div class="hero-flex-imm">
        <div class="hero-copy-imm">
          <p class="scene-label-imm">Personal Branding</p>
          <h1 class="hero-title-imm">¿Tu web solo <br/><span class="accent-teal">la ves tú?</span></h1>
          <p class="hero-sub-imm">
            SEO, Contenidos y Estrategia Digital para quienes no se conforman con lo básico. 
            Vamos a cambiar eso y convertir tu presencia en un imán de leads.
          </p>

          <div class="hero-actions-imm">
            <button class="btn-pkg-imm" onclick="window.goToScene(4)">Diseñar mi Estrategia</button>
            <button class="btn-outline-imm" onclick="window.goToScene(1)">Web vs. Imán de Leads</button>
          </div>

          <div class="hero-chips-imm">
             <span class="chip-pill-imm">Lead Magnet</span>
             <span class="chip-pill-imm">Authority SEO</span>
             <span class="chip-pill-imm">Conversion</span>
          </div>
        </div>

        <aside class="hero-visual-imm">
           <img src="/images/hero-branding.png" alt="High-Authority Personal Brand" class="hero-img-scene-imm" />
        </aside>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
        <p class="scene-label-imm">La Evolución</p>
        <h2 class="section-title-imm">El <em>Antes y Después.</em></h2>
      </div>

      <div class="pillars-list-imm">
        <article class="pillar-box-imm">
          <span class="pillar-idx-imm">01 — ANTES</span>
          <h3>Web "Tarjeta"</h3>
          <ul class="pillar-list-imm-ul">
             <li>Invisibilidad total en Google</li>
             <li>Estética genérica sin propósito</li>
             <li>Sin rutas de captación claras</li>
          </ul>
        </article>
        <article class="pillar-box-imm featured-pillar">
          <span class="pillar-idx-imm">02 — DESPUÉS</span>
          <h3>Imán de Leads</h3>
          <ul class="pillar-list-imm-ul">
             <li>Dominio de palabras clave</li>
             <li>Diseño que proyecta autoridad</li>
             <li>Embudo de conversión optimizado</li>
          </ul>
        </article>
        <article class="pillar-box-imm">
          <span class="pillar-idx-imm">03 — IMPACTO</span>
          <h3>Crecimiento</h3>
          <p>Transformamos un sitio pasivo en un motor de generación de leads cualificados 24/7.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Servicios</p>
         <h2 class="section-title-imm">Estrategia <em>Integral.</em></h2>
      </div>
      
      <div class="services-imm-grid">
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Auditoría SEO Profunda</h3>
            <p>Análisis técnico y de posicionamiento de tus activos actuales.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Web Optimizada</h3>
            <p>Desarrollo premium enfocado en velocidad y conversión móvil.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Blog Corporativo</h3>
            <p>Estrategia de contenidos para dominar tu nicho de autoridad.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">04</span>
            <h3>Redes Útiles</h3>
            <p>Gestión con propósito comercial y enfoque en resultados.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Diferenciador</p>
         <h2 class="section-title-imm">Por qué <em>EMRG.</em></h2>
      </div>
      
      <div class="quote-full-imm">
         <p class="hero-quote-imm">"Somos tu equipo de marketing externo, pero con tu misma pasión."</p>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-4">
    <div class="content-wrap-imm form-layout-imm">
       <div class="form-info-imm">
          <p class="scene-label-imm">Contacto</p>
          <h2 class="section-title-imm">Hablemos de <em>tu proyecto.</em></h2>
          <p class="hero-sub-imm">Cuéntanos sobre tus metas y diseñamos tu estrategia personalizada hoy mismo.</p>
       </div>
       <div class="form-box-imm">
          <form class="personal-form-imm">
             <div class="form-grid-imm">
                <input type="text" placeholder="TU NOMBRE" required />
                <input type="text" placeholder="TU PROFESIÓN" required />
             </div>
             <textarea placeholder="CUÉNTANOS TU META PRINCIPAL..." required style="width: 100%; height: 120px; background: var(--void); border: 1px solid var(--rim); color: white; padding: 18px; font-family: var(--body);"></textarea>
             <div class="form-grid-imm">
                <input type="email" placeholder="EMAIL CORPORATIVO" required />
                <input type="tel" placeholder="WHATSAPP" required />
             </div>
             <button class="btn-pkg-imm" type="submit">SOLICITAR ESTRATEGIA</button>
             <p class="form-success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.8rem; font-weight: 800;">SOLICITUD ENVIADA CON ÉXITO. REVISAREMOS TU CASO.</p>
          </form>
       </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .scene-label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .hero-flex-imm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-copy-imm {
    max-width: 650px;
  }

  .hero-title-imm {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 32px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .section-title-imm {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 48px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .hero-sub-imm {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--smoke);
    max-width: 480px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .btn-pkg-imm {
    background: var(--teal);
    color: #fff;
    padding: 12px 28px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
  }

  .btn-outline-imm {
    background: transparent;
    border: 1px solid var(--rim);
    color: #fff;
    padding: 12px 28px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition: 0.3s;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
    margin-left: 20px;
  }

  .btn-pkg-imm:hover, .btn-outline-imm:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .hero-visual-imm {
    border: 1px solid var(--rim);
    border-radius: 4px;
    padding: 12px;
    background: rgba(255,255,255,0.05);
  }

  .hero-img-scene-imm {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .hero-quote-imm {
     font-size: 2.8rem;
     line-height: 1.2;
     color: var(--white);
     font-family: var(--title);
     font-style: italic;
     text-align: center;
     max-width: 900px;
     margin: 0 auto;
  }

  .pillars-list-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .pillar-box-imm {
     border: 1px solid var(--rim);
     padding: 48px;
     background: var(--surface);
  }

  .featured-pillar {
    border-color: var(--teal);
    background: var(--teal-glow);
  }

  .pillar-idx-imm {
     font-family: var(--body);
     font-size: 0.65rem;
     color: var(--teal);
     display: block;
     margin-bottom: 16px;
     font-weight: 600;
     letter-spacing: 0.1em;
  }

  .pillar-box-imm h3 {
     font-size: 2rem;
     margin-bottom: 24px;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .pillar-list-imm-ul {
     list-style: none;
     padding: 0;
     display: grid;
     gap: 12px;
  }

  .pillar-list-imm-ul li {
     color: var(--smoke);
     font-size: 0.95rem;
  }

  .pillar-list-imm-ul li::before {
     content: "→";
     margin-right: 10px;
     color: var(--teal);
  }

  .services-imm-grid {
     display: grid;
     grid-template-columns: repeat(2, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .serv-card-imm {
     background: var(--surface);
     padding: 60px;
     border: 1px solid var(--rim);
     transition: 0.3s;
  }

  .serv-card-imm:hover {
    border-color: var(--teal);
  }

  .serv-card-imm h3 {
     color: var(--white);
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
     font-size: 2rem;
  }

  .quote-full-imm {
    width: 100%;
    padding: 100px 0;
  }

  .form-layout-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 100px;
     align-items: center;
  }

  .form-grid-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 16px;
  }

  .form-box-imm form {
     display: flex;
     flex-direction: column;
     gap: 16px;
  }

  input {
     background: var(--void);
     border: 1px solid var(--rim);
     padding: 18px;
     color: var(--white);
     font-family: var(--body);
  }

  @media (max-width: 1024px) {
    .content-wrap-imm { padding: 0 24px; }
    .hero-flex-imm, .pillars-list-imm, .services-imm-grid, .form-layout-imm, .form-grid-imm {
      grid-template-columns: 1fr;
    }
    .hero-visual-imm { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const auditForm = document.querySelector('.personal-form-imm');
    if (auditForm) {
      auditForm.addEventListener('submit', (e) => {
        e.preventDefault();
        auditForm.reset();
        const success = document.querySelector('.form-success-imm');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
