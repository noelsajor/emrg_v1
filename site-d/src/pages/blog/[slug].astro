---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { client, urlFor } from '../../lib/sanity.client';
import { postBySlugQuery } from '../../lib/sanity.queries';
import { generateSchemaMarkup, generateBreadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  let posts = [];
  try {
    posts = await client.fetch(`*[_type == "post" && defined(slug.current)]{ "slug": slug.current }`);
  } catch (e) {
    console.warn("Sanity fetch failed for static paths, using placeholders");
    posts = [
      { slug: 'future-dtc-architecture' },
      { slug: 'brand-identity-growth' },
      { slug: 'post-purchase-optimization' }
    ];
  }
  return posts.map((post: any) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;

let post;
try {
  post = await client.fetch(postBySlugQuery, { slug });
} catch (e) {
  console.warn(`Sanity fetch failed for slug ${slug}, using fallback mock data`);
}

// Fallback / Mock data if fetch fails
if (!post) {
  const mocks = {
    'future-dtc-architecture': {
      title: "The Future of DTC Architecture",
      excerpt: "How headless systems are changing the conversion landscape for growing brands.",
      publishedAt: new Date().toISOString(),
      author: { name: "EMRG Team" },
      categories: ["Engineering"],
      readingTime: 5,
      body: [
        { _type: 'block', children: [{ text: "Headless commerce is no longer just a buzzword. It's the infrastructure required to hit the sub-second load times that modern DTC consumers expect. By decoupling the presentation layer (Astro) from the commerce backend (Shopify), brands can deliver experiences that are both visually stunning and technically superior." }] }
      ],
      relatedPosts: []
    }
  };
  post = mocks[slug] || {
    title: "Insight Entry",
    excerpt: "Detailed ecommerce intelligence and engineering strategy.",
    publishedAt: new Date().toISOString(),
    author: { name: "EMRG Team" },
    categories: ["Strategy"],
    readingTime: 5,
    body: [{ _type: 'block', children: [{ text: "Content loading or unavailable." }] }],
    relatedPosts: []
  };
}

const jsonLd = generateSchemaMarkup({
  title: post.title,
  description: post.excerpt,
  type: 'article',
  publishedAt: post.publishedAt,
  authorName: post.author?.name
});

const breadcrumbs = generateBreadcrumbSchema([
  { name: 'Home', item: 'https://emrg.studio/' },
  { name: 'Blog', item: 'https://emrg.studio/blog' },
  { name: post.title, item: `https://emrg.studio/blog/${slug}` }
]);
---

<BaseLayout title={`${post.title} — EMRG`} description={post.excerpt}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  
  <article class="post-article">
    <div class="post-container">
      <div class="case-tag-imm" style="margin-bottom: 24px;">
        {post.categories?.[0]} · {post.readingTime} min read
      </div>
      <h1 class="hero-title post-title">{post.title}</h1>
      <p class="hero-sub post-excerpt">{post.excerpt}</p>

      {post.mainImage && (
        <div class="post-feature-image">
          <img src={urlFor(post.mainImage).url()} alt={post.title} />
        </div>
      )}
      
      <div class="post-meta">
        <div class="post-author">
          <div class="author-avatar"></div>
          <div>
            <div class="author-name">{post.author?.name || "EMRG"}</div>
            <div class="author-role">Ecommerce Strategist</div>
          </div>
        </div>
        <div class="post-date">
          Published {new Date(post.publishedAt).toLocaleDateString()}
        </div>
      </div>

      <div class="prose">
        {post.body?.map((block: any) => {
          if (block._type === 'block') {
            const style = block.style || 'normal';
            if (style === 'h2') return <h2 style="color: var(--white); font-family: var(--title); font-size: 2.2rem; margin: 48px 0 24px; letter-spacing: 0.04em; text-align: left;">{block.children.map((c: any) => c.text).join('')}</h2>;
            if (style === 'h3') return <h3 style="color: var(--white); font-family: var(--title); font-size: 1.8rem; margin: 40px 0 20px; letter-spacing: 0.04em; text-align: left;">{block.children.map((c: any) => c.text).join('')}</h3>;
            return <p style="margin-bottom: 24px; text-align: left;">{block.children.map((c: any) => c.text).join('')}</p>;
          }
          if (block._type === 'image') {
            return (
              <figure style="margin: 48px 0; border: 1px solid var(--rim); border-radius: 8px; overflow: hidden; background: var(--deep);">
                <img src={urlFor(block).url()} alt={block.alt || ""} style="width: 100%; height: auto; display: block;" />
                {block.caption && <figcaption style="padding: 16px; font-size: 0.8rem; color: var(--mist); text-align: center; border-top: 1px solid var(--rim);">{block.caption}</figcaption>}
              </figure>
            );
          }
          return null;
        })}
      </div>

      <div class="post-cta">
        <h2 class="scene-title post-cta-title">Ready to engineer<br />your growth?</h2>
        <a href="https://cal.com/emrg" class="btn-glow">Book a Call →</a>
      </div>

      {post.relatedPosts?.length > 0 && (
        <div class="related-section">
          <h3 class="scene-label">Related Reading</h3>
          <div class="blog-grid">
            {post.relatedPosts.map((p: any) => <BlogCard post={p} showExcerpt={false} />)}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<style is:global>
	body {
		overflow: auto !important;
		cursor: default !important;
	}
	#cursor, #cursor-ring, #canvas-bg, #scene-nav, #scroll-hint {
		display: none !important;
	}
	#nav {
		background: rgba(2,4,8,0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--rim);
	}
	.hero-title {
		opacity: 1 !important;
		transform: none !important;
	}
</style>

<style>
  .post-article {
    padding: 160px 80px 80px;
    min-height: 100vh;
    position: relative;
    z-index: 5;
    background: var(--void);
  }
  .post-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: left;
  }
  .post-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-bottom: 32px;
    line-height: 1.1;
    text-align: left;
  }
  .post-excerpt {
    margin: 0 0 48px;
    max-width: 100%;
    font-size: 1.25rem;
    color: var(--smoke);
    text-align: left;
  }
  .post-feature-image {
    margin-bottom: 64px;
    border: 1px solid var(--rim);
    border-radius: 12px;
    overflow: hidden;
    background: var(--deep);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }
  .post-feature-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .post-meta {
    padding: 24px 0;
    border-top: 1px solid var(--rim);
    border-bottom: 1px solid var(--rim);
    margin-bottom: 64px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .post-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    background: var(--teal);
    border-radius: 50%;
  }
  .author-name {
    font-size: 0.8rem;
    font-weight: 600;
  }
  .author-role {
    font-size: 0.65rem;
    color: var(--mist);
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--mist);
    text-transform: uppercase;
  }
  .prose {
    color: var(--smoke);
    line-height: 1.8;
    font-size: 1.1rem;
    letter-spacing: 0.01em;
  }
  .prose p {
    margin-bottom: 24px;
  }
  .prose img {
    max-width: 100%;
    border-radius: 8px;
    margin: 40px 0;
  }
  .post-cta {
    margin-top: 100px;
    padding: 64px;
    border: 1px solid var(--teal);
    background: rgba(0,229,200,0.05);
    text-align: center;
  }
  .post-cta-title {
    font-size: 2.5rem;
    margin-bottom: 24px;
  }
  .related-section {
    margin-top: 100px;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
    margin-top: 32px;
  }
  @media (max-width: 768px) {
    .post-article {
      padding: 120px 24px 64px;
    }
    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
