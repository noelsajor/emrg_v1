---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque Legal | EMRG" description="SEO y captación de clientes para abogados que quieren dominar Google en su ciudad.">
  
  <!-- Intro Scene -->
  <section class="scene active" id="scene-0">
    <div class="content-wrap-imm">
      <div class="hero-flex-imm">
        <div class="hero-copy-imm">
          <p class="scene-label-imm">Especialistas en crecimiento legal</p>
          <h1 class="hero-title-imm">El Veredicto <br/><span class="accent-teal">Digital.</span></h1>
          <p class="hero-sub-imm">SEO y captación estratégica para firmas de abogados que dominan su mercado digital.</p>
          <div class="hero-actions-imm">
            <a href="#scene-4" class="btn-pkg-imm" onclick="window.goToScene(4); return false;">Auditoría Gratuita</a>
          </div>
        </div>
        
        <div class="hero-metric-box">
           <div class="m-row">
              <span class="m-val">§ 01</span>
              <span class="m-lbl">Presencia Dominante</span>
           </div>
           <div class="m-row">
              <span class="m-val">3X</span>
              <span class="m-lbl">Consultas Cualificadas</span>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Scene -->
  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
        <p class="scene-label-imm">El Problema</p>
        <h2 class="section-title-imm">Muchos despachos pierden oportunidades por una <em>presencia digital débil.</em></h2>
      </div>
      
      <div class="pillars-list-imm">
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Invisibilidad</h3>
            <p>Si no apareces en búsquedas de alta intención, cedes tu mercado a otros despachos.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Fuga de Confianza</h3>
            <p>El cliente legal no contacta si no percibe autoridad absoluta en cada punto visual.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Captación Pasiva</h3>
            <p>Depender de referidos limita el escalado. Necesitas un sistema proactivo y digital.</p>
         </div>
      </div>
    </div>
  </section>

  <!-- Authority Scene -->
  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Metodología</p>
         <h2 class="section-title-imm">Metodología técnica para <em>firmas de élite.</em></h2>
      </div>
      
      <div class="services-imm-grid">
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Enfoque Sectorial</h3>
            <p>Arquitectura SEO y confianza diseñada específicamente para el sector jurídico.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Negocio Real</h3>
            <p>Consultas cualificadas alineadas con tu área de práctica y objetivos comerciales.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Técnica CRO</h3>
            <p>Optimización constante de visibilidad y puntos de fuga para mejorar rendimiento.</p>
         </div>
      </div>
    </div>
  </section>

  <!-- Performance Scene -->
  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Impacto</p>
         <h2 class="section-title-imm">Resultados de <em>Alta Intensidad.</em></h2>
      </div>
      
      <div class="cases-scroll-imm">
         <div class="case-item-imm">
            <span class="case-cat-imm">FAMILIA</span>
            <h3>Visibilidad Local</h3>
            <p>+120% en SEO Local | +35% en consultas directas.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">MERCANTIL</span>
            <h3>Autoridad Premium</h3>
            <p>Reposicionamiento digital para captar clientes de alto valor comercial.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">PENAL</span>
            <h3>Conversión Urgente</h3>
            <p>Optimización móvil de alta velocidad para situaciones legales críticas.</p>
         </div>
      </div>
    </div>
  </section>

  <!-- Lead Magnet Scene -->
  <section class="scene" id="scene-4">
    <div class="content-wrap-imm form-layout-imm">
       <div class="form-info-imm">
          <p class="scene-label-imm">Recurso</p>
          <h2 class="section-title-imm">Guía Gratuita.</h2>
          <p class="hero-sub-imm">12 errores que impiden a un despacho captar clientes desde Google.</p>
          <ul class="checklist-imm">
             <li>Detección de puntos de fuga</li>
             <li>Auditoría de confianza visual</li>
             <li>Checklist local de Google</li>
          </ul>
       </div>
       <div class="form-box-imm">
          <form class="legal-lead-form-imm">
             <input type="email" placeholder="EMAIL PROFESIONAL" required />
             <button class="btn-pkg-imm" type="submit">DESCARGAR AHORA</button>
          </form>
          <p class="lead-success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.85rem; font-weight: 800;">Enviado. Comprueba tu bandeja de entrada.</p>
       </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
    width: 100%;
  }

  .scene-label-imm {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--teal);
    margin-bottom: 24px;
    display: block;
    font-weight: 800;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .hero-flex-imm {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hero-copy-imm {
    max-width: 650px;
  }

  .hero-title-imm {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.9;
    margin-bottom: 32px;
    font-family: var(--title);
    text-transform: uppercase;
  }

  .section-title-imm {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 40px;
    font-family: var(--title);
    text-transform: uppercase;
  }

  .hero-sub-imm {
    font-size: 1.15rem;
    color: var(--smoke);
    max-width: 500px;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .btn-pkg-imm {
    background: var(--teal);
    color: #000;
    padding: 18px 36px;
    font-weight: 900;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
  }

  .btn-pkg-imm:hover {
    background: #fff;
    transform: translateY(-2px);
  }

  .hero-metric-box {
    background: var(--surface);
    border: 1px solid var(--rim);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    min-width: 300px;
  }

  .m-row .m-val {
    display: block;
    font-family: var(--title);
    font-size: 3.5rem;
    color: var(--white);
    line-height: 1;
  }
  .m-row .m-lbl {
    font-size: 0.75rem;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
  }

  .pillars-list-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .pillar-box-imm {
     border-top: 1px solid var(--rim);
     padding-top: 32px;
  }

  .pillar-idx-imm {
     font-family: monospace;
     font-size: 0.85rem;
     color: var(--teal);
     display: block;
     margin-bottom: 24px;
     font-weight: 800;
  }

  .pillar-box-imm h3 {
     font-size: 2rem;
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .pillar-box-imm p {
     font-size: 0.95rem;
     color: var(--smoke);
     line-height: 1.6;
  }

  .services-imm-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .serv-card-imm {
     background: var(--surface);
     padding: 40px;
     border: 1px solid var(--rim);
     transition: 0.3s;
  }

  .serv-card-imm:hover {
    border-color: var(--teal);
  }

  .serv-card-imm h3 {
     color: var(--white);
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
     font-size: 1.8rem;
  }

  .serv-card-imm p {
     color: var(--smoke);
     font-size: 0.95rem;
     line-height: 1.6;
  }

  .cases-scroll-imm {
     display: flex;
     gap: 32px;
     margin-top: 40px;
  }

  .case-item-imm {
     flex: 1;
     border: 1px solid var(--rim);
     padding: 40px;
     background: var(--surface);
  }

  .case-cat-imm {
     font-size: 0.75rem;
     color: var(--teal);
     letter-spacing: 0.15em;
     display: block;
     margin-bottom: 16px;
     font-weight: 800;
  }

  .case-item-imm h3 {
    font-size: 2rem;
    font-family: var(--title);
    margin-bottom: 12px;
  }

  .form-layout-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 100px;
     align-items: center;
  }

  .checklist-imm {
     list-style: none;
     padding: 0;
     margin-top: 32px;
  }

  .checklist-imm li {
     padding-left: 28px;
     position: relative;
     margin-bottom: 16px;
     color: var(--white);
     font-size: 0.95rem;
  }

  .checklist-imm li::before {
     content: '→';
     position: absolute;
     left: 0;
     color: var(--teal);
     font-weight: 800;
  }

  .form-box-imm form {
     display: flex;
     flex-direction: column;
     gap: 16px;
  }

  input {
     background: var(--void);
     border: 1px solid var(--rim);
     padding: 18px;
     color: var(--white);
     font-family: var(--body);
  }

  @media (max-width: 1024px) {
    .content-wrap-imm { padding: 0 24px; }
    .hero-flex-imm, .pillars-list-imm, .services-imm-grid, .cases-scroll-imm, .form-layout-imm {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
    .hero-metric-box { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const leadForm = document.querySelector('.legal-lead-form-imm');
    if (leadForm) {
      leadForm.addEventListener('submit', (e) => {
        e.preventDefault();
        leadForm.reset();
        const success = document.querySelector('.lead-success-imm');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
