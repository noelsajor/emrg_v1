---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque Legal | EMRG" description="SEO y estrategias digitales para despachos de abogados y firmas legales. Construimos prestigio y captamos clientes cualificados.">
  
  <section class="scene active" id="scene-0">
    <div class="content-wrap-imm">
      <div class="hero-flex-imm">
        <div class="hero-copy-imm">
          <p class="scene-label-imm">Sector Legal</p>
          <h1 class="hero-title-imm">Tu despacho merece una presencia digital <span class="accent-teal">tan sólida como tus argumentos.</span></h1>
          <p class="hero-sub-imm">Estrategias de SEO y contenidos para firmas que buscan liderar su sector. Construimos la infraestructura digital que tu prestigio demanda.</p>
          <div class="hero-actions-imm">
            <a href="#scene-5" class="btn-pkg-imm" onclick="window.goToScene(5); return false;">Solicitar auditoría gratuita</a>
          </div>
        </div>
        
        <div class="hero-image-box-imm">
           <img src="/images/hero-legal.png" alt="Despacho legal" class="hero-img-imm" />
        </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
        <p class="scene-label-imm">Propuesta de Valor</p>
        <h2 class="section-title-imm">No solo hacemos webs, <em class="accent-teal">construimos prestigio.</em></h2>
      </div>
      
      <div class="pillars-list-imm">
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Arquitectura Ética</h3>
            <p>Estructuramos tu sitio para reflejar la profundidad de tus servicios con el máximo rigor profesional.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Reputación Digital</h3>
            <p>Aseguramos que tu autoridad offline se traduzca perfectamente al entorno digital corporativo.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Captación de Élite</h3>
            <p>Estrategias diseñadas para atraer el perfil de cliente que tu firma merece.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">La Solución</p>
         <h2 class="section-title-imm">Framework <em>Legal Growth.</em></h2>
      </div>
      
      <div class="services-imm-grid">
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 1</span>
            <h3>Arquitectura Web</h3>
            <p>Diseño enfocado en áreas específicas: Penal, Mercantil, Familia.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 2</span>
            <h3>Gestión de RRSS</h3>
            <p>LinkedIn e Instagram con tono institucional y branding de socios.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 3</span>
            <h3>Fidelización CRM</h3>
            <p>Email Marketing estratégico para mantener la recurrencia de clientes.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Especialidades</p>
         <h2 class="section-title-imm">Marketing para <em>Expertos en Leyes.</em></h2>
      </div>
      
      <div class="cases-scroll-imm">
         <div class="case-item-imm">
            <span class="case-cat-imm">DERECHO PENAL</span>
            <h3>Autoridad Directa</h3>
            <p>Estrategias de contenido que generan confianza inmediata ante casos complejos.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">MERCANTIL</span>
            <h3>Branding B2B</h3>
            <p>Posicionamos a tu firma como el socio estratégico ideal para empresas.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">FAMILIA</span>
            <h3>Empatía y Rigor</h3>
            <p>Diseño de mensajes que equilibran la sensibilidad humana con la solidez legal.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-4" style="background: var(--surface);">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Autoridad</p>
         <h2 class="section-title-imm">Resultados <em>Dedicados.</em></h2>
      </div>
      <div class="services-list-imm">
         <div class="service-row-imm"><span>01</span><h3>+15 Firmas Asesoradas</h3></div>
         <div class="service-row-imm"><span>02</span><h3>Posicionamiento Premium</h3></div>
         <div class="service-row-imm"><span>03</span><h3>Estrategia LinkedIn Socio</h3></div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-5">
    <div class="content-wrap-imm form-layout-imm">
       <div class="form-info-imm">
          <p class="scene-label-imm">Diagnóstico</p>
          <h2 class="section-title-imm">Solicita una auditoría gratuita para <em class="accent-teal">tu firma legal.</em></h2>
          <p class="hero-sub-imm">Agenda tu diagnóstico y descubre cómo elevar tu prestigio digital.</p>
       </div>
       <div class="form-box-imm">
          <form class="legal-audit-form-imm" id="legal-form">
             <div class="form-grid-imm">
                <input type="text" placeholder="NOMBRE COMPLETO" required />
                <input type="text" placeholder="FIRMA / DESPACHO" required />
             </div>
             <input type="email" placeholder="EMAIL CORPORATIVO" required />
             <textarea placeholder="OBJETIVOS DE LA FIRMA..." required style="min-height: 100px;"></textarea>
             <button class="btn-pkg-imm" type="submit">Solicitar auditoría ahora</button>
          </form>
          <p class="audit-success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.85rem; font-weight: 800;">Solicitud recibida. Contactaremos con tu despacho pronto.</p>
       </div>
    </div>
  </section>

  <section class="scene" id="scene-6-proof" style="background: var(--surface);">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Prestigio</p>
         <h2 class="section-title-imm">Confianza avalada por el <em class="accent-teal">sector.</em></h2>
      </div>
      <div class="carousel-container-imm">
        <div class="carousel-track-imm" id="testimonial-track-imm">
          <div class="carousel-slide-imm active">
            <p>“Profesionales que entienden el rigor de nuestra firma.”</p>
            <strong>Socio Director — Firma Madrid</strong>
          </div>
          <div class="carousel-slide-imm">
            <p>“Nuestra captación LinkedIn creció exponencialmente.”</p>
            <strong>Despacho Mercantil — Barcelona</strong>
          </div>
        </div>
        <div class="carousel-nav-imm">
          <button class="dot-imm active"></button>
          <button class="dot-imm"></button>
        </div>
      </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .scene-label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .hero-flex-imm {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hero-copy-imm {
    max-width: 650px;
  }

  .hero-title-imm {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 32px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .section-title-imm {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 48px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .hero-sub-imm {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--smoke);
    max-width: 480px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .btn-pkg-imm {
    background: var(--teal);
    color: #fff;
    padding: 12px 28px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
  }

  .btn-pkg-imm:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .hero-image-box-imm {
    width: 100%;
    max-width: 500px;
    border-radius: 20px;
    border: 1px solid var(--rim);
    overflow: hidden;
    box-shadow: 0 0 40px rgba(115, 96, 248, 0.2);
    transition: 0.5s;
  }

  .hero-image-box-imm:hover {
    transform: scale(1.02);
    box-shadow: 0 0 60px rgba(115, 96, 248, 0.4);
  }

  .hero-img-imm {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  /* Carousel */
  .carousel-container-imm {
    margin-top: 40px;
    overflow: hidden;
    padding-bottom: 40px;
  }
  .carousel-track-imm {
    display: flex;
    transition: 0.5s;
  }
  .carousel-slide-imm {
    min-width: 100%;
    padding: 40px;
    text-align: center;
    opacity: 0.3;
    transition: 0.5s;
    background: rgba(255,255,255,0.02);
  }
  .carousel-slide-imm.active { opacity: 1; border: 1px solid var(--teal); }
  .carousel-slide-imm p { font-size: 1.5rem; font-style: italic; margin-bottom: 16px; font-family: var(--title); }
  .carousel-nav-imm { display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
  .dot-imm { width: 8px; height: 8px; border-radius: 50%; background: var(--rim); border: none; cursor: pointer; }
  .dot-imm.active { background: var(--teal); width: 20px; border-radius: 10px; }

  .pillars-list-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .pillar-box-imm {
     border-top: 1px solid var(--rim);
     padding-top: 32px;
  }

  .pillar-idx-imm {
     font-family: var(--body);
     font-size: 0.65rem;
     color: var(--teal);
     display: block;
     margin-bottom: 16px;
     font-weight: 600;
     letter-spacing: 0.1em;
  }

  .pillar-box-imm h3 {
     font-size: 2rem;
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .pillar-box-imm p {
     font-size: 0.95rem;
     color: var(--smoke);
     line-height: 1.6;
  }

  .services-imm-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .serv-card-imm {
     background: var(--surface);
     padding: 40px;
     border: 1px solid var(--rim);
     transition: 0.3s;
  }

  .serv-card-imm:hover {
    border-color: var(--teal);
  }

  .serv-card-imm h3 {
     color: var(--white);
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
     font-size: 1.8rem;
  }

  .serv-card-imm p {
     color: var(--smoke);
     font-size: 0.8rem;
     line-height: 1.7;
  }

  .cases-scroll-imm {
     display: flex;
     gap: 32px;
     margin-top: 40px;
  }

  .case-item-imm {
     flex: 1;
     border: 1px solid var(--rim);
     padding: 40px;
     background: var(--surface);
  }

  .case-cat-imm {
     font-size: 0.75rem;
     color: var(--teal);
     letter-spacing: 0.15em;
     display: block;
     margin-bottom: 16px;
     font-weight: 800;
  }

  .case-item-imm h3 {
    font-size: 2rem;
    font-family: var(--title);
    margin-bottom: 12px;
  }

  .services-list-imm {
    width: 100%;
    margin-top: 40px;
  }

  .service-row-imm {
     display: flex;
     align-items: center;
     gap: 48px;
     padding: 32px 0;
     border-bottom: 1px solid var(--rim);
     transition: 0.3s;
  }

  .service-row-imm span {
    color: var(--teal);
    font-weight: 600;
    font-family: var(--body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .service-row-imm h3 {
     font-size: 3rem;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .form-layout-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 100px;
     align-items: center;
  }

  .form-grid-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 16px;
  }

  .form-box-imm form {
     display: flex;
     flex-direction: column;
     gap: 16px;
  }

  input, textarea {
     background: var(--void);
     border: 1px solid var(--rim);
     padding: 18px;
     color: var(--white);
     font-family: var(--body);
  }

  @media (max-width: 1024px) {
    .content-wrap-imm { padding: 0 24px; }
    .hero-flex-imm, .pillars-list-imm, .services-imm-grid, .cases-scroll-imm, .form-layout-imm, .service-row-imm h3 {
      grid-template-columns: 1fr;
      flex-direction: column;
      font-size: 2rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const f = document.getElementById('legal-form');
    if (f) {
      f.addEventListener('submit', (e) => {
        e.preventDefault();
        f.reset();
        const success = document.querySelector('.audit-success-imm');
        if (success) success.style.display = 'block';
      });
    }

    // Carousel
    const track = document.getElementById('testimonial-track-imm');
    const slides = Array.from(track ? track.children : []);
    const dots = Array.from(document.querySelectorAll('.dot-imm'));
    let curIdx = 0;

    function upd(i) {
      if(!track) return;
      track.style.transform = `translateX(-${i*100}%)`;
      slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
      dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
      curIdx = i;
    }
    dots.forEach((d, i) => d.addEventListener('click', () => upd(i)));
    if(slides.length > 0) setInterval(() => upd((curIdx+1)%slides.length), 5000);
  });
</script>
