---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutPage from '../components/AboutPage.astro';
---

<BaseLayout title="About Us | EMRG">
  <AboutPage />
</BaseLayout>

<style is:global>
  /* Fixed bg for consistency */
  body {
    background: #020408;
    overflow: auto; /* Enable scroll for static page */
    cursor: default; /* Reset custom cursor if needed or keep it? I'll keep it for flair */
  }
  #scroll-container {
    position: relative;
    height: auto;
    overflow: visible;
  }
</style>
