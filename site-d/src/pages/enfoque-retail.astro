---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque Retail y Mayoristas | EMRG" description="Gestión integral de marketing digital para negocios que venden en grande. Tiendas online de alto rendimiento y SEO para catálogos masivos.">
  
  <section class="scene active" id="scene-0">
    <div class="hero-block-imm">
      <p class="label-imm">Retail & Mayoristas</p>
      <h1 class="title-imm">Vende en <br/><span class="teal-glow">Grande.</span></h1>
      <p class="desc-imm">Lleva tu inventario a las pantallas de tus clientes ideales. Gestión integral de marketing digital para negocios que operan en gran volumen.</p>
      
      <div class="action-grid-imm">
        <a href="#scene-3" class="btn-imm" onclick="window.goToScene(3); return false;">Hablemos de Escalar //</a>
        <div class="metric-chip-imm">
           <span class="m-val-imm">INVENTORY SYNC</span>
           <span class="m-val-imm">GROWTH DATA</span>
        </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <h2 class="section-title-imm">Enfoque en <span class="teal-glow">Resultados.</span></h2>
      <p class="desc-imm">No solo gestionamos, escalamos. Nuestras estrategias están diseñadas para convertir el tráfico en ingresos predecibles.</p>
      
      <div class="stats-grid-imm">
        <div class="stat-box-imm">
           <span class="s-val-imm">+120%</span>
           <p>Crecimiento en tráfico orgánico de categorías.</p>
        </div>
        <div class="stat-box-imm highlight-imm">
           <span class="s-val-imm">+45%</span>
           <p>Mejora en tasa de conversión e-commerce.</p>
        </div>
        <div class="stat-box-imm">
           <span class="s-val-imm">+3x</span>
           <p>Retorno de inversión en email marketing.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <h2 class="section-title-imm">Servicios <span class="teal-glow">Clave.</span></h2>
      <div class="services-imm">
         <div class="service-row-imm">
            <span>01</span>
            <h3>Tiendas High-Performance</h3>
         </div>
         <div class="service-row-imm">
            <span>02</span>
            <h3>Email Automático</h3>
         </div>
         <div class="service-row-imm">
            <span>03</span>
            <h3>SEO de Categoría</h3>
         </div>
         <div class="service-row-imm">
            <span>04</span>
            <h3>Social Cataloging</h3>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="contact-split-imm">
        <div class="contact-text-imm">
          <h2 class="section-title-imm">Escalar tus <span class="teal-glow">Ventas.</span></h2>
          <p class="desc-imm">Hablemos de cómo escalar tus ventas este mes con una infraestructura digital profesional y contenido que convierte.</p>
        </div>
        
        <form class="imm-form retail-form">
          <div class="form-row-imm">
            <input type="text" placeholder="NOMBRE" required />
            <input type="text" placeholder="EMPRESA" required />
          </div>
          <div class="form-row-imm">
            <input type="text" placeholder="CATÁLOGO (SKUs)" required />
            <input type="text" placeholder="CIUDAD" required />
          </div>
          <textarea placeholder="¿CUÁL ES TU META DE VENTAS?" required></textarea>
          <button type="submit" class="btn-imm">Hablemos de Escalar //</button>
          <p class="success-imm" style="display:none; margin-top: 1rem; color: var(--teal); font-weight: 800;">SOLICITUD RECIBIDA. NOS PONDREMOS EN CONTACTO.</p>
        </form>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-4-proof" style="background: var(--surface);">
    <div class="content-wrap-imm">
       <div class="differentiator-imm">
          <p class="scene-label-imm">Diferenciador</p>
          <h2 class="section-title-imm">Contenido que <em class="teal-glow">vende.</em></h2>
          <p class="desc-imm" style="max-width: 800px;">"Estrategias de contenido integral que convierten seguidores en compradores. Gestión de redes sociales enfocada 100% en catálogo y conversión comercial."</p>
       </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  .title-imm {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    font-weight: 900;
    margin-bottom: 32px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .section-title-imm {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    font-weight: 900;
    margin-bottom: 48px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .teal-glow {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .desc-imm {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--smoke);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .action-grid-imm {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .btn-imm {
    background: var(--teal);
    color: #fff;
    padding: 12px 28px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
  }

  .btn-imm:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .metric-chip-imm {
     display: flex;
     gap: 20px;
     font-size: 0.75rem;
     color: var(--teal);
     font-family: monospace;
     font-weight: 800;
  }

  .stats-grid-imm {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .stat-box-imm {
    padding: 40px;
    border: 1px solid var(--rim);
    background: var(--surface);
  }
  .stat-box-imm.highlight-imm { border-color: var(--teal); background: var(--teal-glow); }
  .s-val-imm { font-size: 3rem; font-family: var(--title); color: var(--white); display: block; margin-bottom: 16px; }
  .highlight-imm .s-val-imm { color: var(--teal); }

  .services-imm {
     width: 100%;
  }

  .service-row-imm {
     display: flex;
     align-items: center;
     gap: 48px;
     padding: 24px 0;
     border-bottom: 1px solid var(--rim);
     transition: 0.3s;
  }

  .service-row-imm:hover {
    padding-left: 24px;
    border-bottom-color: var(--teal);
  }

  .service-row-imm span {
    color: var(--teal);
    font-weight: 600;
    font-family: var(--body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .service-row-imm h3 {
     font-size: 3rem;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .contact-split-imm {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    width: 100%;
    align-items: center;
  }

  .imm-form {
    display: grid;
    gap: 20px;
    background: var(--surface);
    padding: 48px;
    border: 1px solid var(--rim);
  }

  .form-row-imm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  input, textarea {
    background: var(--void);
    border: 1px solid var(--rim);
    padding: 18px;
    color: #fff;
    width: 100%;
    font-family: var(--body);
  }

  textarea {
    height: 120px;
    resize: none;
  }

  .scene-label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .stats-grid-imm, .contact-split-imm, .form-row-imm {
      grid-template-columns: 1fr;
    }
    .service-row-imm h3 { font-size: 1.8rem; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.retail-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.reset();
        const success = form.querySelector('.success-imm');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
