---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque en Salud | EMRG" description="SEO y crecimiento digital especializado en salud. Ayudamos a clínicas y médicos a atraer más pacientes.">
  
  <section class="scene active" id="scene-0">
    <div class="content-wrap-imm">
      <div class="hero-flex-imm">
        <div class="hero-copy-imm">
          <p class="scene-label-imm">Sector Salud</p>
          <h1 class="hero-title-imm">¿Tus pacientes te buscan en Google o <span class="accent-teal">solo te encuentran por recomendación?</span></h1>
          <p class="hero-sub-imm">Creamos sitios web que generan confianza y citas médicas en automático. Diseño web para médicos y clínicas que buscan autoridad digital.</p>
          <div class="hero-actions-imm">
            <a href="#scene-5" class="btn-pkg-imm" onclick="window.goToScene(5); return false;">Quiero digitalizar mi consulta</a>
          </div>
        </div>
        
        <div class="hero-image-box-imm">
           <img src="/images/hero-medical.png" alt="Consultorio" class="hero-img-imm" />
        </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
        <p class="scene-label-imm">El Problema</p>
        <h2 class="section-title-imm">¿Tu web actual parece un <em class="accent-teal">folleto viejo?</em></h2>
      </div>
      
      <div class="pillars-list-imm">
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Oscuridad Local</h3>
            <p>Si no apareces en Google Maps o búsquedas locales, tu clínica es invisible para tu vecino.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Fricción de Reserva</h3>
            <p>Mala UX que impide al paciente agendar una cita de forma rápida y sencilla.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Baja Autoridad</h3>
            <p>Falta de contenido técnico y testimonios que validen tu expertise profesional.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">La Solución</p>
         <h2 class="section-title-imm">Framework <em>Health Growth.</em></h2>
      </div>
      
      <div class="services-imm-grid">
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 1</span>
            <h3>Diseño UX/UI Médico</h3>
            <p>Webs rápidas y confiables enfocadas en el profesionalismo.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 2</span>
            <h3>SEO Local</h3>
            <p>Google Maps y búsquedas geolocalizadas para atraer pacientes.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 3</span>
            <h3>Contenido Experto</h3>
            <p>Posicionamiento de marca y autoridad a través de blog especializado.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Especialidades</p>
         <h2 class="section-title-imm">Resultados en <em>Sectores Críticos.</em></h2>
      </div>
      
      <div class="cases-scroll-imm">
         <div class="case-item-imm">
            <span class="case-cat-imm">ODONTOLOGÍA</span>
            <h3>Leads Directos</h3>
            <p>Optimización de funnel para captar pacientes de implantes y estética.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">CLÍNICAS</span>
            <h3>SEO Corporativo</h3>
            <p>Estructura escalable para centros con múltiples especialidades.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">MÉDICOS</span>
            <h3>Marca Autoridad</h3>
            <p>Posicionamiento de la consulta privada sobre agregadores externos.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-4" style="background: var(--surface);">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Servicios</p>
         <h2 class="section-title-imm">Estrategias <em>Dedicadas.</em></h2>
      </div>
      <div class="services-list-imm">
         <div class="service-row-imm"><span>01</span><h3>SEO Local Health</h3></div>
         <div class="service-row-imm"><span>02</span><h3>UX/UI Médica</h3></div>
         <div class="service-row-imm"><span>03</span><h3>Conversión Clínicas</h3></div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-5">
    <div class="content-wrap-imm form-layout-imm">
       <div class="form-info-imm">
          <p class="scene-label-imm">Diagnóstico</p>
          <h2 class="section-title-imm">Quiero digitalizar mi consulta y <em class="accent-teal">atraer más pacientes.</em></h2>
          <p class="hero-sub-imm">Agenda tu auditoría gratuita y descubre cómo podemos ayudarte.</p>
       </div>
       <div class="form-box-imm">
          <form class="health-audit-form-imm">
             <div class="form-grid-imm">
                <input type="text" placeholder="NOMBRE" required />
                <input type="text" placeholder="ESPECIALIDAD" required />
             </div>
             <input type="email" placeholder="EMAIL PROFESIONAL" required />
             <textarea placeholder="RETOS ACTUALES..." required style="min-height: 100px;"></textarea>
             <button class="btn-pkg-imm" type="submit">Quiero mi auditoría ahora</button>
          </form>
          <p class="audit-success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.85rem; font-weight: 800;">Recibido. Contactaremos con tu clínica pronto.</p>
       </div>
    </div>
  </section>

  <section class="scene" id="scene-6-proof" style="background: var(--surface);">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Prueba Social</p>
         <h2 class="section-title-imm">Confianza avalada por el <em class="accent-teal">sector.</em></h2>
      </div>
      <div class="carousel-container-imm">
        <div class="carousel-track-imm" id="testimonial-track-imm">
          <div class="carousel-slide-imm active">
            <p>“Profesionales que entienden las necesidades de los especialistas.”</p>
            <strong>Dr. Alejandro Ruiz</strong>
          </div>
          <div class="carousel-slide-imm">
            <p>“Mi clínica duplicó las citas con el nuevo enfoque SEO local.”</p>
            <strong>Dra. Elena Martínez</strong>
          </div>
        </div>
        <div class="carousel-nav-imm">
          <button class="dot-imm active"></button>
          <button class="dot-imm"></button>
        </div>
      </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    width: 100%;
  }

  .scene-label-imm {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--teal);
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .hero-flex-imm {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hero-copy-imm {
    max-width: 650px;
  }

  .hero-title-imm {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 32px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .section-title-imm {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 48px;
    font-family: var(--title);
    letter-spacing: -0.01em;
  }

  .hero-sub-imm {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--smoke);
    max-width: 480px;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .btn-pkg-imm {
    background: var(--teal);
    color: #fff;
    padding: 12px 28px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
  }

  .btn-pkg-imm:hover {
    background: #fff;
    color: #000;
    transform: translateY(-2px);
  }

  .hero-metric-box {
    background: var(--surface);
    border: 1px solid var(--rim);
    padding: 60px;
    max-width: 450px;
  }

  .hero-image-box-imm {
    width: 100%;
    max-width: 500px;
    border-radius: 20px;
    border: 1px solid var(--rim);
    overflow: hidden;
    box-shadow: 0 0 40px rgba(115, 96, 248, 0.2);
    transition: 0.5s;
  }

  .hero-image-box-imm:hover {
    transform: scale(1.02);
    box-shadow: 0 0 60px rgba(115, 96, 248, 0.4);
  }

  .hero-img-imm {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  /* Carousel */
  .carousel-container-imm {
    margin-top: 40px;
    overflow: hidden;
    padding-bottom: 40px;
  }
  .carousel-track-imm {
    display: flex;
    transition: 0.5s;
  }
  .carousel-slide-imm {
    min-width: 100%;
    padding: 40px;
    text-align: center;
    opacity: 0.3;
    transition: 0.5s;
    background: rgba(255,255,255,0.02);
  }
  .carousel-slide-imm.active { opacity: 1; border: 1px solid var(--teal); }
  .carousel-slide-imm p { font-size: 1.5rem; font-style: italic; margin-bottom: 16px; font-family: var(--title); }
  .carousel-nav-imm { display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
  .dot-imm { width: 8px; height: 8px; border-radius: 50%; background: var(--rim); border: none; cursor: pointer; }
  .dot-imm.active { background: var(--teal); width: 20px; border-radius: 10px; }

  .hero-quote-imm {
     font-size: 1.8rem;
     line-height: 1.4;
     color: var(--white);
     font-family: var(--title);
     font-style: italic;
  }

  .pillars-list-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .pillar-box-imm {
     border-top: 1px solid var(--rim);
     padding-top: 32px;
  }

  .pillar-idx-imm {
     font-family: var(--body);
     font-size: 0.65rem;
     color: var(--teal);
     display: block;
     margin-bottom: 16px;
     font-weight: 600;
     letter-spacing: 0.1em;
  }

  .pillar-box-imm h3 {
     font-size: 2rem;
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .pillar-box-imm p {
     font-size: 0.8rem;
     color: var(--smoke);
     line-height: 1.7;
  }

  .services-imm-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .serv-card-imm {
     background: var(--surface);
     padding: 40px;
     border: 1px solid var(--rim);
     transition: 0.3s;
  }

  .serv-card-imm:hover {
    border-color: var(--teal);
  }

  .serv-card-imm h3 {
     color: var(--white);
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
     font-size: 1.8rem;
  }

  .serv-card-imm p {
     color: var(--smoke);
     font-size: 0.8rem;
     line-height: 1.7;
  }

  .cases-scroll-imm {
     display: flex;
     gap: 32px;
     margin-top: 40px;
  }

  .case-item-imm {
     flex: 1;
     border: 1px solid var(--rim);
     padding: 40px;
     background: var(--surface);
  }

  .case-cat-imm {
     font-size: 0.75rem;
     color: var(--teal);
     letter-spacing: 0.15em;
     display: block;
     margin-bottom: 16px;
     font-weight: 800;
  }

  .case-item-imm h3 {
    font-size: 2rem;
    font-family: var(--title);
    margin-bottom: 12px;
  }

  .services-list-imm {
    width: 100%;
    margin-top: 40px;
  }

  .service-row-imm {
     display: flex;
     align-items: center;
     gap: 48px;
     padding: 32px 0;
     border-bottom: 1px solid var(--rim);
     transition: 0.3s;
  }

  .service-row-imm span {
    color: var(--teal);
    font-weight: 600;
    font-family: var(--body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }

  .service-row-imm h3 {
     font-size: 3rem;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .form-layout-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 100px;
     align-items: center;
  }

  .form-grid-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 16px;
  }

  .form-box-imm form {
     display: flex;
     flex-direction: column;
     gap: 16px;
  }

  input, textarea {
     background: var(--void);
     border: 1px solid var(--rim);
     padding: 18px;
     color: var(--white);
     font-family: var(--body);
  }

  @media (max-width: 1024px) {
    .content-wrap-imm { padding: 0 24px; }
    .hero-flex-imm, .pillars-list-imm, .services-imm-grid, .cases-scroll-imm, .form-layout-imm, .service-row-imm h3 {
      grid-template-columns: 1fr;
      flex-direction: column;
      font-size: 2rem;
    }
    .hero-metric-box { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const healthForm = document.querySelector('.health-audit-form-imm');
    if (healthForm) {
      healthForm.addEventListener('submit', (e) => {
        e.preventDefault();
        healthForm.reset();
        const success = document.querySelector('.audit-success-imm');
        if (success) success.style.display = 'block';
      });
    }

    // Carousel
    const track = document.getElementById('testimonial-track-imm');
    const slides = Array.from(track ? track.children : []);
    const dots = Array.from(document.querySelectorAll('.dot-imm'));
    let curIdx = 0;

    function upd(i) {
      if(!track) return;
      track.style.transform = `translateX(-${i*100}%)`;
      slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
      dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
      curIdx = i;
    }
    dots.forEach((d, i) => d.addEventListener('click', () => upd(i)));
    if(slides.length > 0) setInterval(() => upd((curIdx+1)%slides.length), 5000);
  });
</script>
