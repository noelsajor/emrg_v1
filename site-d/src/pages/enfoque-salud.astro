---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout title="Enfoque en Salud | EMRG" description="SEO y crecimiento digital especializado en salud. Ayudamos a clínicas y médicos a atraer más pacientes.">
  
  <section class="scene active" id="scene-0">
    <div class="content-wrap-imm">
      <div class="hero-flex-imm">
        <div class="hero-copy-imm">
          <p class="scene-label-imm">Especialización en Salud & Performance</p>
          <h1 class="hero-title-imm">Más pacientes. <br/><span class="accent-teal">Más impacto.</span></h1>
          <p class="hero-sub-imm">SEO médico y crecimiento digital diseñado para clínicas que buscan liderar su mercado local con autoridad.</p>
          <div class="hero-actions-imm">
            <a href="#scene-5" class="btn-pkg-imm" onclick="window.goToScene(5); return false;">Solicitar Auditoría</a>
          </div>
        </div>
        
        <div class="hero-metric-box">
           <div class="hero-quote-imm">
              <p>“El sector salud no necesita más tráfico, necesita más confianza cualificada.”</p>
           </div>
        </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-1">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
        <p class="scene-label-imm">El Problema</p>
        <h2 class="section-title-imm">Muchos centros tienen webs, pero no un <em>sistema de captación.</em></h2>
      </div>
      
      <div class="pillars-list-imm">
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">01</span>
            <h3>Oscuridad Local</h3>
            <p>Si no apareces en Google Maps o búsquedas locales, tu clínica es invisible para tu vecino.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">02</span>
            <h3>Fricción de Reserva</h3>
            <p>Mala UX que impide al paciente agendar una cita de forma rápida y sencilla.</p>
         </div>
         <div class="pillar-box-imm">
            <span class="pillar-idx-imm">03</span>
            <h3>Baja Autoridad</h3>
            <p>Falta de contenido técnico y testimonios que validen tu expertise profesional.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-2">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Metodología</p>
         <h2 class="section-title-imm">Framework <em>Health Growth.</em></h2>
      </div>
      
      <div class="services-imm-grid">
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 1</span>
            <h3>SEO Médico</h3>
            <p>Posicionamiento de especialidades y keywords de alta intención de consulta.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 2</span>
            <h3>Autoridad Web</h3>
            <p>Diseño enfocado en CRO para convertir visitas en pacientes reales.</p>
         </div>
         <div class="serv-card-imm">
            <span class="pillar-idx-imm">FASE 3</span>
            <h3>Escalado Local</h3>
            <p>Domina tu zona geográfica con estrategias de visibilidad 360.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-3">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Especialidades</p>
         <h2 class="section-title-imm">Resultados en <em>Sectores Críticos.</em></h2>
      </div>
      
      <div class="cases-scroll-imm">
         <div class="case-item-imm">
            <span class="case-cat-imm">ODONTOLOGÍA</span>
            <h3>Leads Directos</h3>
            <p>Optimización de funnel para captar pacientes de implantes y estética.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">CLÍNICAS</span>
            <h3>SEO Corporativo</h3>
            <p>Estructura escalable para centros con múltiples especialidades.</p>
         </div>
         <div class="case-item-imm">
            <span class="case-cat-imm">MÉDICOS</span>
            <h3>Marca Autoridad</h3>
            <p>Posicionamiento de la consulta privada sobre agregadores externos.</p>
         </div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-4" style="background: var(--surface);">
    <div class="content-wrap-imm">
      <div class="scene-header-imm">
         <p class="scene-label-imm">Servicios</p>
         <h2 class="section-title-imm">Estrategias <em>Dedicadas.</em></h2>
      </div>
      <div class="services-list-imm">
         <div class="service-row-imm"><span>01</span><h3>SEO Local Health</h3></div>
         <div class="service-row-imm"><span>02</span><h3>UX/UI Médica</h3></div>
         <div class="service-row-imm"><span>03</span><h3>Conversión Clínicas</h3></div>
      </div>
    </div>
  </section>

  <section class="scene" id="scene-5">
    <div class="content-wrap-imm form-layout-imm">
       <div class="form-info-imm">
          <p class="scene-label-imm">Diagnóstico</p>
          <h2 class="section-title-imm">Agenda tu Auditoría.</h2>
          <p class="hero-sub-imm">Detectamos puntos críticos en tu presencia digital para empezar a atraer pacientes cualificados.</p>
       </div>
       <div class="form-box-imm">
          <form class="health-audit-form-imm">
             <div class="form-grid-imm">
                <input type="text" placeholder="NOMBRE" required />
                <input type="text" placeholder="ESPECIALIDAD" required />
             </div>
             <input type="email" placeholder="EMAIL PROFESIONAL" required />
             <textarea placeholder="RETOS ACTUALES..." required style="min-height: 100px;"></textarea>
             <button class="btn-pkg-imm" type="submit">SOLICITAR ANÁLISIS</button>
          </form>
          <p class="audit-success-imm" style="display:none; color: var(--teal); margin-top: 1rem; font-size:0.85rem; font-weight: 800;">Recibido. Contactaremos con tu clínica pronto.</p>
       </div>
    </div>
  </section>

  <Contact />

</BaseLayout>

<style>
  .content-wrap-imm {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
    width: 100%;
  }

  .scene-label-imm {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--teal);
    margin-bottom: 24px;
    display: block;
    font-weight: 800;
  }

  .accent-teal {
    color: var(--teal);
    text-shadow: 0 0 20px var(--teal-dim);
  }

  .hero-flex-imm {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hero-copy-imm {
    max-width: 650px;
  }

  .hero-title-imm {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.9;
    margin-bottom: 32px;
    font-family: var(--title);
    text-transform: uppercase;
  }

  .section-title-imm {
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 40px;
    font-family: var(--title);
    text-transform: uppercase;
  }

  .hero-sub-imm {
    font-size: 1.15rem;
    color: var(--smoke);
    max-width: 500px;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .btn-pkg-imm {
    background: var(--teal);
    color: #000;
    padding: 18px 36px;
    font-weight: 900;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    transition: 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--body);
    text-transform: uppercase;
    display: inline-block;
  }

  .btn-pkg-imm:hover {
    background: #fff;
    transform: translateY(-2px);
  }

  .hero-metric-box {
    background: var(--surface);
    border: 1px solid var(--rim);
    padding: 60px;
    max-width: 450px;
  }

  .hero-quote-imm {
     font-size: 1.8rem;
     line-height: 1.4;
     color: var(--white);
     font-family: var(--title);
     font-style: italic;
  }

  .pillars-list-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .pillar-box-imm {
     border-top: 1px solid var(--rim);
     padding-top: 32px;
  }

  .pillar-idx-imm {
     font-family: monospace;
     font-size: 0.85rem;
     color: var(--teal);
     display: block;
     margin-bottom: 24px;
     font-weight: 800;
  }

  .pillar-box-imm h3 {
     font-size: 2rem;
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .pillar-box-imm p {
     font-size: 0.95rem;
     color: var(--smoke);
     line-height: 1.6;
  }

  .services-imm-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 32px;
     margin-top: 40px;
  }

  .serv-card-imm {
     background: var(--surface);
     padding: 40px;
     border: 1px solid var(--rim);
     transition: 0.3s;
  }

  .serv-card-imm:hover {
    border-color: var(--teal);
  }

  .serv-card-imm h3 {
     color: var(--white);
     margin-bottom: 16px;
     font-family: var(--title);
     text-transform: uppercase;
     font-size: 1.8rem;
  }

  .serv-card-imm p {
     color: var(--smoke);
     font-size: 0.95rem;
     line-height: 1.6;
  }

  .cases-scroll-imm {
     display: flex;
     gap: 32px;
     margin-top: 40px;
  }

  .case-item-imm {
     flex: 1;
     border: 1px solid var(--rim);
     padding: 40px;
     background: var(--surface);
  }

  .case-cat-imm {
     font-size: 0.75rem;
     color: var(--teal);
     letter-spacing: 0.15em;
     display: block;
     margin-bottom: 16px;
     font-weight: 800;
  }

  .case-item-imm h3 {
    font-size: 2rem;
    font-family: var(--title);
    margin-bottom: 12px;
  }

  .services-list-imm {
    width: 100%;
    margin-top: 40px;
  }

  .service-row-imm {
     display: flex;
     align-items: center;
     gap: 48px;
     padding: 32px 0;
     border-bottom: 1px solid var(--rim);
     transition: 0.3s;
  }

  .service-row-imm span {
    color: var(--teal);
    font-weight: 800;
    font-family: monospace;
  }

  .service-row-imm h3 {
     font-size: 3rem;
     font-family: var(--title);
     text-transform: uppercase;
  }

  .form-layout-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 100px;
     align-items: center;
  }

  .form-grid-imm {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 16px;
  }

  .form-box-imm form {
     display: flex;
     flex-direction: column;
     gap: 16px;
  }

  input, textarea {
     background: var(--void);
     border: 1px solid var(--rim);
     padding: 18px;
     color: var(--white);
     font-family: var(--body);
  }

  @media (max-width: 1024px) {
    .content-wrap-imm { padding: 0 24px; }
    .hero-flex-imm, .pillars-list-imm, .services-imm-grid, .cases-scroll-imm, .form-layout-imm, .service-row-imm h3 {
      grid-template-columns: 1fr;
      flex-direction: column;
      font-size: 2rem;
    }
    .hero-metric-box { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const healthForm = document.querySelector('.health-audit-form-imm');
    if (healthForm) {
      healthForm.addEventListener('submit', (e) => {
        e.preventDefault();
        healthForm.reset();
        const success = document.querySelector('.audit-success-imm');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
