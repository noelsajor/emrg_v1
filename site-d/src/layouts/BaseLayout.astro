---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "EMRG — Ecommerce Performance Studio",
  description = "EMRG — Founder-led ecommerce performance studio. We design the brand, build the store, and engineer the growth system.",
  image = "/og-image.jpg"
} = Astro.props;
