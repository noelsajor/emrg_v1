<section id="trust" aria-label="Key Performance Indicators">
  <div class="trust-row sr">
    <div class="trust-cell">
      <div class="trust-fig">12<span>+</span></div>
      <div class="trust-desc" data-i18n="trust.1">Years of DTC experience</div>
    </div>
    <div class="trust-cell">
      <div class="trust-fig">1.2<span>M</span></div>
      <div class="trust-desc" data-i18n="trust.2">Lines of code shipped</div>
    </div>
    <div class="trust-cell">
      <div class="trust-fig">8k<span>+</span></div>
      <div class="trust-desc" data-i18n="trust.3">A/B tests deployed</div>
    </div>
    <div class="trust-cell">
      <div class="trust-fig">0<span>%</span></div>
      <div class="trust-desc" data-i18n="trust.4">Outsourced talent</div>
    </div>
  </div>
  <div class="trust-disclaimer-bar">
    <div class="wrap" style="padding:0">
      <span data-i18n="trust.bar">Verified performance data since 2012</span>
    </div>
  </div>
</section>
