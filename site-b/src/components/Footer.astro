<footer role="contentinfo">
  <div class="footer-wrap">
    <div class="footer-top">
      <div class="footer-col">
        <a href="#hero" class="footer-logo">EMRG<em>.</em></a>
        <p class="footer-tag" data-i18n="footer.tag">Engineering high-performance commerce engines for founder-led brands.</p>
        <a href="mailto:hello@emrg.studio" class="footer-mail">hello@emrg.studio</a>
      </div>

      <div class="footer-col">
        <div class="footer-col-label" data-i18n="footer.l1">Navigation</div>
        <div class="footer-nav">
          <a href="#pillars" data-i18n="nav.services">Services</a>
          <a href="#work" data-i18n="nav.work">Work</a>
          <a href="#process" data-i18n="nav.process">Process</a>
          <a href="#packages" data-i18n="nav.pricing">Pricing</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-label" data-i18n="footer.l2">Resources</div>
        <div class="footer-nav">
            <!-- Blog link pointed to the new blog route -->
          <a href="/blog">Blog</a>
          <a href="#faq" data-i18n="nav.faq">FAQ</a>
          <a href="https://emrg.sh" target="_blank">emrg.sh</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-label" data-i18n="footer.l3">Connect</div>
        <div class="footer-socials">
          <a href="#" class="footer-social-link">LinkedIn</a>
          <a href="#" class="footer-social-link">Twitter / X</a>
          <a href="#" class="footer-social-link">Instagram</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">
        &copy; {new Date().getFullYear()} EMRG Performance Studio. <span data-i18n="footer.rights">All rights reserved.</span>
      </div>
      <div class="footer-legal">
        <a href="#" data-i18n="footer.privacy">Privacy Policy</a>
        <a href="#" data-i18n="footer.terms">Terms of Service</a>
      </div>
    </div>
  </div>
