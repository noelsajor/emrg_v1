---
---
<section id="pillars" aria-labelledby="pillars-h">
  <div class="pillars-header sr">
    <div class="section-rule">
      <div class="section-rule-label" data-i18n="pillars.rule">Our Pillars</div>
      <div class="section-rule-line"></div>
      <div class="section-rule-num">01 — 03</div>
    </div>
    <h2 class="display" id="pillars-h" data-i18n-html="pillars.title">A holistic approach to <em>scaling</em>.</h2>
    <p class="pillars-sub" data-i18n="pillars.desc">We don't just build websites; we build commerce ecosystems that convert visitors into lifelong customers.</p>
  </div>

  <div class="pillars-grid sr sr-d1">
    <div class="pillar-col">
      <div class="pillar-index">01</div>
      <h3 class="pillar-name" data-i18n="pillars.p1.title">Brand Identity</h3>
      <p class="pillar-tagline" data-i18n="pillars.p1.desc">We find the soul of your brand and translate it into a visual system that commands attention.</p>
      <div class="pillar-items">
        {['Logo & Visual ID', 'Voice & Tone', 'Style Guides', 'Packaging Design'].map(item => (
          <div class="pillar-item">
            <span>{item}</span>
            <span class="pillar-arrow">→</span>
          </div>
        ))}
      </div>
      <a href="#cta" class="btn-text" data-i18n="pillars.p1.cta">Learn More</a>
    </div>

    <div class="pillar-col">
      <div class="pillar-index">02</div>
      <h3 class="pillar-name" data-i18n="pillars.p2.title">Storefront Engineering</h3>
      <p class="pillar-tagline" data-i18n="pillars.p2.desc">Performance is a feature. We build lightning-fast storefronts that feel like native apps.</p>
      <div class="pillar-items">
        {['Shopify Development', 'Custom Apps', 'POS Integration', 'Performance Audit'].map(item => (
          <div class="pillar-item">
            <span>{item}</span>
            <span class="pillar-arrow">→</span>
          </div>
        ))}
      </div>
      <a href="#cta" class="btn-text" data-i18n="pillars.p2.cta">View Tech</a>
    </div>

    <div class="pillar-col">
      <div class="pillar-index">03</div>
      <h3 class="pillar-name" data-i18n="pillars.p3.title">Growth Systems</h3>
      <p class="pillar-tagline" data-i18n="pillars.p3.desc">Engineering the infrastructure needed to scale revenue without scaling complexity.</p>
      <div class="pillar-items">
        {['Conversion Design', 'Retention Cycles', 'Data Pipelines', 'A/B Testing'].map(item => (
          <div class="pillar-item">
            <span>{item}</span>
            <span class="pillar-arrow">→</span>
          </div>
        ))}
      </div>
      <a href="#cta" class="btn-text" data-i18n="pillars.p3.cta">Get Started</a>
    </div>
  </div>
</section>
