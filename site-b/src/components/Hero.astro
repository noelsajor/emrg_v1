---
---
<section id="hero" aria-labelledby="hero-h1">
  <div class="hero-main">
    <div class="hero-left sr">
      <div>
        <div class="hero-eyebrow" data-i18n="hero.eyebrow">Ecommerce Performance Studio</div>
        <h1 id="hero-h1" data-i18n-html="hero.title">We build <em>profitable</em> commerce engines.</h1>
        <div class="hero-cta-group">
          <a href="#cta" class="btn-ink">
            <span data-i18n="hero.cta.primary">Start Your Project</span>
            <span class="arrow">→</span>
          </a>
          <a href="#work" class="btn-bare">
            <span data-i18n="hero.cta.secondary">View Case Studies</span>
          </a>
        </div>
      </div>
    </div>
    
    <div class="hero-right sr sr-d1">
      <div class="hero-deco">01</div>
      <div class="hero-stat-block">
        <div class="hero-stat-eyebrow" data-i18n="hero.stat.label">Average Revenue Growth</div>
        <div class="hero-stat-num">142%</div>
        <div class="hero-stat-sub" data-i18n="hero.stat.sub">First 12 months</div>
      </div>
    </div>
  </div>

  <div class="hero-chips-row sr sr-d2">
    <div class="hero-chip">
      <span data-i18n="hero.chip.1">Founder Led</span>
    </div>
    <div class="hero-chip">
      <span data-i18n="hero.chip.2">Performance Driven</span>
    </div>
    <div class="hero-chip">
      <span data-i18n="hero.chip.3">Shopify Plus Experts</span>
    </div>
  </div>
</section>
