---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Enfoque Marca Personal | EMRG" description="Estrategia digital 360 para consultores, expertos y profesionales que quieren construir autoridad y atraer mejores clientes.">
  <Nav />
  
  <main class="editorial-page">
    <section class="hero-editorial wrap">
      <div class="hero-content">
        <div class="section-rule">
          <span class="rule-lbl">Autoridad Digital</span>
          <div class="rule-line"></div>
          <span class="rule-num">§05</span>
        </div>
        <h1 class="serif">Experiencia <br/><em>Convertida.</em></h1>
        <p class="hero-sub mono">Estrategia 360 para consultores y expertos que buscan liderar su categoría a través de una presencia digital coherente.</p>
        
        <div class="hero-actions">
           <a href="#contacto" class="btn btn-primary">Solicitar Auditoría</a>
           <a href="#framework" class="btn btn-rim">El Framework</a>
        </div>
      </div>
      
      <div class="hero-image-box">
         <div class="hero-quote-box">
            <p class="serif">“Tu marca personal no necesita más ruido. Necesita una estructura que convierta expertise en confianza.”</p>
         </div>
      </div>
    </section>

    <div class="strip-editorial wrap">
       <div class="strip-inner mono">
          <span>MENSAJE COMERCIAL</span> — <span>VISIBILIDAD SEO</span> — <span>AUTORIDAD</span> — <span>CONFIANZA</span> — <span>ESCALA</span>
       </div>
    </div>

    <section class="section problem-editorial wrap">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">Tener experiencia no garantiza <em>ser elegido.</em></h2>
          </div>
          <div class="split-right">
             <p class="mono">Muchos profesionales valiosos siguen siendo invisibles digitalmente porque su comunicación carece de diferenciación y dependen de recomendaciones esporádicas.</p>
             
             <div class="problem-list">
                <div class="prob-item">
                   <span class="mono">01</span>
                   <p>Mensaje genérico que no filtra al cliente ideal.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">02</span>
                   <p>Activos digitales que no validan la trayectoria.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">03</span>
                   <p>Falta de un sistema recurrente de captación.</p>
                </div>
             </div>
          </div>
       </div>
    </section>

    <section class="section authority-editorial wrap" id="framework">
       <div class="section-rule">
          <span class="rule-lbl">Nuestro Proceso</span>
          <div class="rule-line"></div>
          <span class="rule-num">360°</span>
       </div>
       <h2 class="serif">Un framework diseñado para <em>expertos reales.</em></h2>
       
       <div class="bento-grid">
          <div class="bento-card card-dark">
             <span class="mono">FASE 1</span>
             <h3 class="serif">Diagnóstico</h3>
             <p>Auditoría de activos, puntos de fuga y posicionamiento actual en el mercado.</p>
          </div>
          <div class="bento-card">
             <span class="mono">FASE 2</span>
             <h3 class="serif">Claridad</h3>
             <p>Definición de mensaje comercial, categoría y especialización de nicho.</p>
          </div>
          <div class="bento-card">
             <span class="mono">FASE 3</span>
             <h3 class="serif">Autoridad</h3>
             <p>Web estratégica, SEO personal y activos de validación de alto impacto.</p>
          </div>
       </div>
    </section>

    <section class="section services-editorial wrap" id="servicios">
       <h2 class="serif">Nuestros <em>Servicios.</em></h2>
       <div class="services-stack">
          <div class="service-row">
             <span class="serif">01</span>
             <h3 class="serif">SEO para Marca Personal</h3>
             <p>Posicionamos tu nombre y servicios.</p>
          </div>
          <div class="service-row">
             <span class="serif">02</span>
             <h3 class="serif">Marketing para Consultores</h3>
             <p>Alineamos mensaje y propuesta comercial.</p>
          </div>
          <div class="service-row">
             <span class="serif">03</span>
             <h3 class="serif">Web Estratégica</h3>
             <p>Diseño enfocado en autoridad y conversión.</p>
          </div>
       </div>
    </section>

    <section class="section contact-editorial wrap" id="contacto">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">Solicita tu <em>Auditoría Estratégica.</em></h2>
             <p class="mono">Review de posicionamiento, activos y principales oportunidades de crecimiento.</p>
          </div>
          <div class="split-right">
             <form class="main-legal-form personal-audit-form">
                <div class="form-grid">
                   <input type="text" placeholder="Nombre completo" required />
                   <input type="text" placeholder="Especialidad" required />
                   <input type="text" placeholder="Marca / Proyecto" required />
                   <select required>
                      <option value="">Objetivo</option>
                      <option>Visibilidad</option>
                      <option>Autoridad</option>
                      <option>Leads</option>
                   </select>
                </div>
                <div class="form-grid">
                   <input type="email" placeholder="Email" required />
                   <input type="tel" placeholder="WhatsApp" required />
                </div>
                <button class="btn btn-primary btn-block">Solicitar Auditoría</button>
                <p class="success-txt" style="display:none; margin-top: 1rem; color: var(--accent); font-weight: 600;">Recibido. Contactaremos pronto.</p>
             </form>
          </div>
       </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .editorial-page {
    background: var(--paper);
    color: var(--ink);
  }

  .serif {
    font-family: var(--font-serif);
  }

  .mono {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .rule-lbl {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .rule-line {
    flex-grow: 1;
    height: 1px;
    background: var(--border);
  }

  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
  }

  .hero-editorial {
    padding: 160px 0 100px;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 100px;
    align-items: center;
  }

  .hero-editorial h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: .85;
    margin-bottom: 40px;
    letter-spacing: -0.04em;
  }

  .hero-editorial h1 em {
    color: var(--accent);
  }

  .hero-sub {
    max-width: 450px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
  }

  .hero-image-box {
    background: var(--paper-2);
    border: 1px solid var(--border-strong);
    padding: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-quote-box {
     text-align: center;
     font-size: 1.5rem;
     line-height: 1.4;
     color: var(--ink);
     font-style: italic;
  }

  .strip-editorial {
    padding: 24px 0;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border-strong);
  }

  .strip-inner {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
  }

  .grid-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 100px;
  }

  .split-left h2 {
    font-size: 3rem;
    line-height: 1.1;
  }

  .split-right p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 48px;
    text-transform: none;
    letter-spacing: normal;
  }

  .problem-list {
    display: grid;
    gap: 24px;
  }

  .prob-item {
    display: flex;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }

  .prob-item p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  .bento-card {
    background: var(--paper-2);
    padding: 48px;
    border: 1px solid var(--border);
  }

  .card-dark {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .bento-card h3 {
    font-size: 1.8rem;
    margin-bottom: 24px;
    margin-top: 16px;
  }

  .services-stack {
    margin-top: 60px;
    border-top: 1px solid var(--border-strong);
  }

  .service-row {
    display: grid;
    grid-template-columns: 80px 1fr 300px;
    align-items: center;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-strong);
  }

  .service-row span {
    font-size: 1.2rem;
    color: var(--accent);
  }

  .service-row h3 {
    font-size: 2rem;
  }

  .service-row p {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
  }

  .main-legal-form {
    display: grid;
    gap: 24px;
  }

  .main-legal-form .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .main-legal-form input, 
  .main-legal-form select {
    background: var(--paper-2);
    border: 1px solid var(--border);
    padding: 16px;
    font-family: var(--font-mono);
  }

  .btn {
    padding: 16px 32px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    transition: var(--t);
    display: inline-block;
  }

  .btn-primary {
    background: var(--ink);
    color: var(--paper);
  }

  .btn-rim {
    border: 1px solid var(--border-strong);
    color: var(--ink);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .hero-editorial, .grid-split, .bento-grid, .service-row, .main-legal-form .form-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-editorial h1 { font-size: 4rem; }
    .hero-image-box { order: -1; }
    .service-row p { text-align: left; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.querySelector('.personal-audit-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        mainForm.querySelector('.success-txt').style.display = 'block';
      });
    }
  });
</script>
