---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Enfoque Emprendedores y PYMES | EMRG" description="SEO, CRO y estrategia digital para ecommerce, retailers y mayoristas que quieren escalar facturación.">
  <Nav />
  
  <main class="editorial-page">
    <section class="hero-editorial wrap">
      <div class="hero-content">
        <div class="section-rule">
          <span class="rule-lbl">Estrategia Ecommerce</span>
          <div class="rule-line"></div>
          <span class="rule-num">§03</span>
        </div>
        <h1 class="serif">Máquina de <br/><em>Ventas.</em></h1>
        <p class="hero-sub mono">SEO, CRO y rendimiento digital para retailers y mayoristas que buscan dominar el canal online.</p>
        
        <div class="hero-actions">
           <a href="#contacto" class="btn btn-primary">Solicitar Auditoría</a>
           <a href="#resultados" class="btn btn-rim">Ver Resultados</a>
        </div>
      </div>
      
      <div class="hero-image-box">
         <div class="metric-wheel">
            <div class="mw-item">
               <span class="mw-val">+38%</span>
               <span class="mw-lbl">CONVERSIÓN</span>
            </div>
            <div class="mw-item">
               <span class="mw-val">+72%</span>
               <span class="mw-lbl">SEO TRAFFIC</span>
            </div>
         </div>
      </div>
    </section>

    <div class="strip-editorial wrap">
       <div class="strip-inner mono">
          <span>RETAIL GROWTH</span> — <span>ECM STRATEGY</span> — <span>CONVERSION OPT</span> — <span>MAYORISTAS B2B</span> — <span>SCALABILITY</span>
       </div>
    </div>

    <section class="section problem-editorial wrap">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">Muchas tiendas atraen tráfico, pero <em>pierden ventas.</em></h2>
          </div>
          <div class="split-right">
             <p class="mono">Un ecommerce puede tener buen catálogo, pero seguir dejando dinero sobre la mesa por errores en estructura, SEO técnico y fricción en la experiencia de compra.</p>
             
             <div class="problem-list">
                <div class="prob-item">
                   <span class="mono">01</span>
                   <p>Categorías sin posicionamiento orgánico real.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">02</span>
                   <p>Procesos de compra complejos que generan abandono.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">03</span>
                   <p>Falta de un sistema recurrente de crecimiento.</p>
                </div>
             </div>
          </div>
       </div>
    </section>

    <section class="section authority-editorial wrap" id="servicios">
       <div class="section-rule">
          <span class="rule-lbl">Nuestros Servicios</span>
          <div class="rule-line"></div>
          <span class="rule-num">ECM</span>
       </div>
       <h2 class="serif">Estrategia de <em>Alto Rendimiento.</em></h2>
       
       <div class="bento-grid">
          <div class="bento-card card-dark">
             <span class="mono">01</span>
             <h3 class="serif">SEO Ecommerce</h3>
             <p>Arquitectura técnica y keyword mapping enfocado en ventas por colecciones.</p>
          </div>
          <div class="bento-card">
             <span class="mono">02</span>
             <h3 class="serif">Optimización CRO</h3>
             <p>Refinamos los mensajes y la UX para elevar el ingreso por cada visita.</p>
          </div>
          <div class="bento-card">
             <span class="mono">03</span>
             <h3 class="serif">Roadmap Growth</h3>
             <p>Priorización de acciones basadas en el impacto directo en facturación.</p>
          </div>
       </div>
    </section>

    <section class="section results-editorial wrap" id="resultados">
       <h2 class="serif">El Impacto en <em>Cifras.</em></h2>
       <div class="services-stack">
          <div class="service-row">
             <span class="serif">01</span>
             <h3 class="serif">Retail Moda</h3>
             <p>+61% Tráfico Orgánico</p>
          </div>
          <div class="service-row">
             <span class="serif">02</span>
             <h3 class="serif">Mayorista Tech</h3>
             <p>+22% Facturación Digital</p>
          </div>
          <div class="service-row">
             <span class="serif">03</span>
             <h3 class="serif">Ecommerce Gen</h3>
             <p>+34% Conversión Funnel</p>
          </div>
       </div>
    </section>

    <section class="section contact-editorial wrap" id="contacto">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">Solicitar <em>Auditoría Ecommerce.</em></h2>
             <p class="mono">Detectamos fugas en tu funnel y oportunidades de escalado comercial.</p>
          </div>
          <div class="split-right">
             <form class="main-legal-form pymes-audit-form">
                <div class="form-grid">
                   <input type="text" placeholder="Nombre" required />
                   <input type="text" placeholder="Empresa" required />
                   <input type="text" placeholder="Plataforma" required />
                   <select required>
                      <option value="">Tipo de Negocio</option>
                      <option>Retail</option>
                      <option>Mayorista</option>
                   </select>
                </div>
                <div class="form-grid">
                   <input type="email" placeholder="Email" required />
                   <input type="tel" placeholder="WhatsApp" required />
                </div>
                <button class="btn btn-primary btn-block">Solicitar Auditoría</button>
                <p class="success-txt" style="display:none; margin-top: 1rem; color: var(--accent); font-weight: 600;">Auditoría solicitada con éxito.</p>
             </form>
          </div>
       </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .editorial-page {
    background: var(--paper);
    color: var(--ink);
  }

  .serif {
    font-family: var(--font-serif);
  }

  .mono {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .rule-lbl {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .rule-line {
    flex-grow: 1;
    height: 1px;
    background: var(--border);
  }

  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
  }

  .hero-editorial {
    padding: 160px 0 100px;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 100px;
    align-items: center;
  }

  .hero-editorial h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: .85;
    margin-bottom: 40px;
    letter-spacing: -0.04em;
  }

  .hero-editorial h1 em {
    color: var(--accent);
  }

  .hero-sub {
    max-width: 450px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
  }

  .hero-image-box {
    background: var(--paper-2);
    border: 1px solid var(--border-strong);
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .metric-wheel {
     display: grid;
     gap: 32px;
     text-align: center;
  }

  .mw-val {
     display: block;
     font-size: 2.5rem;
     font-family: var(--font-serif);
     color: var(--accent);
  }
  .mw-lbl {
     font-family: var(--font-mono);
     font-size: 0.65rem;
     color: var(--muted);
  }

  .strip-editorial {
    padding: 24px 0;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border-strong);
  }

  .strip-inner {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
  }

  .grid-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 100px;
  }

  .split-left h2 {
    font-size: 3rem;
    line-height: 1.1;
  }

  .split-right p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 48px;
    text-transform: none;
    letter-spacing: normal;
  }

  .problem-list {
    display: grid;
    gap: 24px;
  }

  .prob-item {
    display: flex;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }

  .prob-item p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  .bento-card {
    background: var(--paper-2);
    padding: 48px;
    border: 1px solid var(--border);
  }

  .card-dark {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .bento-card h3 {
    font-size: 1.8rem;
    margin-bottom: 24px;
    margin-top: 16px;
  }

  .services-stack {
    margin-top: 60px;
    border-top: 1px solid var(--border-strong);
  }

  .service-row {
    display: grid;
    grid-template-columns: 80px 1fr 300px;
    align-items: center;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-strong);
  }

  .service-row span {
    font-size: 1.2rem;
    color: var(--accent);
  }

  .service-row h3 {
    font-size: 2rem;
  }

  .service-row p {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
  }

  .main-legal-form {
    display: grid;
    gap: 24px;
  }

  .main-legal-form .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .main-legal-form input, 
  .main-legal-form select {
    background: var(--paper-2);
    border: 1px solid var(--border);
    padding: 16px;
    font-family: var(--font-mono);
  }

  .btn {
    padding: 16px 32px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    transition: var(--t);
    display: inline-block;
  }

  .btn-primary {
    background: var(--ink);
    color: var(--paper);
  }

  .btn-rim {
    border: 1px solid var(--border-strong);
    color: var(--ink);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .hero-editorial, .grid-split, .bento-grid, .service-row, .main-legal-form .form-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-editorial h1 { font-size: 4rem; }
    .hero-image-box { order: -1; }
    .service-row p { text-align: left; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.querySelector('.pymes-audit-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        mainForm.querySelector('.success-txt').style.display = 'block';
      });
    }
  });
</script>
