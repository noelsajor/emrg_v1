---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Enfoque Emprendedores y PYMES | EMRG" description="Diseño de sitios web desde cero y optimización estratégica para que tu marca despegue. Deja de ser invisible y lanza tu negocio al mundo digital.">
  <Nav />
  
  <main class="editorial-page">
    <section class="hero-editorial wrap">
      <div class="hero-content">
        <div class="section-rule">
          <span class="rule-lbl">Digital Growth</span>
          <div class="rule-line"></div>
          <span class="rule-num">§04</span>
        </div>
        <h1 class="serif">Deja de ser <br/><em>invisible.</em></h1>
        <p class="hero-sub mono">Es hora de que el mundo encuentre tu negocio. Diseño y optimización estratégica para que tu marca despegue.</p>
        
        <div class="hero-actions">
           <a href="#contacto" class="btn btn-primary">Lanzar mi negocio</a>
           <a href="#hook" class="btn btn-rim">El Dato</a>
        </div>
      </div>
      
      <div class="hero-image-box">
         <img src="/images/hero-pymes.png" alt="SME Growth" class="hero-img-editorial" />
      </div>
    </section>

    <div class="strip-editorial wrap">
       <div class="strip-inner mono">
          <span>SME SCALING</span> — <span>E-COMMERCE OPS</span> — <span>SEO NATIVE</span> — <span>CONTENT STRATEGY</span> — <span>TOTAL VISIBILITY</span>
       </div>
    </div>

    <section id="hook" class="section hook-editorial wrap">
       <div class="hook-card">
          <h2 class="serif">¿Sabías que el <em>80% de las personas</em> investigan en internet antes de comprar?</h2>
          <p class="mono">Si tu marca no está en ese radar, no existe para tu cliente ideal. Nosotros construimos ese puente digital.</p>
       </div>
    </section>

    <section class="section services-editorial wrap">
       <div class="section-rule">
          <span class="rule-lbl">Paquetes de Despegue</span>
          <div class="rule-line"></div>
          <span class="rule-num">PKG</span>
       </div>
       
       <div class="bento-grid">
          <div class="bento-card card-dark">
             <span class="mono">01</span>
             <h3 class="serif">E-commerce</h3>
             <p>Creación de tienda en línea fácil de usar y optimizada para convertir visitas en ventas reales.</p>
          </div>
          <div class="bento-card">
             <span class="mono">02</span>
             <h3 class="serif">SEO Nativo</h3>
             <p>Optimización desde el primer día para que tu sitio sea rastreable y relevante para Google.</p>
          </div>
          <div class="bento-card">
             <span class="mono">03</span>
             <h3 class="serif">Contenidos</h3>
             <p>Gestión integral de textos y narrativa. No te preocupes por qué escribir, nosotros lo hacemos por ti.</p>
          </div>
       </div>
    </section>

    <section class="section benefits-editorial wrap" style="background: var(--paper-2);">
       <h2 class="serif centered-text">Beneficios <em>Diferenciales.</em></h2>
       <div class="feature-grid-imm">
          <div class="feat-item">
             <span class="feat-idx">I</span>
             <h3 class="serif">Ventas 24/7</h3>
             <p>Alcance ininterrumpido a nuevos clientes en cualquier horario.</p>
          </div>
          <div class="feat-item">
             <span class="feat-idx">II</span>
             <h3 class="serif">Alcance Nacional</h3>
             <p>Escala tu mercado más allá de tu ubicación física actual.</p>
          </div>
          <div class="feat-item">
             <span class="feat-idx">III</span>
             <h3 class="serif">Profesionalismo</h3>
             <p>Valida tu propuesta con una imagen corporativa de primer nivel.</p>
          </div>
       </div>
    </section>

    <!-- Contact Section: Matching Site B CTA structure (Dark variant) -->
    <section id="contacto">
      <div class="cta-grid b-form-grid">
        <div class="cta-left sr">
          <div class="cta-eyebrow">Diagnóstico Digital</div>
          <h2 class="cta-title">¡Sí, quiero lanzar mi negocio al <em>mundo digital!</em></h2>
          <p class="cta-body-text">Completa el formulario y cuéntanos sobre tus metas. Diseñaremos tu hoja de ruta personalizada.</p>
        </div>
        <div class="cta-right sr sr-d1">
          <form class="pymes-contact-form-b" id="pymes-form">
            <div class="form-row-b">
              <input type="text" placeholder="NOMBRE COMPLETO" required />
            </div>
            <div class="form-row-b">
              <input type="text" placeholder="NOMBRE DE TU NEGOCIO" required />
            </div>
            <div class="form-row-b">
              <input type="email" placeholder="EMAIL" required />
            </div>
            <div class="form-row-b">
              <select required>
                <option value="">TU OBJETIVO HOY</option>
                <option>Crear mi primera web</option>
                <option>E-commerce / Tienda</option>
                <option>Rediseño / Optimización</option>
                <option>Ganar más clientes</option>
              </select>
            </div>
            <div class="form-row-b">
              <textarea placeholder="CUÉNTANOS BREVEMENTE SOBRE TU PROYECTO..." required style="width:100%; background: rgba(245, 240, 232, 0.05); border: 1px solid rgba(245, 240, 232, 0.15); padding: 18px; font-family: var(--font-mono); color: var(--paper); min-height: 120px;"></textarea>
            </div>
            <button class="btn-ink btn-full" type="submit">
              <span>Solicitar Auditoría Ahora</span>
              <span class="arrow">→</span>
            </button>
            <p class="form-success-b" style="display:none; margin-top:1rem; color:var(--accent); font-weight:500;">¡Recibido! Nos pondremos en contacto pronto.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .editorial-page {
    background: var(--paper);
    color: var(--ink);
  }

  .serif {
    font-family: var(--font-serif);
  }

  .mono {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  .centered-text {
    text-align: center;
    margin-bottom: 80px;
    font-size: 3.5rem;
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 48px;
  }

  .rule-lbl {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .rule-line {
    flex-grow: 1;
    height: 1px;
    background: var(--border);
  }

  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
  }

  .section {
    padding: 120px 0;
  }

  .hero-editorial {
    padding: 140px 0 120px;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
  }

  .hero-editorial h1 {
    font-size: clamp(3.5rem, 9vw, 6.5rem);
    line-height: .85;
    margin-bottom: 40px;
    letter-spacing: -0.04em;
  }

  .hero-editorial h1 em {
    color: var(--accent);
  }

  .hero-sub {
    max-width: 450px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .hero-image-box {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .hero-img-editorial {
    width: 100%;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .strip-editorial {
    padding: 24px 0;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border-strong);
  }

  .strip-inner {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
  }

  .hook-editorial {
     padding: 120px 0;
     text-align: center;
  }

  .hook-card {
     max-width: 900px;
     margin: 0 auto;
     padding: 80px;
     border-bottom: 1px solid var(--border-strong);
  }

  .hook-card h2 {
     font-size: 3rem;
     line-height: 1.1;
     margin-bottom: 24px;
     letter-spacing: -0.02em;
  }

  .grid-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
  }

  .split-left h2 {
    font-size: 3rem;
    line-height: 1.1;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    margin-top: 80px;
  }

  .bento-card {
    background: var(--paper-2);
    padding: 56px 48px;
    border: 1px solid var(--border);
  }

  .card-dark {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .bento-card h3 {
    font-size: 1.8rem;
    margin-top: 16px;
    margin-bottom: 24px;
  }

  .feature-grid-imm {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 48px;
  }

  .feat-item {
     border-left: 1px solid var(--border-strong);
     padding-left: 48px;
  }

  .feat-idx {
     font-family: var(--font-mono);
     color: var(--accent);
     font-size: 0.65rem;
     display: block;
     margin-bottom: 16px;
  }

  .feat-item h3 {
    font-size: 2rem;
    margin-bottom: 16px;
  }

  .feat-item p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Form Styles (Site B Match) */
  #contacto {
    background: var(--ink);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: center;
  }

  .b-form-grid {
    border-top: 1px solid var(--border-strong);
    margin: 0 auto;
    max-width: var(--max);
    padding: 100px var(--pad);
  }

  .cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cta-eyebrow::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--muted);
  }

  .cta-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    color: var(--paper);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }

  .cta-title em {
    font-style: italic;
    color: var(--accent);
  }

  .cta-body-text {
    font-size: 1rem;
    color: var(--paper-3);
    max-width: 400px;
    line-height: 1.6;
  }

  .form-row-b {
    margin-bottom: 12px;
  }

  .pymes-contact-form-b input, 
  .pymes-contact-form-b select {
    width: 100%;
    padding: 18px;
    background: rgba(245, 240, 232, 0.05);
    border: 1px solid rgba(245, 240, 232, 0.15);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--paper);
    transition: all 0.3s;
  }

  .pymes-contact-form-b input:focus, 
  .pymes-contact-form-b select:focus,
  .pymes-contact-form-b textarea:focus {
    outline: none;
    background: rgba(245, 240, 232, 0.1);
    border-color: var(--accent);
  }

  .btn-full {
    width: 100%;
    margin-top: 24px;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .cta-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainForm = document.getElementById('pymes-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        const success = mainForm.querySelector('.form-success-b');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
