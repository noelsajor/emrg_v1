---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Enfoque Retail y Mayoristas | EMRG" description="Acompañamos a pequeños negocios en su salto digital. Tu primera web, visibilidad en Google y captación de clientes.">
  <Nav />
  
  <main class="editorial-page">
    <section class="hero-editorial wrap">
      <div class="hero-content">
        <div class="section-rule">
          <span class="rule-lbl">Digitalización Local</span>
          <div class="rule-line"></div>
          <span class="rule-num">§04</span>
        </div>
        <h1 class="serif">El Salto <br/><em>Digital.</em></h1>
        <p class="hero-sub mono">Tu primera web profesional y presencia en Google para pequeños negocios que buscan crecer de forma práctica.</p>
        
        <div class="hero-actions">
           <a href="#contacto" class="btn btn-primary">Solicitar Diagnóstico</a>
           <a href="#solucion" class="btn btn-rim">Ver Solución</a>
        </div>
      </div>
      
      <div class="hero-image-box">
         <div class="hero-quote-box">
            <p class="serif">“Si tu negocio no aparece en Google, no existe online.”</p>
         </div>
      </div>
    </section>

    <div class="strip-editorial wrap">
       <div class="strip-inner mono">
          <span>WEB PROFESIONAL</span> — <span>GOOGLE MAPS</span> — <span>LOCAL SEO</span> — <span>CONFIANZA DIGITAL</span> — <span>VISIBILIDAD</span>
       </div>
    </div>

    <section class="section problem-editorial wrap">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">El riesgo de ser <em>invisible</em> online.</h2>
          </div>
          <div class="split-right">
             <p class="mono">Muchos negocios pierden ventas por no tener una presencia digital mínima. Si el cliente no te encuentra en el mapa o no ve una web clara, terminará eligiendo a tu competencia.</p>
             
             <div class="problem-list">
                <div class="prob-item">
                   <span class="mono">01</span>
                   <p>No apareces cuando los clientes buscan en tu zona.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">02</span>
                   <p>Falta de profesionalismo y confianza al no tener web.</p>
                </div>
                <div class="prob-item">
                   <span class="mono">03</span>
                   <p>Dependencia total de recomendaciones esporádicas.</p>
                </div>
             </div>
          </div>
       </div>
    </section>

    <section class="section authority-editorial wrap" id="solucion">
       <div class="section-rule">
          <span class="rule-lbl">Estructura Práctica</span>
          <div class="rule-line"></div>
          <span class="rule-num">§§</span>
       </div>
       <h2 class="serif">Soluciones sin <em>Complicaciones.</em></h2>
       
       <div class="bento-grid">
          <div class="bento-card card-dark">
             <span class="mono">01</span>
             <h3 class="serif">Web Inicial</h3>
             <p>Presencia digital clara, rápida y optimizada para todos los dispositivos.</p>
          </div>
          <div class="bento-card">
             <span class="mono">02</span>
             <h3 class="serif">SEO Local</h3>
             <p>Configuración y optimización de Google Maps para que te encuentren primero.</p>
          </div>
          <div class="bento-card">
             <span class="mono">03</span>
             <h3 class="serif">Canal de Contacto</h3>
             <p>Integración de botones de WhatsApp y formularios para recibir consultas directas.</p>
          </div>
       </div>
    </section>

    <section class="section contact-editorial wrap" id="contacto">
       <div class="grid-split">
          <div class="split-left">
             <h2 class="serif">Solicitar <em>Diagnóstico Gratuito.</em></h2>
             <p class="mono">Evaluamos tu situación actual y te mostramos cómo dar el primer paso digital.</p>
          </div>
          <div class="split-right">
             <form class="main-legal-form retail-diagnosis-form">
                <div class="form-grid">
                   <input type="text" placeholder="Tu Nombre" required />
                   <input type="text" placeholder="Negocio" required />
                   <input type="text" placeholder="Rubro" required />
                   <input type="text" placeholder="Ciudad" required />
                </div>
                <div class="form-grid">
                   <input type="email" placeholder="Email" required />
                   <input type="tel" placeholder="WhatsApp" required />
                </div>
                <button class="btn btn-primary btn-block">Quiero mi Diagnóstico</button>
                <p class="success-txt" style="display:none; margin-top: 1rem; color: var(--accent); font-weight: 600;">Enviado. Te contactaremos pronto.</p>
             </form>
          </div>
       </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .editorial-page {
    background: var(--paper);
    color: var(--ink);
  }

  .serif {
    font-family: var(--font-serif);
  }

  .mono {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .rule-lbl {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .rule-line {
    flex-grow: 1;
    height: 1px;
    background: var(--border);
  }

  .rule-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
  }

  .hero-editorial {
    padding: 160px 0 100px;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 100px;
    align-items: center;
  }

  .hero-editorial h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: .85;
    margin-bottom: 40px;
    letter-spacing: -0.04em;
  }

  .hero-editorial h1 em {
    color: var(--accent);
  }

  .hero-sub {
    max-width: 450px;
    margin-bottom: 48px;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .hero-actions {
    display: flex;
    gap: 24px;
  }

  .hero-image-box {
    background: var(--paper-2);
    border: 1px solid var(--border-strong);
    padding: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-quote-box {
     text-align: center;
     font-size: 1.5rem;
     line-height: 1.4;
     color: var(--ink);
     font-style: italic;
  }

  .strip-editorial {
    padding: 24px 0;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border-strong);
  }

  .strip-inner {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
  }

  .grid-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 100px;
  }

  .split-left h2 {
    font-size: 3rem;
    line-height: 1.1;
  }

  .split-right p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 48px;
    text-transform: none;
    letter-spacing: normal;
  }

  .problem-list {
    display: grid;
    gap: 24px;
  }

  .prob-item {
    display: flex;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }

  .prob-item p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    text-transform: none;
    letter-spacing: normal;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  .bento-card {
    background: var(--paper-2);
    padding: 48px;
    border: 1px solid var(--border);
  }

  .card-dark {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .bento-card h3 {
    font-size: 1.8rem;
    margin-bottom: 24px;
    margin-top: 16px;
  }

  .main-legal-form {
    display: grid;
    gap: 24px;
  }

  .main-legal-form .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .main-legal-form input, 
  .main-legal-form select {
    background: var(--paper-2);
    border: 1px solid var(--border);
    padding: 16px;
    font-family: var(--font-mono);
  }

  .btn {
    padding: 16px 32px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    transition: var(--t);
    display: inline-block;
  }

  .btn-primary {
    background: var(--ink);
    color: var(--paper);
  }

  .btn-rim {
    border: 1px solid var(--border-strong);
    color: var(--ink);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .hero-editorial, .grid-split, .bento-grid, .main-legal-form .form-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-editorial h1 { font-size: 4rem; }
    .hero-image-box { order: -1; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const diagForm = document.querySelector('.retail-diagnosis-form');
    if (diagForm) {
      diagForm.addEventListener('submit', (e) => {
        e.preventDefault();
        diagForm.reset();
        diagForm.querySelector('.success-txt').style.display = 'block';
      });
    }
  });
</script>
