---
---
<section id="cta" aria-labelledby="cta-heading">
  <div class="cta-bg" aria-hidden="true">
    <div class="cta-orb"></div>
  </div>
  <div class="container">
    <div class="cta-inner">
      <div class="section-label" style="justify-content:center;" data-i18n="cta.label">Let's Build</div>
      <h2 class="cta-title" id="cta-heading" data-i18n="cta.title">Ready to build something that converts?</h2>
      <p class="cta-sub" data-i18n="cta.sub">Tell us where you are. We'll show you where to go.</p>
      <div class="cta-actions">
        <a href="https://cal.com/emrg" class="btn btn-primary" id="cta-primary-btn">
          <span data-i18n="hero.cta.primary">Book a 15-min Call</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="mailto:hello@emrg.studio" class="btn btn-outline" data-i18n="cta.email">Email Us</a>
      </div>
      <p class="cta-note" data-i18n="cta.note">We reply within 24–48 hours.</p>
    </div>
  </div>
</section>
