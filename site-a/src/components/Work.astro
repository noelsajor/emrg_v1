---
---
<section id="work" aria-labelledby="work-heading">
  <div class="container">
    <div class="work-header">
      <div>
        <div class="section-label" data-i18n="work.label">Featured Work</div>
        <h2 class="section-title" id="work-heading" data-i18n="work.title">Outcomes, not outputs.</h2>
      </div>
      <a href="#cta" class="btn btn-outline" data-i18n="work.viewAll">View All Work</a>
    </div>

    <div class="work-grid">
      <!-- Case 1 -->
      <article class="case-card reveal" aria-labelledby="case-1-brand">
        <div class="case-thumb thumb-1" aria-hidden="true">
          <div class="case-thumb-inner">
            <div style="position:absolute;width:150px;height:150px;background:rgba(139,92,246,0.2);border-radius:50%;top:20px;right:20px;filter:blur(40px);"></div>
            <div style="text-align:center;z-index:1;position:relative;">
              <div class="thumb-label">SOLERA</div>
              <div class="thumb-sub" data-i18n="work.c1.industry">Skincare DTC</div>
            </div>
          </div>
        </div>
        <div class="case-body">
          <div class="case-tag" data-i18n="work.c1.tag">Shopify Build · Brand Identity</div>
          <h3 class="case-brand" id="case-1-brand">Solera</h3>
          <p class="case-problem" data-i18n="work.c1.problem">Entering a saturated skincare market with no digital presence. Needed a brand and store capable of converting cold traffic from day one.</p>
          <div class="case-metrics" role="list">
            <div class="metric" role="listitem">
              <div class="metric-val pos">+28%</div>
              <div class="metric-label" data-i18n="work.metric.cvr">CVR vs industry avg</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">6 <span data-i18n="work.metric.days">Days</span></div>
              <div class="metric-label" data-i18n="work.metric.launch">Launch timeline</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">+19%</div>
              <div class="metric-label" data-i18n="work.metric.aov">AOV lift</div>
            </div>
          </div>
          <div class="case-cta">
            <a href="#cta" class="btn btn-ghost btn-sm" id="case1-btn">
              <span data-i18n="work.readCase">Read Case Study</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Case 2 -->
      <article class="case-card reveal reveal-delay-1" aria-labelledby="case-2-brand">
        <div class="case-thumb thumb-2" aria-hidden="true">
          <div class="case-thumb-inner">
            <div style="position:absolute;width:140px;height:140px;background:rgba(52,211,153,0.15);border-radius:50%;bottom:10px;left:20px;filter:blur(40px);"></div>
            <div style="text-align:center;z-index:1;position:relative;">
              <div class="thumb-label">VARKA</div>
              <div class="thumb-sub" data-i18n="work.c2.industry">Nutrition DTC</div>
            </div>
          </div>
        </div>
        <div class="case-body">
          <div class="case-tag" data-i18n="work.c2.tag">WooCommerce Rebuild · Growth Systems</div>
          <h3 class="case-brand" id="case-2-brand">Varka</h3>
          <p class="case-problem" data-i18n="work.c2.problem">Existing WooCommerce store suffering from slow load times, poor mobile UX, and no post-purchase retention system in place.</p>
          <div class="case-metrics" role="list">
            <div class="metric" role="listitem">
              <div class="metric-val pos">-42%</div>
              <div class="metric-label" data-i18n="work.metric.loadtime">Page load time</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">+22%</div>
              <div class="metric-label" data-i18n="work.metric.repeat">Repeat purchase rate</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">+14%</div>
              <div class="metric-label" data-i18n="work.metric.aov">AOV lift</div>
            </div>
          </div>
          <div class="case-cta">
            <a href="#cta" class="btn btn-ghost btn-sm" id="case2-btn">
              <span data-i18n="work.readCase">Read Case Study</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Case 3 -->
      <article class="case-card reveal reveal-delay-2" aria-labelledby="case-3-brand">
        <div class="case-thumb thumb-3" aria-hidden="true">
          <div class="case-thumb-inner">
            <div style="position:absolute;width:160px;height:160px;background:rgba(236,72,153,0.15);border-radius:50%;top:0;right:0;filter:blur(50px);"></div>
            <div style="text-align:center;z-index:1;position:relative;">
              <div class="thumb-label">DUNE</div>
              <div class="thumb-sub" data-i18n="work.c3.industry">Apparel DTC</div>
            </div>
          </div>
        </div>
        <div class="case-body">
          <div class="case-tag" data-i18n="work.c3.tag">Shopify Build · Brand · CRO</div>
          <h3 class="case-brand" id="case-3-brand">Dune</h3>
          <p class="case-problem" data-i18n="work.c3.problem">Direct-to-consumer apparel brand pivoting from wholesale. Needed a flagship DTC store and full brand system built for conversion.</p>
          <div class="case-metrics" role="list">
            <div class="metric" role="listitem">
              <div class="metric-val pos">+34%</div>
              <div class="metric-label" data-i18n="work.metric.cvrImprov">CVR improvement</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">7 <span data-i18n="work.metric.days">Days</span></div>
              <div class="metric-label" data-i18n="work.metric.fullLaunch">Full launch</div>
            </div>
            <div class="metric" role="listitem">
              <div class="metric-val pos">3.8x</div>
              <div class="metric-label" data-i18n="work.metric.roas">ROAS month 1</div>
            </div>
          </div>
          <div class="case-cta">
            <a href="#cta" class="btn btn-ghost btn-sm" id="case3-btn">
              <span data-i18n="work.readCase">Read Case Study</span>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
