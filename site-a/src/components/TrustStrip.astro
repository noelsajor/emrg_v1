<section id="trust" aria-label="Key stats">
  <div class="container">
    <div class="trust-grid" role="list">
      <div class="trust-item reveal" role="listitem">
        <div class="trust-num">25<span>+</span></div>
        <div class="trust-label" data-i18n="trust.stat1">Ecommerce Builds</div>
      </div>
      <div class="trust-item reveal reveal-delay-1" role="listitem">
        <div class="trust-num">5<span>–7</span></div>
        <div class="trust-label" data-i18n="trust.stat2">Day Avg. Launch</div>
      </div>
      <div class="trust-item reveal reveal-delay-2" role="listitem">
        <div class="trust-num"><span>+</span>22<span>%</span></div>
        <div class="trust-label" data-i18n="trust.stat3">Avg. CVR Improvement</div>
      </div>
      <div class="trust-item reveal reveal-delay-3" role="listitem">
        <div class="trust-num">100<span>%</span></div>
        <div class="trust-label" data-i18n="trust.stat4">Conversion-Focused by Default</div>
      </div>
    </div>
    <p class="trust-disclaimer" data-i18n="trust.disclaimer">Results vary by business, product, and market conditions.</p>
  </div>
</section>
