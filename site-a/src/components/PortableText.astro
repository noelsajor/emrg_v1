---
import { toHTML } from '@portabletext/to-html';
import { urlFor } from '../lib/image';

interface Props {
  value: any;
}

const { value } = Astro.props;

const customComponents = {
  types: {
    image: ({ value }: any) => {
      return `<figure class="post-image">
        <img src="${urlFor(value).width(1200).url()}" alt="${value.alt || ''}" loading="lazy" />
        ${value.caption ? `<figcaption>${value.caption}</figcaption>` : ''}
      </figure>`;
    },
  },
  block: {
    h2: ({ children }: any) => `<h2 class="post-h2">${children}</h2>`,
    h3: ({ children }: any) => `<h3 class="post-h3">${children}</h3>`,
    normal: ({ children }: any) => `<p class="post-p">${children}</p>`,
    blockquote: ({ children }: any) => `<blockquote class="post-quote">${children}</blockquote>`,
  },
  list: {
    bullet: ({ children }: any) => `<ul class="post-ul">${children}</ul>`,
    number: ({ children }: any) => `<ol class="post-ol">${children}</ol>`,
  },
};

const html = toHTML(value, { components: customComponents });
---

<div class="portable-text" set:html={html} />

<style is:global>
  .portable-text {
    color: var(--fg);
    line-height: 1.7;
    font-size: 1.1rem;
  }

  .post-p {
    margin-bottom: 24px;
    color: var(--gray-2);
  }

  .post-h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 48px 0 24px;
    color: var(--fg);
    font-family: 'Syne', sans-serif;
  }

  .post-h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 32px 0 16px;
    color: var(--fg);
    font-family: 'Syne', sans-serif;
  }

  .post-quote {
    border-left: 4px solid var(--accent);
    padding: 16px 32px;
    margin: 40px 0;
    background: var(--bg-2);
    font-style: italic;
    font-size: 1.25rem;
    border-radius: 0 8px 8px 0;
  }

  .post-image {
    margin: 48px 0;
    border-radius: 12px;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-image figcaption {
    padding: 12px;
    font-size: 0.9rem;
    color: var(--gray-3);
    text-align: center;
    background: var(--bg-2);
  }

  .post-ul, .post-ol {
    margin-bottom: 32px;
    padding-left: 24px;
  }

  .post-ul li, .post-ol li {
    margin-bottom: 12px;
    color: var(--gray-2);
  }

  .post-ul li::marker {
    color: var(--accent-light);
  }
</style>
