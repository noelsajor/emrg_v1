---
---
<section class="about-hero">
  <div class="hero-bg">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-grid"></div>
  </div>
  <div class="container hero-inner">
    <div class="hero-badge">
      <div class="dot"></div>
      <span data-i18n="about.badge">Who we are</span>
    </div>
    <h1 data-i18n="about.title">Engineered for <br/><span>Ecommerce</span> Performance.</h1>
    <p class="hero-sub" data-i18n="about.sub">
      We bridge the gap between high-end brand identity and technical growth engineering. EMRG is a founder-led studio built for the next generation of DTC brands.
    </p>
  </div>
</section>

<section class="about-content">
  <div class="container">
    <div class="about-grid">
      <div class="content-block">
        <h2 class="display-sm" data-i18n="about.story_title">Our Story</h2>
        <p data-i18n="about.story_p1">
          EMRG was founded on a simple observation: the most successful ecommerce brands don't just have good products; they have integrated systems. Most agencies focus on either the "creative" or the "technical" side. We do both, simultaneously.
        </p>
        <p data-i18n="about.story_p2">
          By treating the brand, the store, and the growth infrastructure as a single cohesive unit, we eliminate the friction that usually slows down scaling.
        </p>
      </div>
      <div class="stats-sidebar">
        <div class="about-stat">
          <div class="val">7d</div>
          <div class="lbl">Avg. Launch</div>
        </div>
        <div class="about-stat">
          <div class="val">100%</div>
          <div class="lbl">Founder Led</div>
        </div>
        <div class="about-stat">
          <div class="val">20+</div>
          <div class="lbl">DTC Successes</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="about-focus reveal">
  <div class="container">
    <div class="section-header">
      <h2 class="display-sm" data-i18n="about.focus_title">Strategic Focus</h2>
      <p class="focus-sub" data-i18n="about.focus_sub">We specialize in industries where precision and performance are non-negotiable.</p>
    </div>
    <div class="focus-grid">
      <a href="/enfoque-salud" class="focus-card">
        <div class="focus-icon">01</div>
        <h3 data-i18n="about.focus_salud">Enfoque en Salud</h3>
        <p data-i18n="about.focus_salud_desc">Technical performance for health and wellness brands.</p>
        <span class="focus-link">Explore →</span>
      </a>
      <a href="/enfoque-legal" class="focus-card">
        <div class="focus-icon">02</div>
        <h3 data-i18n="about.focus_legal">Enfoque Legal</h3>
        <p data-i18n="about.focus_legal_desc">Rigid branding and communication systems for law firms.</p>
        <span class="focus-link">Explore →</span>
      </a>
      <a href="/enfoque-pymes" class="focus-card">
        <div class="focus-icon">03</div>
        <h3 data-i18n="about.focus_pymes">Enfoque Emprendedore/PYMES</h3>
        <p data-i18n="about.focus_pymes_desc">Scalable growth engines for small and medium businesses.</p>
        <span class="focus-link">Explore →</span>
      </a>
      <a href="/enfoque-retail" class="focus-card">
        <div class="focus-icon">04</div>
        <h3 data-i18n="about.focus_retail">Enfoque Retail/Mayoristas</h3>
        <p data-i18n="about.focus_retail_desc">Complex B2B and B2C infrastructure for scale.</p>
        <span class="focus-link">Explore →</span>
      </a>
      <a href="/enfoque-marca-personal" class="focus-card">
        <div class="focus-icon">05</div>
        <h3 data-i18n="about.focus_personal">Enfoque Marca Personal</h3>
        <p data-i18n="about.focus_personal_desc">Authority systems for experts and thought leaders.</p>
        <span class="focus-link">Explore →</span>
      </a>
    </div>
  </div>
</section>

<style>
  .about-hero {
    position: relative;
    padding: 180px 0 100px;
    overflow: hidden;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .about-content {
    padding: 100px 0;
    background: var(--bg-2);
  }
  h1 span {
    color: var(--accent-light);
  }
  .display-sm {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 100px;
  }
  .content-block p {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 28px;
  }
  .stats-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .about-stat {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
  }
  .about-stat .val {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1;
    margin-bottom: 4px;
  }
  .about-stat .lbl {
    font-size: 0.8rem;
    color: var(--gray-2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 64px;
    }
    .stats-sidebar {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .about-focus {
    padding: 120px 0;
    background: var(--bg);
  }
  .section-header {
    margin-bottom: 64px;
    max-width: 600px;
  }
  .focus-sub {
    color: var(--gray-2);
    font-size: 1.1rem;
  }
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 32px;
  }
  .focus-card {
    background: var(--bg-2);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 40px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }
  .focus-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at top right, rgba(0, 229, 200, 0.05), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .focus-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent);
    background: rgba(0, 229, 200, 0.02);
  }
  .focus-card:hover::before {
    opacity: 1;
  }
  .focus-icon {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 24px;
    opacity: 0.6;
    letter-spacing: 0.2em;
  }
  .focus-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 16px;
  }
  .focus-card p {
    font-size: 0.95rem;
    color: var(--gray-2);
    line-height: 1.5;
    margin-bottom: 24px;
    flex-grow: 1;
  }
  .focus-link {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  @media (max-width: 768px) {
    .about-hero { padding-top: 140px; }
    .display-sm { font-size: 2rem; }
    .focus-grid { grid-template-columns: 1fr; }
  }
</style>
