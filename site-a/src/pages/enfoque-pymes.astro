---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout title="Enfoque Emprendedores y PYMES | EMRG" description="Diseño de sitios web desde cero y optimización estratégica para que tu marca despegue. Deja de ser invisible y captura clientes 24/7.">
  <Nav />
  
  <main id="pymes-focus">
    <section class="hero-section section">
      <div class="container hero-grid-pymes">
        <div class="hero-copy">
          <p class="eyebrow-pymes">Digital Growth</p>
          <h1>Deja de ser invisible. Es hora de que el mundo <span class="highlight">encuentre tu negocio.</span></h1>
          <p class="hero-text-pymes">
            Diseño de sitios web desde cero y optimización estratégica para que tu marca despegue. 
            Construimos la base técnica que tu visión merece.
          </p>
          
          <div class="hero-actions-pymes">
            <a class="btn btn-primary" href="#contacto">¡Sí, quiero lanzar mi negocio!</a>
            <a class="btn btn-secondary" href="#hook">Saber más</a>
          </div>

          <ul class="trust-list-pymes" aria-label="Beneficios clave">
            <li>Ventas 24/7 ininterrumpidas</li>
            <li>Alcance nacional y escalable</li>
            <li>Imagen profesional y sólida</li>
          </ul>
        </div>

        <div class="hero-image-pymes">
          <img src="/images/hero-pymes.png" alt="Crecimiento Digital PYMES" class="hero-img-main" />
        </div>
      </div>
    </section>

    <section id="hook" class="section section-alt-pymes">
      <div class="container">
        <div class="hook-box reveal">
          <h2 class="hook-title">¿Sabías que el <span class="accent">80% de las personas</span> investigan en internet antes de comprar?</h2>
          <p class="hook-sub">Si no estás allí cuando te buscan, estás regalando tus clientes a la competencia. En EMRG transformamos tu presencia digital en un motor de ventas constante.</p>
        </div>
      </div>
    </section>

    <section class="section dark-bg">
       <div class="container">
          <h2 class="section-title">Beneficios de <span class="highlight">Impacto Real.</span></h2>
          <div class="pillars-grid">
             <div class="pillar-card">
                <div class="p-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <h3>Ventas 24/7</h3>
                <p>Tu negocio nunca cierra. Recibe pedidos y consultas mientras duermes o te enfocas en operar.</p>
             </div>
             <div class="pillar-card">
                <div class="p-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h3>Alcance Nacional</h3>
                <p>Rompe las barreras geográficas y llega a clientes en todo el país con una logística simplificada.</p>
             </div>
             <div class="pillar-card">
                <div class="p-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3>Profesionalismo</h3>
                <p>Gana la confianza de tus clientes con una imagen sólida que valida la calidad de tu trabajo.</p>
             </div>
          </div>
       </div>
    </section>

    <section id="servicios" class="section">
      <div class="container">
        <h2 class="section-title">Paquetes de <span class="highlight">Despegue.</span></h2>
        <div class="services-list">
          <div class="service-item">
            <h3>Creación de Tienda Online</h3>
            <p>E-commerce fácil de usar, autogestionable y diseñado para maximizar conversiones.</p>
          </div>
          <div class="service-item">
            <h3>Optimización SEO</h3>
            <p>Aparece en los primeros resultados desde el día 1. No solo hacemos webs, hacemos que te encuentren.</p>
          </div>
          <div class="service-item">
            <h3>Gestión de Contenidos</h3>
            <p>No te preocupes por qué escribir. Nosotros creamos el copy que conecta con tu audiencia por ti.</p>
          </div>
          <div class="service-item">
            <h3>Soporte Estratégico</h3>
            <p>Acompañamiento continuo para que tu negocio siga escalando al ritmo del mercado.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-social-proof">
      <div class="container">
        <h2 class="section-title centeredText">Lo que dicen <span class="highlight">nuestros clientes.</span></h2>
        <div class="testimonial-carousel" id="pymes-carousel">
          <div class="carousel-track">
            <div class="testimonial-card active">
              <p class="t-quote">"Pasamos de vender localmente a enviar a todo el país en menos de un mes. El sistema que montaron es impecable."</p>
              <div class="t-author">Fundadora — Tienda de Diseño</div>
            </div>
            <div class="testimonial-card">
              <p class="t-quote">"Por primera vez mi negocio aparece primero en Google. La inversión se recuperó en apenas dos semanas."</p>
              <div class="t-author">Dueño — Empresa de Distribución</div>
            </div>
            <div class="testimonial-card">
              <p class="t-quote">"No tenía tiempo para la web ni los textos. Se encargaron de todo y el resultado es más profesional de lo que imaginé."</p>
              <div class="t-author">Gerente — Boutique de Servicios</div>
            </div>
          </div>
          <div class="carousel-nav">
            <button class="dot active" aria-label="Go to slide 1"></button>
            <button class="dot" aria-label="Go to slide 2"></button>
            <button class="dot" aria-label="Go to slide 3"></button>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="section">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info">
            <h2 class="section-title">¡Sí, quiero lanzar mi negocio al <br/><span class="highlight">mundo digital!</span></h2>
            <p>Completa el formulario y reserva tu auditoría gratuita. Es el primer paso para dejar de ser invisible.</p>
            <div class="form-perks">
               <div>✓ Análisis de competencia online</div>
               <div>✓ Plan de digitalización personalizado</div>
               <div>✓ Presupuesto sin sorpresas</div>
            </div>
          </div>
          <form class="diagnosis-form pymes-form">
            <div class="form-grid">
               <input type="text" placeholder="Tu Nombre completo" required />
               <input type="text" placeholder="Nombre de tu negocio" required />
            </div>
            <div class="form-grid">
               <select required>
                  <option value="">Tu objetivo hoy</option>
                  <option>Crear mi primera web</option>
                  <option>Montar una tienda online</option>
                  <option>Mejorar mi web actual</option>
                  <option>Ganar más clientes</option>
               </select>
               <input type="tel" placeholder="WhatsApp para contactarte" required />
            </div>
            <textarea placeholder="Cuéntanos brevemente sobre tu negocio y qué te gustaría lograr..." required></textarea>
            <input type="email" placeholder="Email corporativo / personal" required />
            <button type="submit" class="btn btn-primary">Solicitar Auditoría Ahora</button>
            <p class="success-msg" style="display:none; margin-top: 1rem; color: var(--accent); font-weight: 800;">¡Recibido! Nos pondremos en contacto muy pronto para despegar tu negocio.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <CtaSection />
  <Footer />
</BaseLayout>

<style>
  :root {
    --pymes-accent: #a78bfa;
    --pymes-accent-dark: #7c3aed;
    --void: #09090b;
    --glass: rgba(255, 255, 255, 0.02);
    --border: rgba(255, 255, 255, 0.07);
    --surface: #121214;
  }

  main#pymes-focus {
    background: var(--void);
    color: #fff;
    font-family: 'Syne', sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .section {
    padding: 100px 0;
  }

  .section-alt-pymes {
    background: #0d0d10;
  }

  .highlight {
    color: var(--pymes-accent);
  }

  .accent {
    color: var(--pymes-accent);
  }

  .centeredText {
    text-align: center;
  }

  /* REFACTORED HERO */
  .hero-section {
    padding: 160px 0 100px;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero-grid-pymes {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .hero-copy {
    z-index: 2;
  }

  .eyebrow-pymes {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pymes-accent);
    margin-bottom: 24px;
  }

  .eyebrow-pymes::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--pymes-accent);
  }

  .hero-copy h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 28px;
    max-width: 18ch;
  }

  .hero-text-pymes {
    font-size: 1.15rem;
    color: #a1a1aa;
    max-width: 50ch;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .hero-actions-pymes {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
  }

  .trust-list-pymes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .trust-list-pymes li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9rem;
    color: #e2e4e9;
    font-weight: 500;
  }

  .trust-list-pymes li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--pymes-accent);
    border-radius: 50%;
  }

  .hero-image-pymes {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    aspect-ratio: 16/11;
  }

  .hero-img-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* HOOK SECTION */
  .hook-box {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 60px;
    text-align: center;
    border-radius: 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .hook-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .hook-sub {
    font-size: 1.1rem;
    color: #a1a1aa;
    line-height: 1.6;
  }

  /* PILLARS & SERVICES */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 3rem;
    letter-spacing: -0.03em;
  }

  .pillars-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 24px;
  }

  .pillar-card {
     padding: 40px;
     background: var(--surface);
     border: 1px solid var(--border);
     border-radius: 16px;
     transition: all 0.3s;
  }

  .pillar-card:hover { border-color: var(--pymes-accent); transform: translateY(-5px); }
  .p-icon { color: var(--pymes-accent); margin-bottom: 1.5rem; }
  .pillar-card h3 { font-size: 1.5rem; margin-bottom: 1rem; }
  .pillar-card p { color: #a1a1aa; font-size: 0.9rem; }

  .services-list {
     display: grid;
     grid-template-columns: repeat(2, 1fr);
     gap: 24px;
  }

  .service-item {
     padding: 40px;
     background: var(--surface);
     border: 1px solid var(--border);
     border-radius: 16px;
  }

  /* TESTIMONIALS */
  .testimonial-carousel {
    max-width: 800px;
    margin: 40px auto 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 20px;
  }

  .carousel-track { display: flex; transition: transform 0.6s ease; }
  .testimonial-card { min-width: 100%; padding: 40px; text-align: center; opacity: 0; transition: opacity 0.4s; }
  .testimonial-card.active { opacity: 1; }
  .t-quote { font-size: 1.4rem; font-style: italic; margin-bottom: 1.5rem; }
  .t-author { font-size: 0.8rem; text-transform: uppercase; color: var(--pymes-accent); font-weight: 700; }
  .carousel-nav { display: flex; justify-content: center; gap: 8px; margin-top: 20px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); border: none; cursor: pointer; }
  .dot.active { background: var(--pymes-accent); transform: scale(1.3); }

  /* CONTACT FORM */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: center;
  }

  .diagnosis-form {
    background: #0d0d10;
    padding: 40px;
    border: 1px solid var(--border);
    border-radius: 24px;
  }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  input, select, textarea { 
    background: var(--void); 
    border: 1px solid var(--border); 
    padding: 14px; 
    color: #fff; 
    width: 100%; 
    border-radius: 8px; 
  }

  /* REUSABLE BTNS */
  .btn-primary {
    background: var(--pymes-accent);
    color: var(--void);
    padding: 14px 28px;
    font-weight: 700;
    border-radius: 8px;
    transition: 0.3s;
    text-decoration: none;
    text-align: center;
  }

  .btn-secondary {
    border: 1px solid var(--border);
    color: #fff;
    padding: 14px 28px;
    font-weight: 700;
    border-radius: 8px;
    transition: 0.3s;
    text-decoration: none;
    text-align: center;
  }

  .btn-primary:hover { background: #fff; transform: translateY(-2px); }
  .btn-secondary:hover { border-color: var(--pymes-accent); }

  @media (max-width: 1024px) {
    .hero-grid-pymes, .contact-grid, .pillars-grid, .services-list, .form-grid {
      grid-template-columns: 1fr;
    }
    .hero-image-pymes { order: -1; }
    .hero-copy h1 { max-width: none; }
    .section { padding: 60px 0; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Form logic
    const form = document.querySelector('.pymes-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.reset();
        const success = form.querySelector('.success-msg');
        if (success) success.style.display = 'block';
      });
    }

    // Carousel logic
    const track = document.querySelector('.carousel-track');
    const slides = Array.from(track.children);
    const dts = Array.from(document.querySelectorAll('.dot'));
    let curIdx = 0;

    function updCarousel(idx) {
      track.style.transform = `translateX(-${idx * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      dts.forEach((d, i) => d.classList.toggle('active', i === idx));
      curIdx = idx;
    }

    dts.forEach((d, i) => d.addEventListener('click', () => updCarousel(i)));
    setInterval(() => updCarousel((curIdx + 1) % slides.length), 5000);
  });
</script>
