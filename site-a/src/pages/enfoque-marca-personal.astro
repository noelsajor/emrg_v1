---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout title="Enfoque Marca Personal | EMRG" description="Estrategia digital 360 para consultores, expertos y profesionales que quieren construir autoridad y atraer mejores clientes.">
  <Nav />
  
  <main class="expertise-page personal-theme">
    <section class="expertise-hero">
      <div class="container">
        <div class="hero-content">
          <div class="expertise-tag">Autoridad & Influencia</div>
          <h1>Convierte tu experiencia en <span class="highlight">activos digitales.</span></h1>
          <p class="hero-lead">Diseñamos sistemas de visibilidad para consultores, expertos y profesionales que quieren dejar de depender de referencias y liderar su categoría.</p>
          <div class="hero-actions">
            <a href="#contacto" class="btn-primary">Solicitar Auditoría</a>
            <a href="#framework" class="btn-secondary">Nuestro Framework</a>
          </div>
        </div>
      </div>
    </section>

    <section class="expertise-pillars">
       <div class="container">
          <div class="pillars-grid">
             <div class="pillar-card">
                <span class="p-num">01</span>
                <h3>Diferenciación</h3>
                <p>Ocupa un espacio único en la mente de tu cliente ideal.</p>
             </div>
             <div class="pillar-card">
                <span class="p-num">02</span>
                <h3>Visibilidad</h3>
                <p>Aparece cuando buscan soluciones que tú dominas.</p>
             </div>
             <div class="pillar-card">
                <span class="p-num">03</span>
                <h3>Autoridad</h3>
                <p>Construye confianza incluso antes del primer contacto.</p>
             </div>
          </div>
       </div>
    </section>

    <section class="expertise-problem section">
      <div class="container">
        <div class="grid-split">
          <div class="text-block">
            <h2 class="section-title">El experto <span class="accent">invisible.</span></h2>
            <p>Tener experiencia no garantiza ser el elegido. Muchos profesionales valiosos siguen dependiendo de recomendaciones esporádicas porque su presencia digital no refleja su nivel real.</p>
            
            <div class="issue-box">
               <div class="issue-item">
                  <strong>Mensaje Genérico</strong>
                  <p>Si tu propuesta suena igual que el resto, compites por precio.</p>
               </div>
               <div class="issue-item">
                  <strong>Activos Débiles</strong>
                  <p>Una web desactualizada que no valida tu credibilidad.</p>
               </div>
            </div>
          </div>
          <div class="visual-quote">
            <blockquote>
              "Tu marca personal no necesita más ruido. Necesita un sistema que convierta expertise en demanda."
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <section class="expertise-authority section dark-bg" id="framework">
      <div class="container">
        <h2 class="section-title centeredText">Framework de <span class="highlight">Autoridad 360.</span></h2>
        <div class="authority-steps">
          <div class="step-card">
            <div class="step-label">Fase 1</div>
            <h3>Diagnóstico</h3>
            <p>Auditoría de activos, puntos de fuga y posicionamiento actual.</p>
          </div>
          <div class="step-card">
            <div class="step-label">Fase 2</div>
            <h3>Claridad</h3>
            <p>Definición de mensaje comercial y especialización de nicho.</p>
          </div>
          <div class="step-card">
            <div class="step-label">Fase 3</div>
            <h3>Sistemas</h3>
            <p>Despliegue de web estratégica y activos de autoridad.</p>
          </div>
          <div class="step-card">
            <div class="step-label">Fase 4</div>
            <h3>Impacto</h3>
            <p>SEO personal y captación de leads de alto valor.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="expertise-services section">
      <div class="container">
        <h2 class="section-title">Estructura para <span class="highlight">Expertos.</span></h2>
        <div class="services-list">
          <div class="service-item">
            <h3>SEO de Autoridad</h3>
            <p>Posicionamos tus servicios y expertise para búsquedas de alta intención.</p>
          </div>
          <div class="service-item">
            <h3>Web Estratégica</h3>
            <p>Arquitectura de conversión diseñada específicamente para profesionales.</p>
          </div>
          <div class="service-item">
            <h3>Embudo de Expertos</h3>
            <p>Sistema de captación de leads para consultores y mentores.</p>
          </div>
          <div class="service-item">
            <h3>Reposicionamiento Digital</h3>
            <p>Evolucionamos tu marca para atraer clientes de mayor nivel.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="expertise-contact section">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info">
            <h2 class="section-title">Construyamos tu <br/><span class="highlight">Autoridad Digital.</span></h2>
            <p>Analizamos el estado actual de tu marca personal y trazamos un plan para elevar tu demanda.</p>
            <div class="form-perks">
               <div>✓ Auditoría de posicionamiento</div>
               <div>✓ Análisis de activos digitales</div>
               <div>✓ Roadmap de especialización</div>
            </div>
          </div>
          <form class="diagnosis-form personal-form">
            <div class="form-grid">
               <input type="text" placeholder="Tu Nombre completo" required />
               <input type="text" placeholder="Especialidad / Profesión" required />
            </div>
            <input type="text" placeholder="Nombre de tu marca o proyecto" required />
            <div class="form-grid">
               <select required>
                  <option value="">Objetivo Principal</option>
                  <option>Ganar Visibilidad</option>
                  <option>Fortalecer Autoridad</option>
                  <option>Captar Mejores Clientes</option>
                  <option>Otro</option>
               </select>
               <input type="url" placeholder="Web Actual (si tienes)" />
            </div>
            <textarea placeholder="Cuéntanos sobre tu expertise y qué buscas lograr..." required></textarea>
            <div class="form-grid">
               <input type="email" placeholder="Email" required />
               <input type="tel" placeholder="WhatsApp" required />
            </div>
            <button type="submit" class="btn-primary">Solicitar Auditoría</button>
            <p class="success-msg" style="display:none; margin-top: 1rem; color: var(--accent);">Auditoría enviada. Revisaremos tu caso personalmente.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <CtaSection />
  <Footer />
</BaseLayout>

<style>
  :root {
    --accent: #f0abfc;
    --accent-dark: #d946ef;
    --void: #09090b;
    --glass: rgba(255, 255, 255, 0.02);
    --border: rgba(255, 255, 255, 0.07);
  }

  .expertise-page {
    background: var(--void);
    color: #fff;
    font-family: 'Syne', sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 120px 0;
  }

  .highlight {
    color: var(--accent);
  }

  .accent {
    color: var(--accent-dark);
  }

  .centeredText {
    text-align: center;
  }

  .expertise-tag {
    display: inline-block;
    padding: 6px 16px;
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
    color: var(--accent);
  }

  .expertise-hero {
    padding: 220px 0 100px;
  }

  .expertise-hero h1 {
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.85;
    letter-spacing: -0.05em;
    margin-bottom: 2.5rem;
  }

  .hero-lead {
    font-size: 1.3rem;
    color: #a1a1aa;
    max-width: 650px;
    line-height: 1.5;
    margin-bottom: 3.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
  }

  .pillars-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 30px;
     border-top: 1px solid var(--border);
     padding-top: 60px;
  }

  .pillar-card {
     padding: 40px;
     background: var(--glass);
     border: 1px solid var(--border);
  }

  .p-num {
     display: block;
     font-size: 1rem;
     color: var(--accent);
     margin-bottom: 1.5rem;
     font-weight: 800;
  }

  .pillar-card h3 {
     font-size: 1.8rem;
     margin-bottom: 1rem;
  }

  .grid-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 120px;
    align-items: center;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: 2.5rem;
    line-height: 0.95;
  }

  .text-block p {
    font-size: 1.2rem;
    color: #a1a1aa;
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .issue-box {
     display: grid;
     gap: 2rem;
  }

  .issue-item strong {
     display: block;
     color: var(--accent);
     margin-bottom: 0.5rem;
  }

  .visual-quote {
     font-size: 2.5rem;
     line-height: 1.1;
     font-style: italic;
     color: #fff;
     position: relative;
  }
  .visual-quote::before {
     content: '"';
     position: absolute;
     left: -40px;
     top: -20px;
     font-size: 5rem;
     color: var(--accent);
     opacity: 0.2;
  }

  .dark-bg {
    background: #0d0d10;
  }

  .authority-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 60px;
  }

  .step-card {
    padding: 30px;
    border: 1px solid var(--border);
    transition: 0.3s;
  }
  .step-card:hover {
     background: var(--glass);
     border-color: var(--accent);
  }

  .step-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .services-list {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 30px;
     margin-top: 40px;
  }

  .service-item {
     padding: 50px;
     background: var(--glass);
     border: 1px solid var(--border);
  }

  .service-item h3 {
     font-size: 2rem;
     margin-bottom: 1.5rem;
     color: #fff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 100px;
  }

  .form-perks {
     margin-top: 3rem;
     display: grid;
     gap: 1rem;
     font-size: 1.1rem;
     color: var(--accent);
  }

  .diagnosis-form {
    display: grid;
    gap: 1.5rem;
    background: #0f0f13;
    padding: 60px;
    border: 1px solid var(--border);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  input, select, textarea {
    background: transparent;
    border: 1px solid var(--border);
    padding: 1.25rem;
    color: #fff;
    font-family: inherit;
    width: 100%;
  }

  textarea {
    height: 120px;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--void);
    padding: 1.25rem 2.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border: none;
    cursor: pointer;
    transition: 0.3s;
    text-align: center;
  }

  .btn-primary:hover {
    background: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 1px solid var(--border);
    padding: 1.25rem 2.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: 0.3s;
  }

  @media (max-width: 1024px) {
    .grid-split, .contact-grid, .pillars-grid, .authority-steps, .services-list, .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.personal-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.reset();
        form.querySelector('.success-msg').style.display = 'block';
      });
    }
  });
</script>
