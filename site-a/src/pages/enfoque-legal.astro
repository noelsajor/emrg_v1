---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout title="Enfoque Legal | EMRG" description="SEO y captación de clientes para abogados que quieren dominar Google en su ciudad.">
  <Nav />
  
  <main class="legal-page">
    <section class="hero-legal">
      <div class="container hero-grid-legal">
        <div class="hero-copy reveal">
          <p class="eyebrow">Especialistas en crecimiento para el sector legal</p>
          <h1>Expertos en <span class="accent-txt">Captación Legal</span> y SEO para Abogados.</h1>
          <p class="hero-sub">
            Ayudamos a despachos y firmas legales a ganar visibilidad, aumentar consultas cualificadas
            y convertir su web en una herramienta real de captación. Sin estrategias genéricas.
            Solo marketing digital diseñado específicamente para abogados.
          </p>
          
          <div class="hero-actions">
            <a href="#contacto" class="btn btn-primary">Solicitar auditoría gratuita</a>
            <a href="#casos" class="btn btn-secondary">Ver casos de éxito</a>
          </div>
          
          <ul class="trust-list-legal">
            <li>Estrategias especializadas</li>
            <li>SEO Local orientado a consultas</li>
            <li>Webs de alta confianza</li>
          </ul>
        </div>
        
        <aside class="hero-card-legal reveal">
          <div class="card-inner">
            <p class="card-label">Propuesta de Valor</p>
            <ul class="metric-list-legal">
              <li>
                <strong>Más visibilidad</strong>
                <span>para búsquedas legales de alto valor</span>
              </li>
              <li>
                <strong>Más autoridad</strong>
                <span>con una presencia digital premium y creíble</span>
              </li>
              <li>
                <strong>Más consultas</strong>
                <span>desde SEO y optimización de conversión técnica</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <div class="logos-strip reveal">
      <div class="container logos-flex">
        <span>SEO PARA ABOGADOS</span>
        <span>CAPTACIÓN LEGAL</span>
        <span>DISEÑO WEB JURÍDICO</span>
        <span>SEO LOCAL</span>
        <span>CRO LEGAL</span>
      </div>
    </div>

    <section class="section problem-section">
      <div class="container">
        <div class="section-heading reveal">
          <p class="eyebrow">El Problema</p>
          <h2>La mayoría de los despachos pierden oportunidades por una <em>presencia digital débil.</em></h2>
          <p class="p-sub">
            Muchos abogados confían en recomendaciones, pero hoy el cliente también compara y evalúa credibilidad online antes de contactar. Si tu web no transmite confianza, las oportunidades terminan en otro despacho.
          </p>
        </div>

        <div class="problem-grid-legal">
          <article class="p-card reveal">
            <div class="card-icon">01</div>
            <h3>Invisibilidad en Google</h3>
            <p>Si tu despacho no posiciona para términos locales o áreas de práctica, estás dejando demanda activa en manos de la competencia más digitalizada.</p>
          </article>
          <article class="p-card reveal">
            <div class="card-icon">02</div>
            <h3>Baja conversión web</h3>
            <p>Diseños genéricos y formularios mal planteados reducen la confianza. Muchos despachos atraen tráfico pero no generan consultas reales.</p>
          </article>
          <article class="p-card reveal">
            <div class="card-icon">03</div>
            <h3>Falta de estrategia</h3>
            <p>Tener una web no es suficiente. Hace falta un sistema pensado para atraer, convencer y convertir potenciales clientes legales de forma consistente.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section authority-legal">
      <div class="container">
        <div class="section-heading reveal">
          <p class="eyebrow">Metodología</p>
          <h2>Una estrategia creada para despachos, no una <em>adaptación genérica.</em></h2>
        </div>
        
        <div class="auth-grid-legal">
          <div class="auth-item reveal">
             <h3>Enfoque Sectorial</h3>
             <p>Arquitectura SEO y elementos de conversión que responden a cómo un cliente elige a su abogado.</p>
          </div>
          <div class="auth-item reveal">
             <h3>Orientación a Negocio</h3>
             <p>No buscamos solo tráfico, diseñamos para atraer consultas cualificadas según tu área de práctica.</p>
          </div>
          <div class="auth-item reveal">
             <h3>Optimización Técnica</h3>
             <p>Analizamos visibilidad y puntos de fuga para mejorar el rendimiento de captación de tu despacho.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section cases-legal" id="casos">
      <div class="container">
        <div class="section-heading reveal">
          <p class="eyebrow">Casos de Uso</p>
          <h2>Resultados reales en el <em>sector jurídico.</em></h2>
        </div>
        
        <div class="case-grid-legal">
          <article class="case-legal-card reveal">
            <span class="tag">DERECHO DE FAMILIA</span>
            <h3>Visibilidad Local</h3>
            <p>Reestructuración y SEO local para captar búsquedas relevantes en zonas de alta competencia.</p>
            <ul class="case-bullets">
              <li>Arquitectura por especialidades</li>
              <li>Sistemas de confianza</li>
              <li>Optimización de agendamiento</li>
            </ul>
          </article>
          <article class="case-legal-card reveal">
            <span class="tag">DERECHO MERCANTIL</span>
            <h3>Autoridad Digital</h3>
            <p>Nueva propuesta web orientada a servicios premium, con foco en reputación y captación de clientes de alto valor.</p>
            <ul class="case-bullets">
              <li>Percepción profesional premium</li>
              <li>Filtrado de oportunidades</li>
              <li>Coherencia de marca</li>
            </ul>
          </article>
          <article class="case-legal-card reveal">
            <span class="tag">DERECHO PENAL</span>
            <h3>Conversión de Urgencia</h3>
            <p>Optimización del recorrido del usuario para aumentar contactos rápidos y reforzar la confianza en situaciones críticas.</p>
            <ul class="case-bullets">
              <li>Copy directo y persuasivo</li>
              <li>CTAs de alta visibilidad</li>
              <li>Estructura móvil acelerada</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section lead-magnet-legal">
      <div class="container lead-split">
        <div class="lead-info reveal">
          <p class="eyebrow">Recurso Gratuito</p>
          <h2>Guía: 12 errores que impiden a un despacho captar clientes en Google.</h2>
          <p>Un recurso práctico para identificar fallos frecuentes en SEO, estructura web y mensajes que frenan tu captación digital.</p>
          <ul class="checklist-legal">
             <li>Detecta debilidades de posicionamiento</li>
             <li>Evalúa tu nivel de confianza digital</li>
             <li>Identifica puntos críticos de fuga</li>
          </ul>
        </div>
        <div class="lead-form-box reveal">
           <form class="legal-form-inline">
              <div class="form-row">
                 <input type="text" placeholder="NOMBRE" required />
              </div>
              <div class="form-row">
                 <input type="email" placeholder="EMAIL PROFESIONAL" required />
              </div>
              <button class="btn btn-primary btn-block">DESCARGAR GUÍA</button>
           </form>
           <p class="success-note" style="display:none; color: var(--accent); margin-top: 1rem; font-weight: 600;">Enviado. Revisa tu email.</p>
        </div>
      </div>
    </section>

    <section class="section contact-legal" id="contacto">
      <div class="container contact-grid-legal">
        <div class="contact-copy reveal">
           <p class="eyebrow">Auditoría</p>
           <h2>Solicita una <em>Consulta Estratégica.</em></h2>
           <p>Revisamos tu visibilidad actual, posicionamiento local y oportunidades de captación para detectar dónde estás perdiendo clientes.</p>
           
           <div class="points-grid">
              <div class="point-card">
                 <h4>Qué revisamos</h4>
                 <p>SEO actual, estructura de servicios, mensajes de confianza y puntos de conversión.</p>
              </div>
              <div class="point-card">
                 <h4>Para quién es</h4>
                 <p>Despachos que quieren crecer con una estrategia profesional y especializada.</p>
              </div>
           </div>
        </div>
        <div class="contact-form-box reveal">
           <form class="legal-main-form">
              <div class="form-inner-grid">
                 <input type="text" placeholder="NOMBRE" required />
                 <input type="text" placeholder="FIRMA LEGAL" required />
                 <input type="text" placeholder="CIUDAD" required />
                 <input type="text" placeholder="ÁREA DE PRÁCTICA" required />
                 <input type="email" placeholder="EMAIL" required />
                 <input type="tel" placeholder="TELÉFONO" required />
              </div>
              <select required>
                 <option value="">OBJETIVO PRINCIPAL</option>
                 <option>Conseguir más clientes</option>
                 <option>Mejorar SEO</option>
                 <option>Rediseñar Web</option>
              </select>
              <button class="btn btn-primary btn-block">SOLICITAR AUDITORÍA</button>
           </form>
           <p class="main-success" style="display:none; color: var(--accent); margin-top: 1rem; font-weight: 600;">Solicitud recibida. Te contactaremos pronto.</p>
        </div>
      </div>
    </section>

    <CtaSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal-page {
    background: var(--bg);
  }

  .accent-txt {
    color: var(--accent);
  }

  .hero-legal {
    padding: 160px 0 100px;
    background: radial-gradient(circle at 10% 10%, var(--accent-glow), transparent 40%);
  }

  .hero-grid-legal {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--border);
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font);
    font-size: 0.9rem;
    font-weight: 600;
    transition: var(--transition);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  .hero-sub {
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 40px;
    color: var(--gray-2);
  }

  .hero-actions {
    display: flex;
    gap: 20px;
    margin-bottom: 60px;
  }

  .trust-list-legal {
    display: flex;
    gap: 15px;
    list-style: none;
    padding: 0;
  }

  .trust-list-legal li {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--white);
    padding: 12px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-card-legal .card-inner {
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.4);
  }

  .card-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    letter-spacing: 0.1em;
  }

  .metric-list-legal {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 24px;
  }

  .metric-list-legal li {
    padding-left: 20px;
    border-left: 2px solid var(--accent);
  }

  .metric-list-legal strong {
    display: block;
    color: var(--white);
    font-size: 1.1rem;
    margin-bottom: 4px;
  }

  .metric-list-legal span {
    font-size: 0.9rem;
    color: var(--gray-2);
  }

  .logos-strip {
    padding: 24px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
  }

  .logos-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logos-flex span {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--gray-3);
    letter-spacing: 0.2em;
  }

  .section-heading h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--white);
    max-width: 800px;
    margin-bottom: 24px;
  }

  .p-sub {
    font-size: 1.1rem;
    color: var(--gray-2);
    max-width: 700px;
  }

  .problem-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
  }

  .p-card {
    background: var(--bg-3);
    padding: 40px;
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .card-icon {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 24px;
  }

  .p-card h3 {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 16px;
  }

  .p-card p {
    font-size: 0.95rem;
    color: var(--gray-2);
  }

  .auth-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-top: 40px;
  }

  .auth-item h3 {
    color: var(--white);
    margin-bottom: 12px;
  }

  .auth-item p {
    color: var(--gray-2);
  }

  .case-grid-legal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 40px;
  }

  .case-legal-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 40px;
    border-radius: 16px;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 20px;
    display: block;
  }

  .case-legal-card h3 {
    margin-bottom: 16px;
  }

  .case-bullets {
    margin-top: 24px;
    padding-left: 18px;
    color: var(--gray-2);
    font-size: 0.9rem;
  }

  .case-bullets li+li {
    margin-top: 8px;
  }

  .lead-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    padding: 80px 0;
    background: var(--bg-2);
    border-radius: 20px;
    padding: 60px;
  }

  .checklist-legal {
    list-style: none;
    padding: 0;
    margin-top: 32px;
  }

  .checklist-legal li {
    padding-left: 28px;
    position: relative;
    margin-bottom: 12px;
    color: var(--white);
  }

  .checklist-legal li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .legal-form-inline input {
    width: 100%;
    background: var(--bg-3);
    border: 1px solid var(--border);
    padding: 16px;
    color: var(--white);
    margin-bottom: 16px;
  }

  .contact-grid-legal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    padding: 100px 0;
  }

  .points-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .point-card h4 {
    color: var(--white);
    margin-bottom: 8px;
  }

  .form-inner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .contact-form-box form input, 
  .contact-form-box form select {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 16px;
    color: var(--white);
  }

  .contact-form-box form select {
     margin-bottom: 16px;
  }

  @media (max-width: 1024px) {
    .hero-grid, .problem-grid-legal, .auth-grid-legal, .case-grid-legal, .lead-split, .contact-grid-legal {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .logos-flex {
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Form handlers
    const mainForm = document.querySelector('.legal-main-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        mainForm.reset();
        document.querySelector('.main-success').style.display = 'block';
      });
    }

    const inlineForm = document.querySelector('.legal-form-inline');
    if (inlineForm) {
      inlineForm.addEventListener('submit', (e) => {
        e.preventDefault();
        inlineForm.reset();
        document.querySelector('.success-note').style.display = 'block';
      });
    }
  });
</script>
