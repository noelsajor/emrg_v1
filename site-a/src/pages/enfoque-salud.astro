<script is:inline>
  // Form handling
  document.addEventListener('DOMContentLoaded', () => {
    const qualificationForm = document.querySelector(".qualification-form-health");
    
    if (qualificationForm) {
      qualificationForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const fields = qualificationForm.querySelectorAll("input[required], select[required]");
        const successMessage = qualificationForm.querySelector(".form-success");
        let firstInvalidField = null;
        let isValid = true;

        fields.forEach((field) => {
          const wrapper = field.closest(".form-row-health");
          const errorElement = wrapper ? wrapper.querySelector(".error-message") : null;
          let message = "";

          if (!field.value.trim()) {
            message = "Este campo es obligatorio.";
          } else if (field.type === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim())) {
            message = "Introduce un email válido.";
          } else if (
            field.type === "url" &&
            field.value.trim() !== "" &&
            !/^https?:\/\/.+/i.test(field.value.trim())
          ) {
            message = "Incluye una URL válida que empiece por http:// o https://";
          }

          if (message) {
            isValid = false;
            field.style.borderColor = "var(--danger, #ff4444)";
            if (errorElement) errorElement.textContent = message;
            if (!firstInvalidField) firstInvalidField = field;
          } else {
            field.style.borderColor = "";
            if (errorElement) errorElement.textContent = "";
          }
        });

        if (!isValid) {
          if (successMessage) successMessage.textContent = "";
          if (firstInvalidField) firstInvalidField.focus();
          return;
        }

        qualificationForm.reset();
        if (successMessage) {
          successMessage.textContent = "¡Solicitud enviada! Nos pondremos en contacto pronto.";
        }
      });
    }

    // Testimonial Carousel Logic (Synced with Pymes)
    const track = document.querySelector('#salud-carousel .carousel-track');
    if (track) {
      const slides = Array.from(track.children);
      const dots = Array.from(document.querySelectorAll('#salud-carousel .dot'));
      let currentSlide = 0;

      function updateCarousel(index) {
        track.style.transform = `translateX(-${index * 100}%)`;
        slides.forEach((slide, i) => {
          slide.classList.toggle('active', i === index);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
        currentSlide = index;
      }

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => updateCarousel(index));
      });

      // Auto-play
      setInterval(() => {
        let nextSlide = (currentSlide + 1) % slides.length;
        updateCarousel(nextSlide);
      }, 5000);
    }
  });
</script>
