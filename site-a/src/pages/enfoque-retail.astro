---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout title="Enfoque Retail y Mayoristas | EMRG" description="Gestión integral de marketing digital para negocios que venden en grande. Tiendas online de alto rendimiento y SEO para catálogos masivos.">
  <Nav />
  
  <main id="retail-focus">
    <section class="hero-section section">
      <div class="container hero-grid-retail">
        <div class="hero-copy">
          <div class="eyebrow-retail">Sector Retail</div>
          <h1>Lleva tu inventario a las pantallas de tus <span class="highlight">clientes ideales.</span></h1>
          <p class="hero-text-retail">Gestión integral de marketing digital para negocios que venden en grande. Construimos la infraestructura que soporta tu crecimiento masivo.</p>
          <div class="hero-actions-retail">
            <a href="#contacto" class="btn btn-primary">Escalar mis Ventas</a>
            <a href="#solucion" class="btn btn-secondary">Ver Servicios</a>
          </div>
        </div>
        <div class="hero-image-retail">
          <img src="/images/hero-retail.png" alt="Retail Management Dashboard" class="hero-img-main" />
        </div>
      </div>
    </section>

    <section class="section section-alt-retail">
       <div class="container">
          <div class="pillars-grid-retail">
             <div class="pillar-card-retail">
                <span class="p-num">01</span>
                <h3>Tiendas de Alto Rendimiento</h3>
                <p>E-commerce robusto preparado para manejar catálogos masivos y picos de tráfico extremo.</p>
             </div>
             <div class="pillar-card-retail">
                <span class="p-num">02</span>
                <h3>SEO de Categorías</h3>
                <p>Posicionamiento estratégico para productos específicos y categorías de alta demanda en el mercado.</p>
             </div>
             <div class="pillar-card-retail">
                <span class="p-num">03</span>
                <h3>Growth Automatizado</h3>
                <p>Email Marketing para carritos abandonados y promociones inteligentes que cierran ventas solos.</p>
             </div>
          </div>
       </div>
    </section>

    <section id="resultados" class="section">
      <div class="container">
        <div class="grid-split-retail">
          <div class="text-block">
            <h2 class="section-title">Enfoque en <span class="accent">Resultados.</span></h2>
            <p>No solo gestionamos, escalamos. Nuestras estrategias están diseñadas para convertir el tráfico en ingresos predecibles y sostenibles.</p>
            
            <div class="stats-retail-list">
               <div class="stat-retail-item">
                  <strong>+45% Conversión</strong>
                  <div class="bar-container"><div class="bar" style="width: 85%;"></div></div>
               </div>
               <div class="stat-retail-item">
                  <strong>+120% Tráfico Orgánico</strong>
                  <div class="bar-container"><div class="bar" style="width: 95%;"></div></div>
               </div>
            </div>
          </div>
          <div class="visual-quote">
            <blockquote>
              "Estrategias de contenido integral que convierten seguidores en compradores."
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <section id="solucion" class="section section-alt-retail">
      <div class="container">
        <h2 class="section-title">Servicios <span class="highlight">Clave.</span></h2>
        <div class="services-list-retail">
          <div class="service-item-retail">
            <h3>E-commerce Enterprise</h3>
            <p>Arquitectura web optimizada para catálogos dinámicos y transacciones fluidas de gran volumen.</p>
          </div>
          <div class="service-item-retail">
            <h3>Automatización CRM</h3>
            <p>Retención de clientes mediante flujos de email marketing que recuperan ventas perdidas.</p>
          </div>
          <div class="service-item-retail">
            <h3>SEO para Retail</h3>
            <p>Visibilidad orgánica total para tus términos de búsqueda más rentables y categorías estrella.</p>
          </div>
          <div class="service-item-retail">
            <h3>Social Cataloging</h3>
            <p>Gestión de redes sociales enfocada en catálogos de producto que impulsan la compra directa.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto" class="section">
      <div class="container">
        <div class="contact-grid-retail">
          <div class="contact-info">
            <h2 class="section-title">Hablemos de cómo <br/><span class="highlight">escalar tus ventas.</span></h2>
            <p>Completa el formulario y diseñaremos una hoja de ruta para llevar tu inventario al siguiente nivel digital este mismo mes.</p>
            <div class="form-perks">
               <div>✓ Auditoría de infraestructura actual</div>
               <div>✓ Análisis de competencia en categorías</div>
               <div>✓ Plan de automatización de ventas</div>
            </div>
          </div>
          <form class="qualification-form-retail retail-form">
            <div class="form-grid">
               <input type="text" placeholder="Tu Nombre" required />
               <input type="text" placeholder="Empresa / Retailer" required />
            </div>
            <div class="form-grid">
               <input type="text" placeholder="Volumen de Catálogo" required />
               <input type="text" placeholder="Ciudad" required />
            </div>
            <textarea placeholder="¿Cuál es tu meta de ventas para este trimestre?" required></textarea>
            <div class="form-grid">
               <input type="email" placeholder="Email Corporativo" required />
               <input type="tel" placeholder="WhatsApp" required />
            </div>
            <button type="submit" class="btn btn-primary btn-full">Hablemos hoy</button>
            <p class="success-msg" style="display:none; margin-top: 1rem; color: var(--accent);">Diseñaremos tu estrategia de escalado. Nos pondremos en contacto muy pronto.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <CtaSection />
  <Footer />
</BaseLayout>

<style>
  /* Base Overrides for Retail Focus */
  #retail-focus {
    background: var(--bg);
    color: #fff;
  }

  .hero-section {
    padding-top: 10rem;
    padding-bottom: 5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section {
    padding: 100px 0;
  }

  .section-alt-retail {
    background: var(--bg-2);
  }

  .highlight {
    color: var(--accent);
  }

  .accent {
    color: var(--accent-light);
  }

  /* Typography */
  #retail-focus h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 2rem;
    max-width: 18ch;
    letter-spacing: -0.02em;
  }

  .section-title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin-bottom: 2.5rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  /* Components */
  .eyebrow-retail {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .eyebrow-retail::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 15px var(--accent);
  }

  .hero-text-retail {
    font-size: 1.1rem;
    color: var(--gray-2);
    max-width: 50ch;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  /* Grid Layouts */
  .hero-grid-retail {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-image-retail {
    position: relative;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: 0 0 50px rgba(139, 92, 246, 0.15);
    width: 100%;
  }

  .hero-img-main {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    display: block;
    object-fit: cover;
  }

  .hero-actions-retail {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  /* Pillars */
  .pillars-grid-retail {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 1.5rem;
  }

  .pillar-card-retail {
     padding: 2.5rem 2rem;
     background: var(--bg-card);
     border: 1px solid var(--border);
     border-radius: var(--radius);
     transition: 0.3s;
  }

  .pillar-card-retail:hover {
    border-color: var(--accent);
    transform: translateY(-5px);
  }

  .p-num {
     display: block;
     font-size: 0.85rem;
     color: var(--accent);
     margin-bottom: 1.5rem;
     font-weight: 800;
  }

  .pillar-card-retail h3 {
     font-size: 1.5rem;
     margin-bottom: 1rem;
     line-height: 1.2;
  }

  /* Results Split */
  .grid-split-retail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .text-block p {
    font-size: 1.1rem;
    color: var(--gray-2);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .stats-retail-list {
     display: grid;
     gap: 1.5rem;
  }

  .stat-retail-item strong {
     display: block;
     color: var(--white);
     margin-bottom: 0.6rem;
     font-size: 1rem;
  }

  .bar-container {
    width: 100%;
    height: 4px;
    background: var(--border);
    border-radius: 100px;
  }

  .bar {
    height: 100%;
    background: var(--accent);
    border-radius: 100px;
    position: relative;
  }

  .visual-quote {
     font-size: 2rem;
     line-height: 1.2;
     font-style: italic;
     color: var(--white);
     opacity: 0.9;
  }

  /* Services List */
  .services-list-retail {
     display: grid;
     grid-template-columns: 1fr 1fr;
     gap: 1.5rem;
  }

  .service-item-retail {
     padding: 2.5rem;
     background: var(--bg-card);
     border: 1px solid var(--border);
     border-radius: var(--radius-lg);
  }

  .service-item-retail h3 {
     font-size: 1.8rem;
     margin-bottom: 1.2rem;
     color: var(--white);
  }

  /* Contact Grid */
  .contact-grid-retail {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }

  .form-perks {
     margin-top: 2.5rem;
     display: grid;
     gap: 1rem;
     font-size: 1rem;
     color: var(--accent-light);
  }

  .qualification-form-retail {
    display: grid;
    gap: 1.5rem;
    background: var(--bg-card);
    padding: 3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  input, select, textarea {
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border);
    padding: 1.1rem;
    color: #fff;
    font-family: inherit;
    width: 100%;
    border-radius: 4px;
    font-size: 0.95rem;
  }

  textarea {
    height: 110px;
    resize: none;
  }

  .btn-full {
    width: 100%;
  }

  /* Responsive Fixes */
  @media (max-width: 1024px) {
    .container { padding: 0 1.5rem; }
    .hero-grid-retail, .grid-split-retail, .contact-grid-retail, .pillars-grid-retail, .services-list-retail, .form-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-image-retail { order: -1; }
    .hero-section { padding-top: 8rem; }
    #retail-focus h1 { font-size: 2.2rem; }
    .visual-quote { font-size: 1.5rem; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.retail-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.reset();
        const success = form.querySelector('.success-msg');
        if (success) success.style.display = 'block';
      });
    }
  });
</script>
